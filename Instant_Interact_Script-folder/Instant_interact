-- ===================== GUI LOGIC =====================
local gui = createGUI()
local panelOpen = false
local PANEL_HEIGHT = 215

-- ===== Draggable Title Bar (Mobile + PC) =====
local dragging = false
local dragStart, startPos

local function updateDrag(inputPos)
    if dragging then
        local delta = inputPos - dragStart
        local newPos = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        gui.TitleBar.Position = newPos
        gui.MainFrame.Position = UDim2.new(
            newPos.X.Scale, newPos.X.Offset,
            newPos.Y.Scale, newPos.Y.Offset + 42
        )
    end
end

gui.TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = Vector2.new(input.Position.X, input.Position.Y)
        startPos = gui.TitleBar.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging then
        if input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch then
            updateDrag(Vector2.new(input.Position.X, input.Position.Y))
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- ===== Toggle Panel Open/Close =====
local function togglePanel()
    panelOpen = not panelOpen
    local targetSize
    if panelOpen then
        targetSize = UDim2.new(0, 220, 0, PANEL_HEIGHT)
    else
        targetSize = UDim2.new(0, 220, 0, 0)
    end
    gui.MainFrame:TweenSize(targetSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.3, true)
end

-- Debounce agar drag tidak trigger click
local lastClickTime = 0
gui.TitleBar.MouseButton1Up:Connect(function()
    if not dragging then
        local now = tick()
        if now - lastClickTime > 0.3 then
            togglePanel()
        end
        lastClickTime = now
    end
end)

gui.TitleBar.TouchTap:Connect(function()
    togglePanel()
end)

-- ===================== CORE FUNCTIONS =====================

-- Modifikasi satu ProximityPrompt
local function modifyPrompt(prompt)
    if not prompt:IsA("ProximityPrompt") then return end

    -- Simpan nilai asli
    if not originalDurations[prompt] then
        originalDurations[prompt] = prompt.HoldDuration
    end
    if not originalDistances[prompt] then
        originalDistances[prompt] = prompt.MaxActivationDistance
    end

    if Settings.Enabled then
        prompt.HoldDuration = Settings.HoldDuration
        prompt.MaxActivationDistance = Settings.MaxDistance
    end
end

-- Restore satu ProximityPrompt
local function restorePrompt(prompt)
    if not prompt:IsA("ProximityPrompt") then return end

    if originalDurations[prompt] then
        prompt.HoldDuration = originalDurations[prompt]
    end
    if originalDistances[prompt] then
        prompt.MaxActivationDistance = originalDistances[prompt]
    end
end

-- Cari dan modifikasi SEMUA prompts di game
local function modifyAllPrompts()
    local count = 0
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            modifyPrompt(obj)
            count = count + 1
        end
    end
    gui.CounterLabel.Text = "Prompts Found: " .. count
end

-- Restore semua prompts
local function restoreAllPrompts()
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            restorePrompt(obj)
        end
    end
end

