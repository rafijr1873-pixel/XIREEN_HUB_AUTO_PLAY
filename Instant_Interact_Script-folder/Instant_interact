-- ===== Slider Logic (Distance) - Mobile + PC =====
local sliderDragging = false

local function updateSlider(inputPos)
    local sliderAbsPos = gui.SliderBg.AbsolutePosition.X
    local sliderAbsSize = gui.SliderBg.AbsoluteSize.X

    local relative = math.clamp((inputPos - sliderAbsPos) / sliderAbsSize, 0, 1)
    local value = math.floor(relative * 100)

    Settings.MaxDistance = math.max(value, 5) -- Minimum 5
    gui.DistLabel.Text = "Distance: " .. Settings.MaxDistance
    gui.SliderFill.Size = UDim2.new(relative, 0, 1, 0)
    gui.SliderKnob.Position = UDim2.new(relative, -9, 0.5, -9)

    -- Update semua prompt yang sudah ada
    if Settings.Enabled then
        for _, obj in pairs(game:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                obj.MaxActivationDistance = Settings.MaxDistance
            end
        end
    end
end

gui.SliderKnob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
    end
end)

gui.SliderBg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        updateSlider(input.Position.X)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if sliderDragging then
        if input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch then
            updateSlider(input.Position.X)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = false
    end
end)

-- ===================== AUTO INTERACT LOOP =====================
local function getClosestPrompt()
    local character = player.Character
    if not character then return nil end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    local closest = nil
    local closestDist = math.huge

    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Enabled then
            local parent = obj.Parent
            if parent and parent:IsA("BasePart") then
                local dist = (parent.Position - rootPart.Position).Magnitude
                if dist < closestDist and dist <= Settings.MaxDistance then
                    closest = obj
                    closestDist = dist
                end
            elseif parent then
                local part = parent:FindFirstChildWhichIsA("BasePart")
                if part then
                    local dist = (part.Position - rootPart.Position).Magnitude
                    if dist < closestDist and dist <= Settings.MaxDistance then
                        closest = obj
                        closestDist = dist
                    end
                end
            end
        end
    end

    return closest
end

-- Auto Interact Loop
task.spawn(function()
    while true do
        task.wait(Settings.AutoInteractDelay)

        if Settings.Enabled and Settings.AutoInteract then
            local prompt = getClosestPrompt()
            if prompt then
                -- Fire prompt
                pcall(function()
                    fireproximityprompt(prompt)
                end)

                -- Fallback jika fireproximityprompt tidak tersedia
                pcall(function()
                    prompt:InputHoldBegin()
                    task.wait(0.05)
                    prompt:InputHoldEnd()
                end)
            end
        end
    end
end)

