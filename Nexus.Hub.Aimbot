--// ============ GUI EVENTS ============ //--

local guiOpen = false

ToggleButton.MouseButton1Click:Connect(function()
    guiOpen = not guiOpen
    MainFrame.Visible = guiOpen
    TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
        BackgroundColor3 = guiOpen and Color3.fromRGB(0, 140, 200) or Color3.fromRGB(25, 25, 40)
    }):Play()
end)

CloseBtn.MouseButton1Click:Connect(function()
    guiOpen = false
    MainFrame.Visible = false
    TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(25, 25, 40)
    }):Play()
end)

dBtn.MouseButton1Click:Connect(function()
    if FOVCircle then FOVCircle:Remove() end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Character then
            local h = plr.Character:FindFirstChild("NX_HL") if h then h:Destroy() end
            local b = plr.Character:FindFirstChild("NX_BB") if b then b:Destroy() end
        end
    end
    ScreenGui:Destroy()
end)

--// ============ FEATURE LOGIC ============ //--

local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
local aimHolding = false

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aimHolding = true
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aimHolding = false
    end
end)

-- MAIN RENDER LOOP
RunService.RenderStepped:Connect(function()
    Camera = workspace.CurrentCamera

    -- FOV Circle Update
    if FOVCircle then
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        FOVCircle.Radius   = Settings.AimbotFOV
        FOVCircle.Visible  = Settings.FOVShow
    end

    -- AIMBOT
    if Settings.Aimbot then
        local shouldAim = isMobile or aimHolding
        if shouldAim then
            local target = getClosestPlayer()
            if target and target.Character then
                local part = target.Character:FindFirstChild(Settings.AimbotPart)
                          or target.Character:FindFirstChild("HumanoidRootPart")
                if part then
                    local targetCF = CFrame.new(Camera.CFrame.Position, part.Position)
                    Camera.CFrame  = Camera.CFrame:Lerp(targetCF, 1 / Settings.AimbotSmooth)
                end
            end
        end
    end

    -- SPEED
    if Settings.Speed then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = Settings.SpeedVal end
        end
    end

    -- JUMP POWER
    if Settings.JumpPower then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.UseJumpPower = true
                hum.JumpPower    = Settings.JumpVal
            end
        end
    end

    -- NO FALL
    if Settings.NoFall then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
            end
        end
    end
end)

-- INFINITE JUMP
UserInputService.JumpRequest:Connect(function()
    if Settings.InfJump then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        end
    end
end)

--// ============ ESP SYSTEM ============ //--

local function SetupESP(player)
    if player == LocalPlayer then return end

    local function applyESP()
        local char = player.Character
        if not char then return end

        -- Remove old
        local oldH = char:FindFirstChild("NX_HL") if oldH then oldH:Destroy() end
        local oldB = char:FindFirstChild("NX_BB") if oldB then oldB:Destroy() end

        -- Highlight
        local hl = Instance.new("Highlight")
        hl.Name              = "NX_HL"
        hl.FillTransparency  = 0.5
        hl.OutlineTransparency = 0
        hl.Adornee           = char
        hl.Parent            = char

        -- Color by team
        local isTeam = player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team
        if isTeam then
            hl.FillColor    = Color3.fromRGB(0, 130, 255)
            hl.OutlineColor = Color3.fromRGB(0, 180, 255)
        else
            hl.FillColor    = Color3.fromRGB(255, 30, 30)
            hl.OutlineColor = Color3.fromRGB(255, 255, 0)
        end

        -- Billboard
        local head = char:WaitForChild("Head", 3)
        if not head then return end

        local bb = Instance.new("BillboardGui")
        bb.Name         = "NX_BB"
        bb.Adornee      = head
        bb.Size         = UDim2.new(0, 200, 0, 55)
        bb.StudsOffset  = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop  = true
        bb.MaxDistance   = 500
        bb.Parent       = char

        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size                   = UDim2.new(1, 0, 0, 16)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text                   = player.DisplayName
        nameLbl.TextColor3             = Color3.new(1, 1, 1)
        nameLbl.TextSize               = 14
        nameLbl.Font                   = Enum.Font.GothamBold
        nameLbl.TextStrokeTransparency = 0
        nameLbl.TextStrokeColor3       = Color3.new(0, 0, 0)
        nameLbl.Parent                 = bb

        local hpBG = Instance.new("Frame")
        hpBG.Size             = UDim2.new(0.8, 0, 0, 6)
        hpBG.Position         = UDim2.new(0.1, 0, 0, 19)
        hpBG.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        hpBG.BorderSizePixel  = 0
        hpBG.Parent           = bb
        Instance.new("UICorner", hpBG).CornerRadius = UDim.new(1, 0)

        local hpFill = Instance.new("Frame")
        hpFill.Name             = "Fill"
        hpFill.Size             = UDim2.new(1, 0, 1, 0)
        hpFill.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        hpFill.BorderSizePixel  = 0
        hpFill.Parent           = hpBG
        Instance.new("UICorner", hpFill).CornerRadius = UDim.new(1, 0)

        local distLbl = Instance.new("TextLabel")
        distLbl.Name                   = "Dist"
        distLbl.Size                   = UDim2.new(1, 0, 0, 14)
        distLbl.Position               = UDim2.new(0, 0, 0, 28)
        distLbl.BackgroundTransparency = 1
        distLbl.Text                   = "0m"
        distLbl.TextColor3             = Color3.fromRGB(200, 200, 200)
        distLbl.TextSize               = 12
        distLbl.Font                   = Enum.Font.Gotham
        distLbl.TextStrokeTransparency = 0
        distLbl.TextStrokeColor3       = Color3.new(0, 0, 0)
        distLbl.Parent                 = bb

        -- Update loop
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            spawn(function()
                while char and char.Parent and hum and hum.Health > 0 do
                    if Settings.ESP then
                        local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        hpFill.Size             = UDim2.new(pct, 0, 1, 0)
                        hpFill.BackgroundColor3 = Color3.fromRGB(255*(1-pct), 255*pct, 50)

                        local myChar = LocalPlayer.Character
                        if myChar and myChar:FindFirstChild("HumanoidRootPart")
                        and char:FindFirstChild("HumanoidRootPart") then
                            local d = (myChar.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                            distLbl.Text = math.floor(d).."m"
                        end

                        local teamHide = Settings.ESPTeamCheck
                            and player.Team and LocalPlayer.Team
                            and player.Team == LocalPlayer.Team
                        hl.Enabled = not teamHide
                        bb.Enabled = not teamHide
                    else
                        hl.Enabled = false
                        bb.Enabled = false
                    end
                    wait(0.1)
                end
            end)
        end
    end

    if player.Character then applyESP() end
    player.CharacterAdded:Connect(function()
        wait(1)
        if Settings.ESP then applyESP() end
    end)
end

for _, plr in pairs(Players:GetPlayers()) do SetupESP(plr) end
Players.PlayerAdded:Connect(SetupESP)

