-- TAB 4: INFO & DESTROY
-- ============================================
local InfoTab = Window:CreateTab("ℹ️ Info", 4483362458)

local InfoSection = InfoTab:CreateSection("Nexus Hub v3.0")

InfoTab:CreateParagraph({
    Title = "⚡ Nexus Hub",
    Content = "ESP Script for Operation One & Universal Games\n\nFeatures:\n• Skeleton ESP (R6 & R15)\n• Box ESP + Corner Box\n• Name, Health, Distance\n• Weapon/Tool ESP\n• Tracers (3 modes)\n• Head Dot\n• Full Color Customization\n• Config Save/Load"
})

InfoTab:CreateParagraph({
    Title = "📱 Controls",
    Content = "• Mobile: Tap tombol di kiri atas\n• PC: Klik tombol atau keybind Rayfield\n• Semua setting otomatis tersimpan"
})

local PlayerSection = InfoTab:CreateSection("Player Info")

InfoTab:CreateLabel("Player: " .. LocalPlayer.DisplayName)
InfoTab:CreateLabel("Game: " .. game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name)
InfoTab:CreateLabel("Players: " .. #Players:GetPlayers() .. "/" .. Players.MaxPlayers)

local DangerSection = InfoTab:CreateSection("⚠️ Danger Zone")

InfoTab:CreateButton({
    Name = "🗑️ DESTROY NEXUS HUB",
    Callback = function()
        -- Cleanup ESP
        if RenderConn then RenderConn:Disconnect() end
        for plr in pairs(ESPCache) do RemoveESP(plr) end

        -- Cleanup globals
        _G.NexusLoaded = false
        _G.NexusCache = nil
        _G.NexusRender = nil

        -- Destroy Rayfield
        Rayfield:Destroy()

        print("[Nexus Hub] Destroyed successfully!")
    end,
})

