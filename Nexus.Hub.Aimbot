    AimbotSmooth = 2,
    AimbotPart   = "Head",
    WallCheck    = true,
    TeamCheck    = true,
    ESP          = false,
    ESPTeamCheck = true,
    FOVShow      = false,
    FOVRadius    = 200,
    Speed        = false,
