-- ============================================
-- CLEANUP SCRIPT LAMA
-- ============================================
if _G.NexusLoaded then
    pcall(function()
        if _G.NexusRender then _G.NexusRender:Disconnect() end
        if _G.NexusCache then
            for _, d in pairs(_G.NexusCache) do
                pcall(function()
                    for _, b in pairs(d.Bones or {}) do b:Remove() end
                    for _, b in pairs(d.Box or {}) do b:Remove() end
                    for _, b in pairs(d.Corners or {}) do b:Remove() end
                    if d.Name then d.Name:Remove() end
                    if d.Dist then d.Dist:Remove() end
                    if d.HPBG then d.HPBG:Remove() end
                    if d.HP then d.HP:Remove() end
                    if d.HPText then d.HPText:Remove() end
                    if d.Tracer then d.Tracer:Remove() end
                    if d.HeadDot then d.HeadDot:Remove() end
                    if d.Weapon then d.Weapon:Remove() end
                end)
            end
        end
    end)
    task.wait(0.5)
end
_G.NexusLoaded = true

-- ============================================
-- SERVICES
-- ============================================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- ============================================
-- LOAD RAYFIELD
-- ============================================
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- ============================================
-- CONFIG
-- ============================================
local Config = {
    Enabled = true,
    SkeletonESP = true,
    BoxESP = true,
    CornerBoxESP = false,
    NameESP = true,
    HealthESP = true,
    DistanceESP = true,
    Tracers = false,
    HeadDot = true,
    WeaponESP = true,
    TeamCheck = false,
    VisibleCheck = false,
    MaxDistance = 2500,

    EnemyColor = Color3.fromRGB(255, 60, 60),
    TeamColor = Color3.fromRGB(60, 255, 60),
    VisibleColor = Color3.fromRGB(0, 255, 0),
    HiddenColor = Color3.fromRGB(255, 60, 60),
    SkeletonColor = Color3.fromRGB(255, 255, 255),
    BoxColor = Color3.fromRGB(255, 255, 0),
    TracerColor = Color3.fromRGB(0, 200, 255),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthHighColor = Color3.fromRGB(0, 255, 0),
    HealthLowColor = Color3.fromRGB(255, 0, 0),

    SkeletonThickness = 1.5,
    BoxThickness = 1.5,
    TracerThickness = 1.2,
    HeadDotRadius = 3,
    TextSize = 13,
    TracerOrigin = "Bottom", -- Bottom / Center / Mouse
}

-- ============================================
-- BONE CONNECTIONS
-- ============================================
local R15Bones = {
    {"Head", "UpperTorso"},
    {"UpperTorso", "LowerTorso"},
    {"UpperTorso", "LeftUpperArm"},
    {"LeftUpperArm", "LeftLowerArm"},
    {"LeftLowerArm", "LeftHand"},
    {"UpperTorso", "RightUpperArm"},
    {"RightUpperArm", "RightLowerArm"},
    {"RightLowerArm", "RightHand"},
    {"LowerTorso", "LeftUpperLeg"},
    {"LeftUpperLeg", "LeftLowerLeg"},
    {"LeftLowerLeg", "LeftFoot"},
    {"LowerTorso", "RightUpperLeg"},
    {"RightUpperLeg", "RightLowerLeg"},
    {"RightLowerLeg", "RightFoot"},
}

local R6Bones = {
    {"Head", "Torso"},
    {"Torso", "Left Arm"},
    {"Torso", "Right Arm"},
    {"Torso", "Left Leg"},
    {"Torso", "Right Leg"},
}

-- ============================================
-- UTILITY
-- ============================================
local function W2S(pos)
    local ok, res = pcall(function()
        return Camera:WorldToViewportPoint(pos)
    end)
    if not ok then return Vector2.new(0, 0), false, 0 end
    return Vector2.new(res.X, res.Y), res.Z > 0, res.Z
end

local function GetDist(pos)
    local c = LocalPlayer.Character
    if not c then return math.huge end
    local r = c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")
    if not r then return math.huge end
    return (r.Position - pos).Magnitude
end

local function IsAlly(plr)
    if not Config.TeamCheck then return false end
    if not LocalPlayer.Team or not plr.Team then return false end
    return LocalPlayer.Team == plr.Team
end

local function GetColor(plr)
    return IsAlly(plr) and Config.TeamColor or Config.EnemyColor
end

local function LerpColor(c1, c2, a)
    a = math.clamp(a, 0, 1)
    return Color3.new(c1.R+(c2.R-c1.R)*a, c1.G+(c2.G-c1.G)*a, c1.B+(c2.B-c1.B)*a)
end

local function IsR15(char)
    return char:FindFirstChild("UpperTorso") ~= nil
end

local function GetEquippedTool(char)
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") or v:IsA("BackpackItem") then
            return v.Name
        end
    end
    return nil
end

-- ============================================
-- ACCURATE BOUNDING BOX
-- ============================================
local function GetBounds(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not hum or not root or hum.Health <= 0 then return nil end

    local head = char:FindFirstChild("Head")
    if not head then return nil end

    local topPos, bottomPos

    if hum.RigType == Enum.HumanoidRigType.R15 then
        local lf = char:FindFirstChild("LeftFoot")
        local rf = char:FindFirstChild("RightFoot")
        topPos = head.Position + Vector3.new(0, head.Size.Y / 2 + 0.3, 0)
        if lf and rf then
            local fy = math.min(lf.Position.Y - lf.Size.Y/2, rf.Position.Y - rf.Size.Y/2)
            bottomPos = Vector3.new(root.Position.X, fy, root.Position.Z)
        else
            bottomPos = root.Position - Vector3.new(0, 3, 0)
        end
    else
        local ll = char:FindFirstChild("Left Leg")
        local rl = char:FindFirstChild("Right Leg")
        topPos = head.Position + Vector3.new(0, head.Size.Y / 2 + 0.3, 0)
        if ll and rl then
            local fy = math.min(ll.Position.Y - ll.Size.Y/2, rl.Position.Y - rl.Size.Y/2)
            bottomPos = Vector3.new(root.Position.X, fy, root.Position.Z)
        else
            bottomPos = root.Position - Vector3.new(0, 3, 0)
        end
    end

    local topS, topOn = W2S(topPos)
    local botS, botOn = W2S(bottomPos)
    local rootS, rootOn = W2S(root.Position)

    if not rootOn then return nil end

    local h = math.abs(botS.Y - topS.Y)
    if h < 4 then return nil end

    local w = h * 0.55

    return {
        Top = topS, Bottom = botS,
        Height = h, Width = w,
        Center = Vector2.new(rootS.X, (topS.Y + botS.Y) / 2)
    }
end

-- ============================================
-- SAFE DRAWING
-- ============================================
local function SafeDraw(t, props)
    local ok, obj = pcall(function()
        local d = Drawing.new(t)
        d.Visible = false
        for k, v in pairs(props or {}) do
            pcall(function() d[k] = v end)
        end
        return d
    end)
    return ok and obj or nil
end

-- ============================================
-- ESP CACHE
-- ============================================
local ESPCache = {}
_G.NexusCache = ESPCache

local function MakeESP(plr)
    if plr == LocalPlayer or ESPCache[plr] then return end

    local d = {
        Player = plr,
        Bones = {},
        Box = {},
        Corners = {},
        Name = SafeDraw("Text", {Color=Color3.new(1,1,1), Size=Config.TextSize, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Font=Drawing.Fonts.UI}),
        Dist = SafeDraw("Text", {Color=Color3.fromRGB(200,200,200), Size=Config.TextSize-2, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Font=Drawing.Fonts.UI}),
        Weapon = SafeDraw("Text", {Color=Color3.fromRGB(255,200,80), Size=Config.TextSize-2, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Font=Drawing.Fonts.UI}),
        HPBG = SafeDraw("Line", {Color=Color3.new(0,0,0), Thickness=5}),
        HP = SafeDraw("Line", {Color=Color3.new(0,1,0), Thickness=2.5}),
        HPText = SafeDraw("Text", {Color=Color3.new(1,1,1), Size=Config.TextSize-3, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Font=Drawing.Fonts.UI}),
        Tracer = SafeDraw("Line", {Color=Config.TracerColor, Thickness=Config.TracerThickness}),
        HeadDot = SafeDraw("Circle", {Color=Config.EnemyColor, Filled=true, NumSides=20}),
    }

    for i = 1, 14 do
        d.Bones[i] = SafeDraw("Line", {Color=Config.SkeletonColor, Thickness=Config.SkeletonThickness})
    end
    for i = 1, 4 do
        d.Box[i] = SafeDraw("Line", {Color=Config.BoxColor, Thickness=Config.BoxThickness})
    end
    -- Corner box: 8 lines (4 corners x 2 lines each)
    for i = 1, 8 do
        d.Corners[i] = SafeDraw("Line", {Color=Config.BoxColor, Thickness=Config.BoxThickness})
    end

    ESPCache[plr] = d
end

local function HideAll(d)
    if not d then return end
    pcall(function()
        for _,b in pairs(d.Bones) do if b then b.Visible=false end end
        for _,b in pairs(d.Box) do if b then b.Visible=false end end
        for _,b in pairs(d.Corners) do if b then b.Visible=false end end
        if d.Name then d.Name.Visible=false end
        if d.Dist then d.Dist.Visible=false end
        if d.Weapon then d.Weapon.Visible=false end
        if d.HPBG then d.HPBG.Visible=false end
        if d.HP then d.HP.Visible=false end
        if d.HPText then d.HPText.Visible=false end
        if d.Tracer then d.Tracer.Visible=false end
        if d.HeadDot then d.HeadDot.Visible=false end
    end)
end

local function RemoveESP(plr)
    local d = ESPCache[plr]
    if not d then return end
    pcall(function()
        for _,b in pairs(d.Bones) do if b then b:Remove() end end
        for _,b in pairs(d.Box) do if b then b:Remove() end end
        for _,b in pairs(d.Corners) do if b then b:Remove() end end
        if d.Name then d.Name:Remove() end
        if d.Dist then d.Dist:Remove() end
        if d.Weapon then d.Weapon:Remove() end
        if d.HPBG then d.HPBG:Remove() end
        if d.HP then d.HP:Remove() end
        if d.HPText then d.HPText:Remove() end
        if d.Tracer then d.Tracer:Remove() end
        if d.HeadDot then d.HeadDot:Remove() end
    end)
    ESPCache[plr] = nil
end

-- ============================================
-- UPDATE ESP
-- ============================================
local function UpdateESP(plr, d)
    if not d then return end
    if not Config.Enabled or plr == LocalPlayer then HideAll(d) return end

    local char = plr.Character
    if not char then HideAll(d) return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not hum or not root or hum.Health <= 0 then HideAll(d) return end

    local dist = GetDist(root.Position)
    if dist > Config.MaxDistance then HideAll(d) return end
    if Config.TeamCheck and IsAlly(plr) then HideAll(d) return end

    local _, onScr, depth = W2S(root.Position)
    if not onScr or depth <= 0 then HideAll(d) return end

    local bounds = GetBounds(char)
    if not bounds then HideAll(d) return end

    local col = GetColor(plr)

    -- ====== SKELETON ======
    if Config.SkeletonESP then
        local boneList = IsR15(char) and R15Bones or R6Bones
        for i, bp in ipairs(boneList) do
            if d.Bones[i] then
                local p1 = char:FindFirstChild(bp[1])
                local p2 = char:FindFirstChild(bp[2])
                if p1 and p2 then
                    local s1, o1 = W2S(p1.Position)
                    local s2, o2 = W2S(p2.Position)
                    if o1 and o2 then
                        d.Bones[i].From = s1
                        d.Bones[i].To = s2
                        d.Bones[i].Color = Config.SkeletonColor
                        d.Bones[i].Thickness = Config.SkeletonThickness
                        d.Bones[i].Visible = true
                    else d.Bones[i].Visible = false end
                else d.Bones[i].Visible = false end
            end
        end
        for i = #(IsR15(char) and R15Bones or R6Bones) + 1, #d.Bones do
            if d.Bones[i] then d.Bones[i].Visible = false end
        end
    else
        for _, b in pairs(d.Bones) do if b then b.Visible = false end end
    end

    -- ====== FULL BOX ======
    if Config.BoxESP then
        local x, hw = bounds.Center.X, bounds.Width / 2
        local tl = Vector2.new(x-hw, bounds.Top.Y)
        local tr = Vector2.new(x+hw, bounds.Top.Y)
        local bl = Vector2.new(x-hw, bounds.Bottom.Y)
        local br = Vector2.new(x+hw, bounds.Bottom.Y)
        if d.Box[1] then d.Box[1].From=tl d.Box[1].To=tr d.Box[1].Color=col d.Box[1].Thickness=Config.BoxThickness d.Box[1].Visible=true end
        if d.Box[2] then d.Box[2].From=bl d.Box[2].To=br d.Box[2].Color=col d.Box[2].Thickness=Config.BoxThickness d.Box[2].Visible=true end
        if d.Box[3] then d.Box[3].From=tl d.Box[3].To=bl d.Box[3].Color=col d.Box[3].Thickness=Config.BoxThickness d.Box[3].Visible=true end
        if d.Box[4] then d.Box[4].From=tr d.Box[4].To=br d.Box[4].Color=col d.Box[4].Thickness=Config.BoxThickness d.Box[4].Visible=true end
    else
        for _, b in pairs(d.Box) do if b then b.Visible = false end end
    end

    -- ====== CORNER BOX ======
    if Config.CornerBoxESP then
        local x, hw = bounds.Center.X, bounds.Width / 2
        local cLen = bounds.Height * 0.2

        local tl = Vector2.new(x-hw, bounds.Top.Y)
        local tr = Vector2.new(x+hw, bounds.Top.Y)
        local bl = Vector2.new(x-hw, bounds.Bottom.Y)
        local br = Vector2.new(x+hw, bounds.Bottom.Y)

        -- Top-left
        if d.Corners[1] then d.Corners[1].From=tl d.Corners[1].To=Vector2.new(tl.X+cLen,tl.Y) d.Corners[1].Color=col d.Corners[1].Thickness=Config.BoxThickness d.Corners[1].Visible=true end
        if d.Corners[2] then d.Corners[2].From=tl d.Corners[2].To=Vector2.new(tl.X,tl.Y+cLen) d.Corners[2].Color=col d.Corners[2].Thickness=Config.BoxThickness d.Corners[2].Visible=true end
        -- Top-right
        if d.Corners[3] then d.Corners[3].From=tr d.Corners[3].To=Vector2.new(tr.X-cLen,tr.Y) d.Corners[3].Color=col d.Corners[3].Thickness=Config.BoxThickness d.Corners[3].Visible=true end
        if d.Corners[4] then d.Corners[4].From=tr d.Corners[4].To=Vector2.new(tr.X,tr.Y+cLen) d.Corners[4].Color=col d.Corners[4].Thickness=Config.BoxThickness d.Corners[4].Visible=true end
        -- Bottom-left
        if d.Corners[5] then d.Corners[5].From=bl d.Corners[5].To=Vector2.new(bl.X+cLen,bl.Y) d.Corners[5].Color=col d.Corners[5].Thickness=Config.BoxThickness d.Corners[5].Visible=true end
        if d.Corners[6] then d.Corners[6].From=bl d.Corners[6].To=Vector2.new(bl.X,bl.Y-cLen) d.Corners[6].Color=col d.Corners[6].Thickness=Config.BoxThickness d.Corners[6].Visible=true end
        -- Bottom-right
        if d.Corners[7] then d.Corners[7].From=br d.Corners[7].To=Vector2.new(br.X-cLen,br.Y) d.Corners[7].Color=col d.Corners[7].Thickness=Config.BoxThickness d.Corners[7].Visible=true end
        if d.Corners[8] then d.Corners[8].From=br d.Corners[8].To=Vector2.new(br.X,br.Y-cLen) d.Corners[8].Color=col d.Corners[8].Thickness=Config.BoxThickness d.Corners[8].Visible=true end
    else
        for _, b in pairs(d.Corners) do if b then b.Visible = false end end
    end

    -- ====== NAME ======
    if Config.NameESP and d.Name then
        d.Name.Text = plr.DisplayName
        d.Name.Position = Vector2.new(bounds.Center.X, bounds.Top.Y - 16)
        d.Name.Color = col
        d.Name.Size = Config.TextSize
        d.Name.Visible = true
    elseif d.Name then d.Name.Visible = false end

    -- ====== DISTANCE ======
    if Config.DistanceESP and d.Dist then
        d.Dist.Text = string.format("[%dm]", math.floor(dist))
        d.Dist.Position = Vector2.new(bounds.Center.X, bounds.Bottom.Y + 3)
        d.Dist.Visible = true
    elseif d.Dist then d.Dist.Visible = false end

    -- ====== WEAPON ======
    if Config.WeaponESP and d.Weapon then
        local tool = GetEquippedTool(char)
        if tool then
            local yOff = Config.DistanceESP and 15 or 3
            d.Weapon.Text = "🔫 " .. tool
            d.Weapon.Position = Vector2.new(bounds.Center.X, bounds.Bottom.Y + yOff)
            d.Weapon.Color = Color3.fromRGB(255, 200, 80)
            d.Weapon.Visible = true
        else
            d.Weapon.Visible = false
        end
    elseif d.Weapon then d.Weapon.Visible = false end

    -- ====== HEALTH BAR ======
    if Config.HealthESP then
        local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        local hcol = LerpColor(Config.HealthLowColor, Config.HealthHighColor, pct)
        local bx = bounds.Center.X - bounds.Width/2 - 6

        if d.HPBG then
            d.HPBG.From = Vector2.new(bx, bounds.Top.Y)
            d.HPBG.To = Vector2.new(bx, bounds.Bottom.Y)
            d.HPBG.Thickness = 5
            d.HPBG.Color = Color3.new(0,0,0)
            d.HPBG.Transparency = 0.6
            d.HPBG.Visible = true
        end
        if d.HP then
            local ht = bounds.Bottom.Y - (bounds.Height * pct)
            d.HP.From = Vector2.new(bx, ht)
            d.HP.To = Vector2.new(bx, bounds.Bottom.Y)
            d.HP.Color = hcol
            d.HP.Thickness = 2.5
            d.HP.Visible = true
        end
        if d.HPText then
            if pct < 1 then
                local ht = bounds.Bottom.Y - (bounds.Height * pct)
                d.HPText.Text = tostring(math.floor(hum.Health))
                d.HPText.Position = Vector2.new(bx, ht - 12)
                d.HPText.Color = hcol
                d.HPText.Visible = true
            else d.HPText.Visible = false end
        end
    else
        if d.HPBG then d.HPBG.Visible=false end
        if d.HP then d.HP.Visible=false end
        if d.HPText then d.HPText.Visible=false end
    end

    -- ====== TRACERS ======
    if Config.Tracers and d.Tracer then
        local vs = Camera.ViewportSize
        local fromPos

        if Config.TracerOrigin == "Center" then
            fromPos = Vector2.new(vs.X/2, vs.Y/2)
        elseif Config.TracerOrigin == "Mouse" then
            local mp = UserInputService:GetMouseLocation()
            fromPos = Vector2.new(mp.X, mp.Y)
        else
            fromPos = Vector2.new(vs.X/2, vs.Y)
        end

        d.Tracer.From = fromPos
        d.Tracer.To = Vector2.new(bounds.Center.X, bounds.Bottom.Y)
        d.Tracer.Color = Config.TracerColor
        d.Tracer.Thickness = Config.TracerThickness
        d.Tracer.Visible = true
    elseif d.Tracer then d.Tracer.Visible = false end

    -- ====== HEAD DOT ======
    if Config.HeadDot and d.HeadDot then
        local head = char:FindFirstChild("Head")
        if head then
            local hp, ho = W2S(head.Position)
            if ho then
                d.HeadDot.Position = hp
                d.HeadDot.Radius = math.clamp(Config.HeadDotRadius * (350/math.max(dist,1)), 1, 8)
                d.HeadDot.Color = col
                d.HeadDot.Filled = true
                d.HeadDot.Visible = true
            else d.HeadDot.Visible = false end
        else d.HeadDot.Visible = false end
    elseif d.HeadDot then d.HeadDot.Visible = false end
end

-- ============================================
-- PLAYER EVENTS
-- ============================================
for _, p in ipairs(Players:GetPlayers()) do task.spawn(MakeESP, p) end
Players.PlayerAdded:Connect(function(p) task.spawn(MakeESP, p) end)
Players.PlayerRemoving:Connect(function(p) task.spawn(RemoveESP, p) end)

-- ============================================
-- RENDER LOOP
-- ============================================
local RenderConn = RunService.RenderStepped:Connect(function()
    Camera = workspace.CurrentCamera
    for plr, data in pairs(ESPCache) do
        local ok = pcall(function()
            if plr and plr.Parent then
                UpdateESP(plr, data)
            else
                HideAll(data)
            end
        end)
        if not ok then HideAll(data) end
    end
end)
_G.NexusRender = RenderConn

