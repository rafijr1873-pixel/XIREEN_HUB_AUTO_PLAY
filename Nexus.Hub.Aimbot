    end,
})

ColTab:CreateSection("ESP Element Colors")

ColTab:CreateColorPicker({
    Name = "🦴 Skeleton Color",
    Color = Config.SkeletonColor,
    Flag = "COL_Skeleton",
    Callback = function(val)
        Config.SkeletonColor = val
    end,
})

ColTab:CreateColorPicker({
    Name = "📦 Box Color",
    Color = Config.BoxColor,
    Flag = "COL_Box",
    Callback = function(val)
        Config.BoxColor = val
    end,
})

ColTab:CreateColorPicker({
    Name = "📍 Tracer Color",
    Color = Config.TracerColor,
    Flag = "COL_Tracer",
    Callback = function(val)
        Config.TracerColor = val
    end,
})

ColTab:CreateSection("Health Bar Colors")

ColTab:CreateColorPicker({
    Name = "💚 HP Full Color",
    Color = Config.HealthHighColor,
    Flag = "COL_HPHigh",
    Callback = function(val)
        Config.HealthHighColor = val
    end,
})

ColTab:CreateColorPicker({
    Name = "💔 HP Low Color",
