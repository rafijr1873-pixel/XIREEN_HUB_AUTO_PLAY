-- TAB 4: INFO
-- ==============================
local InfoTab = Window:CreateTab("ℹ️ Info", 4483362458)

InfoTab:CreateSection("About")

InfoTab:CreateParagraph({
    Title = "⚡ NEXUS HUB v2.0",
    Content = "ESP Script untuk Operation One & Universal\n\n"
        .. "✅ Skeleton ESP (R6 & R15 Support)\n"
        .. "✅ Box ESP dengan akurasi tinggi\n"
        .. "✅ Name + Distance ESP\n"
        .. "✅ Health Bar dengan gradien warna\n"
        .. "✅ Tracers dari bawah layar\n"
        .. "✅ Head Dot (auto scale)\n"
        .. "✅ Team Check filter\n"
        .. "✅ Full color customization\n"
        .. "✅ Config auto save/load\n"
        .. "✅ Mobile & PC support",
})

InfoTab:CreateSection("Player Info")

local gameName = "Unknown"
pcall(function()
    gameName = MarketplaceService:GetProductInfo(game.PlaceId).Name
end)

InfoTab:CreateLabel("👤 " .. LocalPlayer.DisplayName .. " (@" .. LocalPlayer.Name .. ")")
InfoTab:CreateLabel("🎮 " .. gameName)
InfoTab:CreateLabel("👥 " .. #Players:GetPlayers() .. "/" .. Players.MaxPlayers .. " players")

InfoTab:CreateSection("⚠️ Danger Zone")

InfoTab:CreateButton({
    Name = "🗑️ DESTROY NEXUS HUB",
    Callback = function()
        Rayfield:Notify({
            Title = "⚡ Nexus Hub",
            Content = "Destroying in 2 seconds...",
            Duration = 2,
        })

        task.wait(2)

        -- Disconnect render
        if RenderConn then
            RenderConn:Disconnect()
        end

        -- Remove all ESP drawings
        for plr in pairs(ESPCache) do
            RemoveESP(plr)
        end

        -- Clean globals
        _G.NexusLoaded = false
        _G.NexusCache = nil
        _G.NexusRender = nil

        -- Destroy Rayfield
        Rayfield:Destroy()

        print("[Nexus Hub] Destroyed!")
    end,
})

-- ============================================
-- STARTUP NOTIFICATION
-- ============================================
Rayfield:Notify({
    Title = "⚡ Nexus Hub v2.0 Loaded!",
    Content = IsMobile
        and "Tap tombol di kiri atas untuk menu"
        or "Klik tombol atau gunakan keybind Rayfield",
    Duration = 5,
    Image = 4483362458,
})

