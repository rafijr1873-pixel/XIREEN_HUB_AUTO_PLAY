end)

-- ============================================
-- TOGGLE CREATOR
-- ============================================
local ToggleOrder = 0

local function CreateSeparator(text)
    ToggleOrder = ToggleOrder + 1
    local sep = Instance.new("Frame")
    sep.Size = UDim2.new(1, 0, 0, 20)
    sep.BackgroundTransparency = 1
    sep.LayoutOrder = ToggleOrder
    sep.ZIndex = 102
    sep.Parent = ScrollFrame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "── " .. string.upper(text) .. " ──"
    label.TextColor3 = Theme.Accent
    label.TextSize = IsMobile and 11 or 10
    label.Font = Enum.Font.GothamBold
    label.ZIndex = 103
    label.Parent = sep
end

local function CreateToggle(name, icon, desc, default, callback)
    ToggleOrder = ToggleOrder + 1
    local state = default

    local holder = Instance.new("Frame")
    holder.Name = name
    holder.Size = UDim2.new(1, 0, 0, BtnSize)
    holder.BackgroundColor3 = Theme.Button
    holder.BorderSizePixel = 0
    holder.LayoutOrder = ToggleOrder
    holder.ZIndex = 102
    holder.Parent = ScrollFrame

    Instance.new("UICorner", holder).CornerRadius = Theme.CornerSmall

    -- Left color indicator
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 3, 0.6, 0)
    indicator.Position = UDim2.new(0, 0, 0.2, 0)
    indicator.BackgroundColor3 = state and Theme.ToggleON or Theme.ToggleOFF
    indicator.BorderSizePixel = 0
    indicator.ZIndex = 103
    indicator.Parent = holder

    Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 2)

    -- Label
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -68, 0, 18)
    label.Position = UDim2.new(0, 12, 0, IsMobile and 6 or 5)
    label.BackgroundTransparency = 1
    label.Text = icon .. "  " .. name
    label.TextColor3 = Theme.Text
    label.TextSize = FontSizeBtn
    label.Font = Enum.Font.GothamSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 103
    label.Parent = holder

    -- Description
    local descLabel = Instance.new("TextLabel")
    descLabel.Size = UDim2.new(1, -68, 0, 14)
    descLabel.Position = UDim2.new(0, 12, 0, IsMobile and 26 or 23)
    descLabel.BackgroundTransparency = 1
    descLabel.Text = desc
    descLabel.TextColor3 = Theme.SubText
    descLabel.TextSize = FontSizeDesc
    descLabel.Font = Enum.Font.Gotham
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.ZIndex = 103
    descLabel.Parent = holder

    -- Switch
    local swW = IsMobile and 46 or 38
    local swH = IsMobile and 24 or 20
    local dotSz = swH - 4

    local switchBG = Instance.new("Frame")
    switchBG.Size = UDim2.new(0, swW, 0, swH)
    switchBG.Position = UDim2.new(1, -(swW + 10), 0.5, -swH/2)
    switchBG.BackgroundColor3 = state and Theme.ToggleON or Theme.ToggleOFF
    switchBG.BorderSizePixel = 0
    switchBG.ZIndex = 103
    switchBG.Parent = holder

    Instance.new("UICorner", switchBG).CornerRadius = UDim.new(1, 0)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, dotSz, 0, dotSz)
    dot.Position = state
        and UDim2.new(1, -(dotSz + 2), 0.5, -dotSz/2)
        or UDim2.new(0, 2, 0.5, -dotSz/2)
    dot.BackgroundColor3 = Color3.new(1, 1, 1)
    dot.BorderSizePixel = 0
    dot.ZIndex = 104
    dot.Parent = switchBG

    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local function SetState(v)
        state = v
        callback(v)
        local ti = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenService:Create(switchBG, ti, {BackgroundColor3 = v and Theme.ToggleON or Theme.ToggleOFF}):Play()
        TweenService:Create(dot, ti, {
            Position = v
                and UDim2.new(1, -(dotSz+2), 0.5, -dotSz/2)
                or UDim2.new(0, 2, 0.5, -dotSz/2)
        }):Play()
        TweenService:Create(indicator, ti, {BackgroundColor3 = v and Theme.ToggleON or Theme.ToggleOFF}):Play()
        TweenService:Create(holder, ti, {
            BackgroundColor3 = v and Color3.fromRGB(25, 45, 35) or Theme.Button
        }):Play()
    end

    -- Clickable overlay
    local clickBtn = Instance.new("TextButton")
    clickBtn.Size = UDim2.new(1, 0, 1, 0)
    clickBtn.BackgroundTransparency = 1
    clickBtn.Text = ""
    clickBtn.ZIndex = 105
    clickBtn.Parent = holder

    clickBtn.MouseButton1Click:Connect(function()
        SetState(not state)
    end)

    return {SetState = SetState}
end

-- ============================================
-- BUILD MENU
-- ============================================
CreateSeparator("Master")

CreateToggle("ESP Master", "⚡", "Nyalakan/matikan semua ESP", Config.Enabled, function(v)
    Config.Enabled = v
    if not v then
        for _, d in pairs(ESPCache) do HideAll(d) end
    end
end)

CreateSeparator("Visual")

CreateToggle("Skeleton", "🦴", "Kerangka tulang pemain", Config.SkeletonESP, function(v) Config.SkeletonESP = v end)
CreateToggle("Box ESP", "📦", "Kotak di sekeliling pemain", Config.BoxESP, function(v) Config.BoxESP = v end)
CreateToggle("Name ESP", "📛", "Nama di atas kepala", Config.NameESP, function(v) Config.NameESP = v end)
CreateToggle("Health Bar", "❤️", "Bar HP di samping kiri", Config.HealthESP, function(v) Config.HealthESP = v end)
CreateToggle("Distance", "📏", "Jarak dalam studs", Config.DistanceESP, function(v) Config.DistanceESP = v end)
CreateToggle("Tracers", "📍", "Garis dari layar ke pemain", Config.Tracers, function(v) Config.Tracers = v end)
CreateToggle("Head Dot", "🔴", "Titik di kepala pemain", Config.HeadDot, function(v) Config.HeadDot = v end)

CreateSeparator("Settings")

CreateToggle("Team Check", "🤝", "Sembunyikan teman satu tim", Config.TeamCheck, function(v) Config.TeamCheck = v end)

-- Destroy button
ToggleOrder = ToggleOrder + 1
local destroyBtn = Instance.new("TextButton")
destroyBtn.Size = UDim2.new(1, 0, 0, IsMobile and 44 or 38)
destroyBtn.BackgroundColor3 = Theme.Danger
destroyBtn.Text = "🗑️  DESTROY NEXUS HUB"
destroyBtn.TextColor3 = Color3.new(1, 1, 1)
destroyBtn.TextSize = FontSizeBtn
destroyBtn.Font = Enum.Font.GothamBold
destroyBtn.BorderSizePixel = 0
destroyBtn.LayoutOrder = ToggleOrder
destroyBtn.ZIndex = 103
destroyBtn.AutoButtonColor = true
destroyBtn.Parent = ScrollFrame

Instance.new("UICorner", destroyBtn).CornerRadius = Theme.CornerSmall

destroyBtn.MouseButton1Click:Connect(function()
    if RenderConn then RenderConn:Disconnect() end
    for plr in pairs(ESPCache) do RemoveESP(plr) end
    ScreenGui:Destroy()
    _G.NexusHubLoaded = false
    _G.NexusGui = nil
    _G.NexusESPCache = nil
    _G.NexusRenderConn = nil
    _G.NexusToggleMenu = nil
    print("[Nexus Hub] Destroyed successfully!")
end)

-- ============================================
-- MENU ANIMATION
-- ============================================
local function ToggleMenu()
    MenuOpen = not MenuOpen

    if MenuOpen then
        MainFrame.Visible = true
        MainFrame.BackgroundTransparency = 1
        MainFrame.Size = UDim2.new(0, MenuWidth, 0, 0)
        MainFrame.Position = UDim2.new(0.5, -MenuWidth/2, 0.5, 0)

        local ti = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        TweenService:Create(MainFrame, ti, {
            Size = UDim2.new(0, MenuWidth, 0, MenuHeight),
            Position = UDim2.new(0.5, -MenuWidth/2, 0.5, -MenuHeight/2),
            BackgroundTransparency = 0,
        }):Play()

        TweenService:Create(FloatBtn, TweenInfo.new(0.25), {
            BackgroundColor3 = Theme.ToggleON,
        }):Play()
    else
        local ti = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        TweenService:Create(MainFrame, ti, {
            Size = UDim2.new(0, MenuWidth, 0, 0),
            Position = UDim2.new(0.5, -MenuWidth/2, 0.5, 0),
            BackgroundTransparency = 1,
        }):Play()

        TweenService:Create(FloatBtn, TweenInfo.new(0.25), {
            BackgroundColor3 = Theme.Accent,
        }):Play()

        task.delay(0.25, function()
            if not MenuOpen then
                MainFrame.Visible = false
            end
        end)
    end
end

_G.NexusToggleMenu = ToggleMenu

CloseBtn.MouseButton1Click:Connect(function()
    if MenuOpen then ToggleMenu() end
end)

-- Keyboard toggle
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift
    or input.KeyCode == Enum.KeyCode.Insert then
        ToggleMenu()
    end
end)

