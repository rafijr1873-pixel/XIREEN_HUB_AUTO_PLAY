-- ============================================
-- CLEANUP SCRIPT LAMA
-- ============================================
if _G.NexusLoaded then
    pcall(function()
        if _G.NexusRender then _G.NexusRender:Disconnect() end
        if _G.NexusCache then
            for _, d in pairs(_G.NexusCache) do
                pcall(function()
                    for _, b in pairs(d.Bones or {}) do if b then b:Remove() end end
                    for _, b in pairs(d.Box or {}) do if b then b:Remove() end end
                    if d.Name then d.Name:Remove() end
                    if d.Dist then d.Dist:Remove() end
                    if d.HPBG then d.HPBG:Remove() end
                    if d.HP then d.HP:Remove() end
                    if d.HPText then d.HPText:Remove() end
                    if d.Tracer then d.Tracer:Remove() end
                    if d.HeadDot then d.HeadDot:Remove() end
                end)
            end
        end
    end)
    pcall(function()
        if Rayfield then Rayfield:Destroy() end
    end)
    task.wait(0.5)
end
_G.NexusLoaded = true

