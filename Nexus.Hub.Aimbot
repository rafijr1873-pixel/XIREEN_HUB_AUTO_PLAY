-- ============================================
-- TOGGLE BUTTON CREATOR
-- ============================================
local ToggleOrder = 0

local function CreateToggle(name, icon, description, default, callback)
    ToggleOrder = ToggleOrder + 1
    local state = default

    local btnHeight = IsMobile and 52 or 44

    local Holder = Instance.new("Frame")
    Holder.Name = name .. "Toggle"
    Holder.Size = UDim2.new(1, -4, 0, btnHeight)
    Holder.BackgroundColor3 = Theme.Button
    Holder.BorderSizePixel = 0
    Holder.LayoutOrder = ToggleOrder
    Holder.ZIndex = 52
    Holder.Parent = ScrollFrame

    local hCorner = Instance.new("UICorner")
    hCorner.CornerRadius = Theme.CornerSmall
    hCorner.Parent = Holder

    -- Icon + Name
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -70, 0, 20)
    Label.Position = UDim2.new(0, 10, 0, IsMobile and 6 or 4)
    Label.BackgroundTransparency = 1
    Label.Text = icon .. "  " .. name
    Label.TextColor3 = Theme.Text
    Label.TextSize = IsMobile and 15 or 13
    Label.Font = Enum.Font.GothamSemibold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.ZIndex = 53
    Label.Parent = Holder

    -- Description
    local Desc = Instance.new("TextLabel")
    Desc.Size = UDim2.new(1, -70, 0, 14)
    Desc.Position = UDim2.new(0, 10, 0, IsMobile and 26 or 22)
    Desc.BackgroundTransparency = 1
    Desc.Text = description
    Desc.TextColor3 = Theme.SubText
    Desc.TextSize = IsMobile and 11 or 10
    Desc.Font = Enum.Font.Gotham
    Desc.TextXAlignment = Enum.TextXAlignment.Left
    Desc.ZIndex = 53
    Desc.Parent = Holder

    -- Toggle Switch Background
    local switchWidth = IsMobile and 48 or 40
    local switchHeight = IsMobile and 26 or 22
    local dotSize = switchHeight - 4

    local SwitchBG = Instance.new("Frame")
    SwitchBG.Name = "SwitchBG"
    SwitchBG.Size = UDim2.new(0, switchWidth, 0, switchHeight)
    SwitchBG.Position = UDim2.new(1, -(switchWidth + 10), 0.5, -(switchHeight/2))
    SwitchBG.BackgroundColor3 = state and Theme.ToggleON or Theme.ToggleOFF
    SwitchBG.BorderSizePixel = 0
    SwitchBG.ZIndex = 53
    SwitchBG.Parent = Holder

    local swCorner = Instance.new("UICorner")
    swCorner.CornerRadius = UDim.new(1, 0)
    swCorner.Parent = SwitchBG

    -- Toggle Dot
    local Dot = Instance.new("Frame")
    Dot.Name = "Dot"
    Dot.Size = UDim2.new(0, dotSize, 0, dotSize)
    Dot.Position = state 
        and UDim2.new(1, -(dotSize + 2), 0.5, -(dotSize/2))
        or UDim2.new(0, 2, 0.5, -(dotSize/2))
    Dot.BackgroundColor3 = Color3.new(1, 1, 1)
    Dot.BorderSizePixel = 0
    Dot.ZIndex = 54
    Dot.Parent = SwitchBG

    local dCorner = Instance.new("UICorner")
    dCorner.CornerRadius = UDim.new(1, 0)
    dCorner.Parent = Dot

    -- Animasi toggle
    local function SetState(newState)
        state = newState
        callback(state)

        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        TweenService:Create(SwitchBG, tweenInfo, {
            BackgroundColor3 = state and Theme.ToggleON or Theme.ToggleOFF
        }):Play()

        TweenService:Create(Dot, tweenInfo, {
            Position = state 
                and UDim2.new(1, -(dotSize + 2), 0.5, -(dotSize/2))
                or UDim2.new(0, 2, 0.5, -(dotSize/2))
        }):Play()

        TweenService:Create(Holder, tweenInfo, {
            BackgroundColor3 = state and Color3.fromRGB(30, 50, 40) or Theme.Button
        }):Play()
    end

    -- Click handler (seluruh holder bisa diklik)
    local ClickBtn = Instance.new("TextButton")
    ClickBtn.Size = UDim2.new(1, 0, 1, 0)
    ClickBtn.BackgroundTransparency = 1
    ClickBtn.Text = ""
    ClickBtn.ZIndex = 55
    ClickBtn.Parent = Holder

    ClickBtn.MouseButton1Click:Connect(function()
        SetState(not state)
    end)

    -- Hover effect (PC only)
    ClickBtn.MouseEnter:Connect(function()
        if not state then
            TweenService:Create(Holder, TweenInfo.new(0.15), {
                BackgroundColor3 = Theme.ButtonHover
            }):Play()
        end
    end)
    ClickBtn.MouseLeave:Connect(function()
        if not state then
            TweenService:Create(Holder, TweenInfo.new(0.15), {
                BackgroundColor3 = Theme.Button
            }):Play()
        end
    end)

    return {SetState = SetState, GetState = function() return state end}
end

-- ============================================
-- SECTION SEPARATOR
-- ============================================
local function CreateSeparator(text)
    ToggleOrder = ToggleOrder + 1

    local Sep = Instance.new("Frame")
    Sep.Size = UDim2.new(1, -4, 0, 22)
    Sep.BackgroundTransparency = 1
    Sep.LayoutOrder = ToggleOrder
    Sep.ZIndex = 52
    Sep.Parent = ScrollFrame

    local SepText = Instance.new("TextLabel")
    SepText.Size = UDim2.new(1, 0, 1, 0)
    SepText.BackgroundTransparency = 1
    SepText.Text = "━━ " .. text .. " ━━"
    SepText.TextColor3 = Theme.Accent
    SepText.TextSize = IsMobile and 12 or 11
    SepText.Font = Enum.Font.GothamBold
    SepText.ZIndex = 53
    SepText.Parent = Sep
end

