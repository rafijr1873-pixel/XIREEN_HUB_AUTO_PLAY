SettingsTab:CreateDropdown({
    Name = "📍 Tracer Start Point",
    Options = {"Bottom", "Center", "Mouse"},
    CurrentOption = {Config.TracerOrigin},
    MultipleOptions = false,
    Flag = "SET_TracerOrigin",
    Callback = function(v)
        Config.TracerOrigin = v[1] or v
    end,
})

