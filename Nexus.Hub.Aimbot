--// ============ GUI EVENTS ============ //--

ToggleButton.MouseButton1Click:Connect(function()
    guiOpen = not guiOpen
    MainFrame.Visible = guiOpen

    if guiOpen then
        MainFrame.Size = UDim2.new(0, 310, 0, 0)
        TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
            Size = UDim2.new(0, 310, 0, 420)
        }):Play()
    end

    TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
        BackgroundColor3 = guiOpen and Color3.fromRGB(0, 130, 200) or Color3.fromRGB(20, 20, 35)
    }):Play()
end)

CloseBtn.MouseButton1Click:Connect(function()
    guiOpen = false

    TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 310, 0, 0)
    }):Play()

    task.delay(0.2, function()
        MainFrame.Visible = false
        MainFrame.Size = UDim2.new(0, 310, 0, 420)
    end)

    TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(20, 20, 35)
    }):Play()
end)

--// ============ AIMBOT INPUT (PC) ============ //--

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aimHolding = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aimHolding = false
    end
end)

--// ============ MAIN RENDER LOOP ============ //--

RunService.RenderStepped:Connect(function()
    Camera = workspace.CurrentCamera

    -- FOV Circle
    UpdateFOVCircle()

    -- AIMBOT
    if Settings.Aimbot then
        local shouldAim = isMobile or aimHolding
        if shouldAim then
            local target = getClosestPlayer()
            if target and isAlive(target) then
                local part = target.Character:FindFirstChild(Settings.AimbotPart)
                    or target.Character:FindFirstChild("Head")
                    or target.Character:FindFirstChild("HumanoidRootPart")
                if part then
                    local targetCF = CFrame.new(Camera.CFrame.Position, part.Position)
                    Camera.CFrame = Camera.CFrame:Lerp(targetCF, 1 / math.max(Settings.AimbotSmooth, 1))
                end
            end
        end
    end

    -- SPEED
    if Settings.Speed then
        pcall(function()
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = Settings.SpeedVal end
        end)
    end

    -- JUMP POWER
    if Settings.JumpPower then
        pcall(function()
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.UseJumpPower = true
                hum.JumpPower = Settings.JumpVal
            end
        end)
    end

    -- NO FALL
    if Settings.NoFall then
        pcall(function()
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
            end
        end)
    end
end)

--// ============ INFINITE JUMP ============ //--

UserInputService.JumpRequest:Connect(function()
    if Settings.InfJump then
        pcall(function()
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    end
end)

--// ============ ESP SYSTEM ============ //--

local function CreateESP(player)
    if player == LocalPlayer then return end

    local function applyESP(char)
        if not char then return end
        task.wait(0.5)
        if not char or not char.Parent then return end

        -- Cleanup old
        pcall(function()
            local old1 = char:FindFirstChild("NX_HL") if old1 then old1:Destroy() end
            local old2 = char:FindFirstChild("NX_BB") if old2 then old2:Destroy() end
        end)

        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not head or not hum then return end

        -- Highlight
        local hl = Instance.new("Highlight")
        hl.Name = "NX_HL"
        hl.FillTransparency = 0.55
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee = char
        hl.Parent = char

        local isTeam = player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team
        if isTeam then
            hl.FillColor = Color3.fromRGB(0, 100, 255)
            hl.OutlineColor = Color3.fromRGB(0, 160, 255)
        else
            hl.FillColor = Color3.fromRGB(255, 30, 30)
            hl.OutlineColor = Color3.fromRGB(255, 200, 0)
        end

        -- Billboard GUI
        local bb = Instance.new("BillboardGui")
        bb.Name = "NX_BB"
        bb.Adornee = head
        bb.Size = UDim2.new(0, 150, 0, 40)
        bb.StudsOffset = Vector3.new(0, 2.5, 0)
        bb.AlwaysOnTop = true
        bb.MaxDistance = 400
        bb.Parent = char

        -- Name
        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size = UDim2.new(1, 0, 0, 14)
        nameLbl.Position = UDim2.new(0, 0, 0, 0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = player.DisplayName
        nameLbl.TextColor3 = Color3.new(1, 1, 1)
        nameLbl.TextSize = 12
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextStrokeTransparency = 0
        nameLbl.TextStrokeColor3 = Color3.new(0, 0, 0)
        nameLbl.Parent = bb

        -- HP Bar BG (SMALLER)
        local hpBG = Instance.new("Frame")
        hpBG.Size = UDim2.new(0.55, 0, 0, 3)
        hpBG.Position = UDim2.new(0.225, 0, 0, 16)
        hpBG.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        hpBG.BorderSizePixel = 0
        hpBG.Parent = bb
        Instance.new("UICorner", hpBG).CornerRadius = UDim.new(1, 0)

        local hpBGStroke = Instance.new("UIStroke", hpBG)
        hpBGStroke.Color = Color3.fromRGB(0, 0, 0)
        hpBGStroke.Thickness = 1

        -- HP Fill (SMALLER)
        local hpFill = Instance.new("Frame")
        hpFill.Name = "Fill"
        hpFill.Size = UDim2.new(1, 0, 1, 0)
        hpFill.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        hpFill.BorderSizePixel = 0
        hpFill.Parent = hpBG
        Instance.new("UICorner", hpFill).CornerRadius = UDim.new(1, 0)

        -- Distance
        local distLbl = Instance.new("TextLabel")
        distLbl.Name = "Dist"
        distLbl.Size = UDim2.new(1, 0, 0, 12)
        distLbl.Position = UDim2.new(0, 0, 0, 21)
        distLbl.BackgroundTransparency = 1
        distLbl.Text = "[0m]"
        distLbl.TextColor3 = Color3.fromRGB(190, 190, 190)
        distLbl.TextSize = 10
        distLbl.Font = Enum.Font.Gotham
        distLbl.TextStrokeTransparency = 0
        distLbl.TextStrokeColor3 = Color3.new(0, 0, 0)
        distLbl.Parent = bb

        -- HP Text (small, on top of bar)
        local hpText = Instance.new("TextLabel")
        hpText.Name = "HPText"
        hpText.Size = UDim2.new(1, 0, 0, 10)
        hpText.Position = UDim2.new(0, 0, 0, 33)
        hpText.BackgroundTransparency = 1
        hpText.Text = ""
        hpText.TextColor3 = Color3.fromRGB(255, 255, 255)
        hpText.TextSize = 9
        hpText.Font = Enum.Font.GothamBold
        hpText.TextStrokeTransparency = 0
        hpText.TextStrokeColor3 = Color3.new(0, 0, 0)
        hpText.Parent = bb

        -- Update loop
        spawn(function()
            while char and char.Parent and hum and hum.Parent do
                pcall(function()
                    if Settings.ESP then
                        -- Team check
                        local teamHide = Settings.ESPTeamCheck
                            and player.Team and LocalPlayer.Team
                            and player.Team == LocalPlayer.Team

                        hl.Enabled = not teamHide
                        bb.Enabled = not teamHide

                        if not teamHide and hum.Health > 0 then
                            -- Health
                            local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                            hpFill.Size = UDim2.new(pct, 0, 1, 0)
                            hpFill.BackgroundColor3 = Color3.fromRGB(
                                math.floor(255 * (1 - pct)),
                                math.floor(255 * pct),
                                50
                            )
                            hpText.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)

                            -- Distance
                            local myChar = LocalPlayer.Character
                            if myChar and myChar:FindFirstChild("HumanoidRootPart")
                                and char:FindFirstChild("HumanoidRootPart") then
                                local d = (myChar.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                                distLbl.Text = "[" .. math.floor(d) .. "m]"
                            end

                            -- Update team color
                            local nowTeam = player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team
                            if nowTeam then
                                hl.FillColor = Color3.fromRGB(0, 100, 255)
                                hl.OutlineColor = Color3.fromRGB(0, 160, 255)
                            else
                                hl.FillColor = Color3.fromRGB(255, 30, 30)
                                hl.OutlineColor = Color3.fromRGB(255, 200, 0)
                            end
                        end
                    else
                        hl.Enabled = false
                        bb.Enabled = false
                    end
                end)
                wait(0.1)
            end
        end)
    end

    -- Apply to current character
    if player.Character then
        spawn(function() applyESP(player.Character) end)
    end

    -- Apply on respawn
    local conn = player.CharacterAdded:Connect(function(char)
        spawn(function() applyESP(char) end)
    end)

    table.insert(ESPConnections, conn)
end

-- Setup ESP for all players
for _, plr in pairs(Players:GetPlayers()) do
    spawn(function() CreateESP(plr) end)
end

Players.PlayerAdded:Connect(function(plr)
    spawn(function() CreateESP(plr) end)
end)

-- Cleanup ESP when player leaves
Players.PlayerRemoving:Connect(function(plr)
    pcall(function()
        if plr.Character then
            local h = plr.Character:FindFirstChild("NX_HL") if h then h:Destroy() end
            local b = plr.Character:FindFirstChild("NX_BB") if b then b:Destroy() end
        end
    end)
end)

