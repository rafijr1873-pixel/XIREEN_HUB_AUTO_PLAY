CreateToggle(AimbotPage, "🎯 Aimbot", false, function(v) Settings.Aimbot = v end)
CreateToggle(AimbotPage, "🧱 Wall Check", true, function(v) Settings.WallCheck = v end)
CreateToggle(AimbotPage, "👥 Team Check", true, function(v) Settings.TeamCheck = v end)

CreateSelector(AimbotPage, "🎯 Aim Part",
    {"Head", "HumanoidRootPart", "Torso"}, "Head",
    function(v) Settings.AimbotPart = v end
)

CreateSlider(AimbotPage, "📐 FOV Radius", 50, 500, 200, function(v)
    Settings.AimbotFOV = v
    Settings.FOVRadius = v
    if FOVCircle then FOVCircle.Radius = v end
end)

CreateSlider(AimbotPage, "🎚️ Smoothness", 1, 20, 2, function(v)
    Settings.AimbotSmooth = v
end)

CreateSection(AimbotPage, "FOV CIRCLE")

CreateToggle(AimbotPage, "⭕ Show FOV Circle", false, function(v)
    Settings.FOVShow = v
    if FOVCircle then FOVCircle.Visible = v end
end)

-- ===== ESP TAB =====
CreateSection(ESPPage, "ESP")

CreateToggle(ESPPage, "👁️ Enable ESP", false, function(v)
    Settings.ESP = v
    if not v then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local h = plr.Character:FindFirstChild("NX_HL")
                if h then h:Destroy() end
                local b = plr.Character:FindFirstChild("NX_BB")
                if b then b:Destroy() end
            end
        end
    end
end)

CreateToggle(ESPPage, "👥 ESP Team Check", true, function(v)
    Settings.ESPTeamCheck = v
end)

-- ===== MISC TAB =====
CreateSection(MiscPage, "CHARACTER")

CreateToggle(MiscPage, "🏃 Speed Hack", false, function(v) Settings.Speed = v end)
CreateSlider(MiscPage, "🏃 Speed Value", 16, 200, 32, function(v) Settings.SpeedVal = v end)

CreateToggle(MiscPage, "🦘 Jump Power", false, function(v) Settings.JumpPower = v end)
CreateSlider(MiscPage, "🦘 Jump Value", 50, 300, 80, function(v) Settings.JumpVal = v end)

CreateToggle(MiscPage, "♾️ Infinite Jump", false, function(v) Settings.InfJump = v end)
CreateToggle(MiscPage, "🛡️ No Fall Damage", false, function(v) Settings.NoFall = v end)

CreateSection(MiscPage, "VISUAL")

CreateToggle(MiscPage, "💡 Fullbright", false, function(v)
    Settings.Fullbright = v
    if v then
        Lighting.Brightness       = 2
        Lighting.ClockTime        = 14
        Lighting.FogEnd           = 100000
        Lighting.GlobalShadows    = false
        Lighting.OutdoorAmbient   = Color3.fromRGB(128, 128, 128)
    else
        Lighting.Brightness       = 1
        Lighting.GlobalShadows    = true
    end
end)

