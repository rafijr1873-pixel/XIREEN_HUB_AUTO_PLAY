--// ============ COMPONENT BUILDERS ============ //--

local TabPages = {}
local tabOrder = 0

local function CreateTab(name, icon)
    tabOrder = tabOrder + 1
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0, 70, 1, 0)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    btn.Text = (icon or "") .. " " .. name
    btn.TextColor3 = Color3.fromRGB(140, 140, 140)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamSemibold
    btn.ZIndex = 12
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.LayoutOrder = tabOrder
    btn.Parent = TabBar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)

    local page = Instance.new("Frame")
    page.Name = name
    page.Size = UDim2.new(1, 0, 0, 0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ZIndex = 11
    page.LayoutOrder = tabOrder
    page.Parent = Content

    pcall(function() page.AutomaticSize = Enum.AutomaticSize.Y end)

    local pageLayout = Instance.new("UIListLayout", page)
    pageLayout.Padding = UDim.new(0, 5)
    pageLayout.SortOrder = Enum.SortOrder.LayoutOrder

    -- Manual height fallback
    pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.Size = UDim2.new(1, 0, 0, pageLayout.AbsoluteContentSize.Y)
    end)

    TabPages[name] = {Button = btn, Page = page}

    btn.MouseButton1Click:Connect(function()
        for _, t in pairs(TabPages) do
            t.Page.Visible = false
            t.Button.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
            t.Button.TextColor3 = Color3.fromRGB(140, 140, 140)
        end
        page.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
        btn.TextColor3 = Color3.new(1, 1, 1)
        task.wait()
        UpdateCanvas()
    end)

    return page
end

local elementOrder = 0

local function CreateSection(parent, text)
