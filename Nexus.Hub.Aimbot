    ToggleOFF = Color3.fromRGB(180, 45, 45),
    Text = Color3.fromRGB(235, 235, 245),
    SubText = Color3.fromRGB(140, 140, 165),
    Accent = Color3.fromRGB(90, 110, 255),
    AccentGlow = Color3.fromRGB(120, 140, 255),
    Danger = Color3.fromRGB(200, 40, 40),
    Corner = UDim.new(0, 8),
    CornerSmall = UDim.new(0, 6),
}

