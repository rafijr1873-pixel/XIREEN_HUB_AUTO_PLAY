-- ============================================
-- SERVICES
-- ============================================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local StarterGui = game:GetService("StarterGui")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- ============================================
-- KONFIGURASI
-- ============================================
local Config = {
    Enabled = true,
    SkeletonESP = true,
    BoxESP = true,
    NameESP = true,
    HealthESP = true,
    DistanceESP = true,
    Tracers = false,
    HeadDot = true,
    TeamCheck = false,
    MaxDistance = 2500,

    -- Warna
    EnemyColor = Color3.fromRGB(255, 60, 60),
    TeamColor = Color3.fromRGB(60, 255, 60),
    SkeletonColor = Color3.fromRGB(255, 255, 255),
    BoxColor = Color3.fromRGB(255, 255, 0),
    TracerColor = Color3.fromRGB(0, 200, 255),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthHighColor = Color3.fromRGB(0, 255, 0),
    HealthLowColor = Color3.fromRGB(255, 0, 0),

    SkeletonThickness = 1.5,
    BoxThickness = 1.5,
    TracerThickness = 1,
    HeadDotRadius = 3,
    TextSize = 13,
}

-- ============================================
-- SKELETON BONE DEFINITIONS
-- ============================================
local R15Bones = {
    {"Head", "UpperTorso"},
    {"UpperTorso", "LowerTorso"},
    {"UpperTorso", "LeftUpperArm"},
    {"LeftUpperArm", "LeftLowerArm"},
    {"LeftLowerArm", "LeftHand"},
    {"UpperTorso", "RightUpperArm"},
    {"RightUpperArm", "RightLowerArm"},
    {"RightLowerArm", "RightHand"},
    {"LowerTorso", "LeftUpperLeg"},
    {"LeftUpperLeg", "LeftLowerLeg"},
    {"LeftLowerLeg", "LeftFoot"},
    {"LowerTorso", "RightUpperLeg"},
    {"RightUpperLeg", "RightLowerLeg"},
    {"RightLowerLeg", "RightFoot"},
}

local R6Bones = {
    {"Head", "Torso"},
    {"Torso", "Left Arm"},
    {"Torso", "Right Arm"},
    {"Torso", "Left Leg"},
    {"Torso", "Right Leg"},
}

-- ============================================
-- UTILITY FUNCTIONS
-- ============================================
local function W2S(pos)
    local s, o = Camera:WorldToViewportPoint(pos)
    return Vector2.new(s.X, s.Y), o, s.Z
end

local function GetDist(pos)
    local c = LocalPlayer.Character
    if not c or not c:FindFirstChild("HumanoidRootPart") then return math.huge end
    return (c.HumanoidRootPart.Position - pos).Magnitude
end

local function IsAlly(plr)
    if not Config.TeamCheck then return false end
    return LocalPlayer.Team and plr.Team and LocalPlayer.Team == plr.Team
end

local function GetColor(plr)
    return IsAlly(plr) and Config.TeamColor or Config.EnemyColor
end

local function LerpColor(c1, c2, a)
    return Color3.new(c1.R+(c2.R-c1.R)*a, c1.G+(c2.G-c1.G)*a, c1.B+(c2.B-c1.B)*a)
end

local function IsR15(char)
    return char:FindFirstChild("UpperTorso") ~= nil
end

local function GetBounds(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return nil end

    local head = char:FindFirstChild("Head")
    local headPos = head and head.Position or (root.Position + Vector3.new(0,2,0))
    local footPos = root.Position - Vector3.new(0,3,0)

    local top, tOn = W2S(headPos + Vector3.new(0,0.5,0))
    local bot, bOn = W2S(footPos)
    if not tOn and not bOn then return nil end

    local h = math.abs(bot.Y - top.Y)
    local w = h * 0.6
    return {
        Top = top, Bottom = bot,
        Height = h, Width = w,
        Center = Vector2.new((top.X+bot.X)/2, (top.Y+bot.Y)/2)
    }
end

-- ============================================
-- DRAWING HELPERS
-- ============================================
local function NewLine(props)
    local l = Drawing.new("Line")
    l.Visible = false
    l.Color = props.Color or Color3.new(1,1,1)
    l.Thickness = props.Thickness or 1
    l.Transparency = props.Transparency or 1
    return l
end

local function NewText(props)
    local t = Drawing.new("Text")
    t.Visible = false
    t.Color = props.Color or Color3.new(1,1,1)
    t.Size = props.Size or 14
    t.Center = true
    t.Outline = true
    t.OutlineColor = Color3.new(0,0,0)
    t.Font = Drawing.Fonts.UI
    return t
end

local function NewCircle(props)
    local c = Drawing.new("Circle")
    c.Visible = false
    c.Color = props.Color or Color3.new(1,1,1)
    c.Thickness = props.Thickness or 1
    c.Filled = props.Filled or false
    c.NumSides = 20
    c.Transparency = props.Transparency or 1
    return c
end

-- ============================================
-- ESP OBJECT STORAGE
-- ============================================
local ESPCache = {}

local function MakeESP(plr)
    if plr == LocalPlayer then return end
    local data = {
        Player = plr,
        Bones = {},
        Box = {},
        Name = NewText({Color = Config.NameColor, Size = Config.TextSize}),
        Dist = NewText({Color = Color3.fromRGB(200,200,200), Size = Config.TextSize - 2}),
        HPBG = NewLine({Color = Color3.new(0,0,0), Thickness = 4}),
        HP = NewLine({Color = Config.HealthHighColor, Thickness = 2}),
        HPText = NewText({Color = Color3.new(1,1,1), Size = Config.TextSize - 3}),
        Tracer = NewLine({Color = Config.TracerColor, Thickness = Config.TracerThickness}),
        HeadDot = NewCircle({Color = Config.EnemyColor, Filled = true}),
    }
    for i = 1, 14 do
        data.Bones[i] = NewLine({Color = Config.SkeletonColor, Thickness = Config.SkeletonThickness})
    end
    for i = 1, 4 do
        data.Box[i] = NewLine({Color = Config.BoxColor, Thickness = Config.BoxThickness})
    end
    ESPCache[plr] = data
end

local function HideAll(d)
    for _,b in pairs(d.Bones) do b.Visible = false end
    for _,b in pairs(d.Box) do b.Visible = false end
    d.Name.Visible = false
    d.Dist.Visible = false
    d.HPBG.Visible = false
    d.HP.Visible = false
    d.HPText.Visible = false
    d.Tracer.Visible = false
    d.HeadDot.Visible = false
end

local function DestroyESP(plr)
    local d = ESPCache[plr]
    if not d then return end
    for _,b in pairs(d.Bones) do b:Remove() end
    for _,b in pairs(d.Box) do b:Remove() end
    d.Name:Remove() d.Dist:Remove()
    d.HPBG:Remove() d.HP:Remove() d.HPText:Remove()
    d.Tracer:Remove() d.HeadDot:Remove()
    ESPCache[plr] = nil
end

-- ============================================
-- UPDATE ESP
-- ============================================
local function UpdateESP(plr, d)
    if not Config.Enabled or plr == LocalPlayer then HideAll(d) return end

    local char = plr.Character
    if not char then HideAll(d) return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root or hum.Health <= 0 then HideAll(d) return end

    local dist = GetDist(root.Position)
    if dist > Config.MaxDistance then HideAll(d) return end
    if Config.TeamCheck and IsAlly(plr) then HideAll(d) return end

    local _, onScreen, depth = W2S(root.Position)
    if not onScreen or depth < 0 then HideAll(d) return end

    local bounds = GetBounds(char)
    if not bounds then HideAll(d) return end

    local col = GetColor(plr)

    -- SKELETON
    if Config.SkeletonESP then
        local bones = IsR15(char) and R15Bones or R6Bones
        for i, bp in ipairs(bones) do
            local p1 = char:FindFirstChild(bp[1])
            local p2 = char:FindFirstChild(bp[2])
            if p1 and p2 and d.Bones[i] then
                local s1, o1 = W2S(p1.Position)
                local s2, o2 = W2S(p2.Position)
                if o1 and o2 then
                    d.Bones[i].From = s1
                    d.Bones[i].To = s2
                    d.Bones[i].Color = Config.SkeletonColor
                    d.Bones[i].Thickness = Config.SkeletonThickness
                    d.Bones[i].Visible = true
                else d.Bones[i].Visible = false end
            elseif d.Bones[i] then d.Bones[i].Visible = false end
        end
        local cnt = #(IsR15(char) and R15Bones or R6Bones)
        for i = cnt+1, #d.Bones do d.Bones[i].Visible = false end
    else
        for _,b in pairs(d.Bones) do b.Visible = false end
    end

    -- BOX
    if Config.BoxESP then
        local tl = Vector2.new(bounds.Center.X - bounds.Width/2, bounds.Top.Y)
        local tr = Vector2.new(bounds.Center.X + bounds.Width/2, bounds.Top.Y)
        local bl = Vector2.new(bounds.Center.X - bounds.Width/2, bounds.Bottom.Y)
        local br = Vector2.new(bounds.Center.X + bounds.Width/2, bounds.Bottom.Y)
        d.Box[1].From=tl d.Box[1].To=tr d.Box[1].Color=col d.Box[1].Visible=true
        d.Box[2].From=bl d.Box[2].To=br d.Box[2].Color=col d.Box[2].Visible=true
        d.Box[3].From=tl d.Box[3].To=bl d.Box[3].Color=col d.Box[3].Visible=true
        d.Box[4].From=tr d.Box[4].To=br d.Box[4].Color=col d.Box[4].Visible=true
    else for _,b in pairs(d.Box) do b.Visible=false end end

    -- NAME
    if Config.NameESP then
        d.Name.Text = plr.DisplayName
        d.Name.Position = Vector2.new(bounds.Center.X, bounds.Top.Y - 16)
        d.Name.Color = col
        d.Name.Visible = true
    else d.Name.Visible = false end

    -- DISTANCE
    if Config.DistanceESP then
        d.Dist.Text = string.format("[%dm]", math.floor(dist))
        d.Dist.Position = Vector2.new(bounds.Center.X, bounds.Bottom.Y + 2)
        d.Dist.Visible = true
    else d.Dist.Visible = false end

    -- HEALTH BAR
    if Config.HealthESP then
        local pct = hum.Health / hum.MaxHealth
        local hcol = LerpColor(Config.HealthLowColor, Config.HealthHighColor, pct)
        local bx = bounds.Center.X - bounds.Width/2 - 6
        d.HPBG.From = Vector2.new(bx, bounds.Top.Y)
        d.HPBG.To = Vector2.new(bx, bounds.Bottom.Y)
        d.HPBG.Thickness = 4
        d.HPBG.Transparency = 0.5
        d.HPBG.Visible = true
        local ht = bounds.Bottom.Y - (bounds.Height * pct)
        d.HP.From = Vector2.new(bx, ht)
        d.HP.To = Vector2.new(bx, bounds.Bottom.Y)
        d.HP.Color = hcol
        d.HP.Visible = true
        if pct < 1 then
            d.HPText.Text = tostring(math.floor(hum.Health))
            d.HPText.Position = Vector2.new(bx, ht - 10)
            d.HPText.Color = hcol
            d.HPText.Visible = true
        else d.HPText.Visible = false end
    else
        d.HPBG.Visible=false d.HP.Visible=false d.HPText.Visible=false
    end

    -- TRACERS
    if Config.Tracers then
        local vs = Camera.ViewportSize
        d.Tracer.From = Vector2.new(vs.X/2, vs.Y)
        d.Tracer.To = Vector2.new(bounds.Center.X, bounds.Bottom.Y)
        d.Tracer.Color = Config.TracerColor
        d.Tracer.Visible = true
    else d.Tracer.Visible = false end

    -- HEAD DOT
    if Config.HeadDot then
        local head = char:FindFirstChild("Head")
        if head then
            local hp, ho = W2S(head.Position)
            if ho then
                d.HeadDot.Position = hp
                d.HeadDot.Radius = math.clamp(Config.HeadDotRadius * (400/dist), 1, 8)
                d.HeadDot.Color = col
                d.HeadDot.Filled = true
                d.HeadDot.Visible = true
            else d.HeadDot.Visible = false end
        else d.HeadDot.Visible = false end
    else d.HeadDot.Visible = false end
end

-- ============================================
-- PLAYER EVENTS
-- ============================================
for _, p in ipairs(Players:GetPlayers()) do MakeESP(p) end
Players.PlayerAdded:Connect(MakeESP)
Players.PlayerRemoving:Connect(DestroyESP)

local RenderConn = RunService.RenderStepped:Connect(function()
    for plr, data in pairs(ESPCache) do
        if plr and plr.Parent then
            UpdateESP(plr, data)
        else HideAll(data) end
    end
end)

