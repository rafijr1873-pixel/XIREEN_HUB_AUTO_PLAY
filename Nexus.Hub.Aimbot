-- ============================================
-- DESTROY BUTTON
-- ============================================
do
    ToggleOrder = ToggleOrder + 1

    local DestroyBtn = Instance.new("TextButton")
    DestroyBtn.Size = UDim2.new(1, -4, 0, IsMobile and 44 or 38)
    DestroyBtn.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
    DestroyBtn.Text = "🗑️  DESTROY ESP"
    DestroyBtn.TextColor3 = Color3.new(1,1,1)
    DestroyBtn.TextSize = IsMobile and 15 or 13
    DestroyBtn.Font = Enum.Font.GothamBold
    DestroyBtn.BorderSizePixel = 0
    DestroyBtn.LayoutOrder = ToggleOrder
    DestroyBtn.ZIndex = 53
    DestroyBtn.Parent = ScrollFrame

    local dbCorner = Instance.new("UICorner")
    dbCorner.CornerRadius = Theme.CornerSmall
    dbCorner.Parent = DestroyBtn

    DestroyBtn.MouseButton1Click:Connect(function()
        -- Hapus semua ESP
        if RenderConn then RenderConn:Disconnect() end
        for plr, _ in pairs(ESPCache) do DestroyESP(plr) end
        ScreenGui:Destroy()
        print("[ESP] Destroyed successfully")
    end)
end

-- ============================================
-- MENU OPEN/CLOSE ANIMATION
-- ============================================
local function ToggleMenu()
    MenuOpen = not MenuOpen

    if MenuOpen then
        MainFrame.Visible = true
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)

        local targetSize = UDim2.new(0, IsMobile and 280 or 250, 0, IsMobile and 440 or 400)
        local targetPos = UDim2.new(0.5, -(IsMobile and 140 or 125), 0.5, -(IsMobile and 220 or 200))

        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = targetSize,
            Position = targetPos
        }):Play()

        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Theme.ToggleON,
            Rotation = 180
        }):Play()
    else
        TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0)
        }):Play()

        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Theme.Accent,
            Rotation = 0
        }):Play()

        task.delay(0.2, function()
            if not MenuOpen then
                MainFrame.Visible = false
            end
        end)
    end
end

ToggleButton.MouseButton1Click:Connect(ToggleMenu)
CloseBtn.MouseButton1Click:Connect(function()
    if MenuOpen then ToggleMenu() end
end)

-- ============================================
-- KEYBOARD TOGGLE (PC)
-- ============================================
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        ToggleMenu()
    end
end)

-- ============================================
-- MAKE TOGGLE BUTTON DRAGGABLE (Mobile)
-- ============================================
do
    local dragging, dragStart, startPos

    ToggleButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = ToggleButton.Position
        end
    end)

    ToggleButton.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            if delta.Magnitude > 10 then -- Threshold supaya tidak trigger click
                ToggleButton.Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            end
        end
    end)
end

