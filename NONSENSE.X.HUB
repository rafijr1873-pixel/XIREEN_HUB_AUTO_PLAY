-- NOTIFICATION SYSTEM
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local notifY = 0

local function notify(title, text, duration)
    duration = duration or 3

    local notif = Instance.new("Frame", screenGui)
    notif.BackgroundColor3 = Color3.fromRGB(25, 25, 38)
    notif.BorderSizePixel = 0
    notif.Size = UDim2.new(0, 240, 0, 56)
    notif.Position = UDim2.new(1, 10, 1, -66 - notifY)
    notif.ZIndex = 50
    notif.ClipsDescendants = true

    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 8)

    local ns = Instance.new("UIStroke", notif)
    ns.Color = Color3.fromRGB(70, 130, 255)
    ns.Thickness = 1
    ns.Transparency = 0.5

    local nAccent = Instance.new("Frame", notif)
    nAccent.BackgroundColor3 = Color3.fromRGB(70, 130, 255)
    nAccent.BorderSizePixel = 0
    nAccent.Size = UDim2.new(0, 3, 1, 0)
    nAccent.ZIndex = 51

    local nTitle = Instance.new("TextLabel", notif)
    nTitle.BackgroundTransparency = 1
    nTitle.Position = UDim2.new(0, 12, 0, 4)
    nTitle.Size = UDim2.new(1, -16, 0, 18)
    nTitle.Font = Enum.Font.GothamBold
    nTitle.Text = title
    nTitle.TextColor3 = Color3.fromRGB(100, 170, 255)
    nTitle.TextSize = 12
    nTitle.TextXAlignment = Enum.TextXAlignment.Left
    nTitle.ZIndex = 51

    local nText = Instance.new("TextLabel", notif)
    nText.BackgroundTransparency = 1
    nText.Position = UDim2.new(0, 12, 0, 22)
    nText.Size = UDim2.new(1, -16, 0, 30)
    nText.Font = Enum.Font.Gotham
    nText.Text = text
    nText.TextColor3 = Color3.fromRGB(180, 195, 220)
    nText.TextSize = 11
    nText.TextXAlignment = Enum.TextXAlignment.Left
    nText.TextWrapped = true
    nText.ZIndex = 51

    local yOff = notifY
    notifY = notifY + 62

    TweenService:Create(notif, tweenSmooth, {
        Position = UDim2.new(1, -250, 1, -66 - yOff)
    }):Play()

    task.delay(duration, function()
        TweenService:Create(notif, tweenSmooth, {
            Position = UDim2.new(1, 10, 1, -66 - yOff)
        }):Play()
        task.delay(0.5, function()
            notif:Destroy()
            notifY = math.max(0, notifY - 62)
        end)
    end)
end

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- UI BUILDER HELPERS
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local function createPage(name)
    local page = Instance.new("ScrollingFrame", contentArea)
    page.Name = "Page_" .. name
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.Position = UDim2.new(0, 0, 0, 40)
    page.Size = UDim2.new(1, 0, 1, -40)
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Color3.fromRGB(70, 130, 255)
    page.ScrollBarImageTransparency = 0.3
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false
    page.ZIndex = 3

    local lay = Instance.new("UIListLayout", page)
    lay.Padding = UDim.new(0, 5)
    lay.SortOrder = Enum.SortOrder.LayoutOrder

    local pad = Instance.new("UIPadding", page)
    pad.PaddingTop = UDim.new(0, 4)
    pad.PaddingBottom = UDim.new(0, 8)
    pad.PaddingLeft = UDim.new(0, 10)
    pad.PaddingRight = UDim.new(0, 12)

    return page
end

local function createSection(parent, text, order)
    local lbl = Instance.new("TextLabel", parent)
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Font = Enum.Font.GothamBold
    lbl.Text = "  " .. text
    lbl.TextColor3 = Color3.fromRGB(100, 170, 255)
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.LayoutOrder = order
    lbl.ZIndex = 4

    local sep = Instance.new("Frame", parent)
    sep.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    sep.BorderSizePixel = 0
    sep.Size = UDim2.new(1, 0, 0, 1)
    sep.LayoutOrder = order + 1
    sep.ZIndex = 4
end

local function createToggle(parent, text, default, callback, order)
    local toggled = default or false

    local btn = Instance.new("TextButton", parent)
    btn.Name = "T_" .. text
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 58)
    btn.BorderSizePixel = 0
    btn.Size = UDim2.new(1, 0, 0, 34)
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.LayoutOrder = order
    btn.ZIndex = 4
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(55, 55, 75)
    stroke.Thickness = 1
    stroke.Transparency = 0.4

    local lbl = Instance.new("TextLabel", btn)
    lbl.BackgroundTransparency = 1
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.Size = UDim2.new(0.65, 0, 1, 0)
    lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(185, 200, 225)
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 5

    local ind = Instance.new("Frame", btn)
    ind.BackgroundColor3 = toggled and Color3.fromRGB(50, 180, 110) or Color3.fromRGB(70, 70, 95)
    ind.BorderSizePixel = 0
    ind.Size = UDim2.new(0, 34, 0, 17)
    ind.Position = UDim2.new(1, -46, 0.5, -8)
    ind.ZIndex = 5
    Instance.new("UICorner", ind).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", ind)
    circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    circle.BorderSizePixel = 0
    circle.Size = UDim2.new(0, 13, 0, 13)
    circle.Position = toggled and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
    circle.ZIndex = 6
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local function refresh()
        if toggled then
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(50, 180, 110)}):Play()
            TweenService:Create(circle, tweenFast, {Position = UDim2.new(1, -15, 0.5, -6)}):Play()
            TweenService:Create(stroke, tweenFast, {Color = Color3.fromRGB(50, 180, 110), Transparency = 0.3}):Play()
        else
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(70, 70, 95)}):Play()
            TweenService:Create(circle, tweenFast, {Position = UDim2.new(0, 2, 0.5, -6)}):Play()
            TweenService:Create(stroke, tweenFast, {Color = Color3.fromRGB(55, 55, 75), Transparency = 0.4}):Play()
        end
    end

    btn.MouseButton1Click:Connect(function()
        toggled = not toggled
        refresh()
        callback(toggled)
    end)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(50, 50, 72)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(40, 40, 58)}):Play()
    end)

    if toggled then refresh(); callback(true) end
    return btn
end

local function createSlider(parent, text, min, max, default, callback, order)
    local value = default or min

    local container = Instance.new("Frame", parent)
    container.BackgroundColor3 = Color3.fromRGB(40, 40, 58)
    container.BorderSizePixel = 0
    container.Size = UDim2.new(1, 0, 0, 50)
    container.LayoutOrder = order
    container.ZIndex = 4
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", container).Color = Color3.fromRGB(55, 55, 75)

    local lbl = Instance.new("TextLabel", container)
    lbl.BackgroundTransparency = 1
    lbl.Position = UDim2.new(0, 12, 0, 2)
    lbl.Size = UDim2.new(0.55, 0, 0, 20)
    lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(185, 200, 225)
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 5

    local valLbl = Instance.new("TextLabel", container)
    valLbl.BackgroundTransparency = 1
    valLbl.Position = UDim2.new(0.6, 0, 0, 2)
    valLbl.Size = UDim2.new(0.35, 0, 0, 20)
    valLbl.Font = Enum.Font.GothamBold
    valLbl.Text = tostring(value)
    valLbl.TextColor3 = Color3.fromRGB(100, 170, 255)
    valLbl.TextSize = 12
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.ZIndex = 5

    local bg = Instance.new("Frame", container)
    bg.Name = "SliderBG"
    bg.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
    bg.BorderSizePixel = 0
    bg.Position = UDim2.new(0, 12, 0, 28)
    bg.Size = UDim2.new(1, -24, 0, 6)
    bg.ZIndex = 5
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", bg)
    fill.BackgroundColor3 = Color3.fromRGB(70, 130, 255)
    fill.BorderSizePixel = 0
    fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    fill.ZIndex = 6
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local fillGrad = Instance.new("UIGradient", fill)
    fillGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 120, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(120, 200, 255))
    })

    local knob = Instance.new("Frame", bg)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
    knob.ZIndex = 7
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local isDragging = false

    local function update(inputPos)
        local rel = math.clamp((inputPos.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max - min) * rel)
        valLbl.Text = tostring(value)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -7, 0.5, -7)
        callback(value)
    end

    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            update(input.Position)
        end
    end)

    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch) then
            update(input.Position)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    return container
end

local function createButton(parent, text, callback, order)
    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = Color3.fromRGB(55, 100, 220)
    btn.BackgroundTransparency = 0.25
    btn.BorderSizePixel = 0
    btn.Size = UDim2.new(1, 0, 0, 32)
    btn.Font = Enum.Font.GothamMedium
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(220, 235, 255)
    btn.TextSize = 12
    btn.AutoButtonColor = false
    btn.LayoutOrder = order
    btn.ZIndex = 4
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(callback)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.05}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.25}):Play()
    end)

    return btn
end

local function createLabel(parent, text, order)
    local lbl = Instance.new("TextLabel", parent)
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 18)
    lbl.Font = Enum.Font.Gotham
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(140, 150, 170)
    lbl.TextSize = 11
    lbl.TextWrapped = true
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.LayoutOrder = order
    lbl.ZIndex = 4
    return lbl
end

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- TAB DEFINITIONS
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local tabNames = {
    "рҹҸ  Main",
    "вҡ”пёҸ Combat",
    "рҹ‘ҒпёҸ Visuals",
    "рҹҢҚ Teleport",
    "рҹҺ® Player",
    "рҹ”§ Misc",
    "вҡҷпёҸ Settings"
}

local tabButtons = {}
local pages = {}

-- Create Tab Buttons
for i, name in ipairs(tabNames) do
    local tab = Instance.new("TextButton", sidebar)
    tab.Name = "Tab_" .. i
    tab.BackgroundColor3 = (i == 1) and Color3.fromRGB(55, 110, 255) or Color3.fromRGB(35, 35, 50)
    tab.BackgroundTransparency = (i == 1) and 0.15 or 0.45
    tab.BorderSizePixel = 0
    tab.Size = UDim2.new(1, 0, 0, 30)
    tab.Font = (i == 1) and Enum.Font.GothamSemibold or Enum.Font.Gotham
    tab.Text = name
    tab.TextColor3 = (i == 1) and Color3.fromRGB(225, 240, 255) or Color3.fromRGB(135, 135, 160)
    tab.TextSize = 11
    tab.AutoButtonColor = false
    tab.LayoutOrder = i
    tab.ZIndex = 6
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 7)

    tabButtons[i] = tab
end

-- Create Pages
for i, name in ipairs(tabNames) do
    pages[i] = createPage(name)
    if i == 1 then pages[i].Visible = true end
end

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- PAGE 1: рҹҸ  MAIN
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[1], "MOVEMENT", 1)

createToggle(pages[1], "вҡЎ Speed Hack", false, function(state)
    States.speed = state
    if not state then
        local h = getHumanoid()
        if h then h.WalkSpeed = 16 end
    end
    notify("Speed Hack", state and "Enabled" or "Disabled", 2)
end, 3)

createSlider(pages[1], "Walk Speed", 16, 500, 16, function(val)
    States.walkSpeed = val
end, 4)

createToggle(pages[1], "рҹҰҳ Infinite Jump", false, function(state)
    States.infiniteJump = state
    notify("Infinite Jump", state and "Enabled" or "Disabled", 2)
end, 5)

createToggle(pages[1], "рҹ‘» Noclip", false, function(state)
    States.noclip = state
    notify("Noclip", state and "Enabled - walk through walls" or "Disabled", 2)
end, 6)

createSection(pages[1], "FLIGHT", 7)

createToggle(pages[1], "рҹ•ҠпёҸ Fly Mode", false, function(state)
    States.fly = state
    if state then
        local hrp = getHRP()
        if hrp then
            flyBV = Instance.new("BodyVelocity", hrp)
            flyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            flyBV.Velocity = Vector3.zero

            flyBG = Instance.new("BodyGyro", hrp)
            flyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            flyBG.D = 200
            flyBG.P = 10000
        end
    else
        if flyBV then flyBV:Destroy() flyBV = nil end
        if flyBG then flyBG:Destroy() flyBG = nil end
    end
    notify("Fly", state and "Enabled - WASD + Space/LShift" or "Disabled", 3)
end, 9)

createSlider(pages[1], "Fly Speed", 10, 300, 50, function(val)
    States.flySpeed = val
end, 10)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- PAGE 2: вҡ”пёҸ COMBAT
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[2], "AUTO", 1)

createToggle(pages[2], "рҹ–ұпёҸ Auto Click (Tool)", false, function(state)
    States.autoClick = state
    notify("Auto Click", state and "Enabled - equip a tool!" or "Disabled", 2)
end, 3)

createSlider(pages[2], "Click Delay (ms)", 50, 1000, 100, function(val)
    States.clickDelay = val
end, 4)

createSection(pages[2], "REACH", 5)

createToggle(pages[2], "рҹ—ЎпёҸ Extended Reach", false, function(state)
    if state then
        local char = LocalPlayer.Character
        if char then
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then
                    local handle = tool:FindFirstChild("Handle")
                    if handle then
                        handle.Size = Vector3.new(1, 1, 50)
                        handle.Transparency = 0.8
                        handle.Massless = true
                    end
                end
            end
        end
        notify("Reach", "Extended - re-equip tool if needed", 2)
    else
        local char = LocalPlayer.Character
        if char then
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then
                    local handle = tool:FindFirstChild("Handle")
                    if handle then
                        handle.Size = Vector3.new(1, 1, 1)
                        handle.Transparency = 0
                    end
                end
            end
        end
        notify("Reach", "Reset to normal", 2)
    end
end, 7)

createSection(pages[2], "INFO", 9)
createLabel(pages[2], "вҡ пёҸ Combat features depend on game", 10)
createLabel(pages[2], "вҡ пёҸ Server-side checks may block some", 11)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- PAGE 3: рҹ‘ҒпёҸ VISUALS
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[3], "PLAYERS", 1)

createToggle(pages[3], "рҹ‘ҒпёҸ ESP Highlight", false, function(state)
    States.esp = state
    if state then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                -- Highlight
                local hl = Instance.new("Highlight")
                hl.Name = "NonsenseESP"
                hl.FillColor = Color3.fromRGB(255, 50, 50)
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.FillTransparency = 0.5
                hl.OutlineTransparency = 0
                hl.Parent = plr.Character
                -- Name Billboard
                local head = plr.Character:FindFirstChild("Head")
                if head then
                    local bb = Instance.new("BillboardGui")
                    bb.Name = "NonsenseESPTag"
                    bb.Adornee = head
                    bb.Size = UDim2.new(0, 200, 0, 40)
                    bb.StudsOffset = Vector3.new(0, 2.5, 0)
                    bb.AlwaysOnTop = true
                    bb.Parent = head

                    local nameTag = Instance.new("TextLabel", bb)
                    nameTag.BackgroundTransparency = 1
                    nameTag.Size = UDim2.new(1, 0, 0.5, 0)
                    nameTag.Font = Enum.Font.GothamBold
                    nameTag.Text = plr.DisplayName
                    nameTag.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameTag.TextStrokeTransparency = 0
                    nameTag.TextSize = 14

                    local distTag = Instance.new("TextLabel", bb)
                    distTag.Name = "Dist"
                    distTag.BackgroundTransparency = 1
                    distTag.Position = UDim2.new(0, 0, 0.5, 0)
                    distTag.Size = UDim2.new(1, 0, 0.5, 0)
                    distTag.Font = Enum.Font.Gotham
                    distTag.Text = "0m"
                    distTag.TextColor3 = Color3.fromRGB(200, 200, 200)
                    distTag.TextStrokeTransparency = 0.3
                    distTag.TextSize = 12
                end
                espElements[plr] = true
            end
        end
        notify("ESP", "Enabled - showing all players", 2)
    else
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Character then
                local hl = plr.Character:FindFirstChild("NonsenseESP")
                if hl then hl:Destroy() end
                local head = plr.Character:FindFirstChild("Head")
                if head then
                    local bb = head:FindFirstChild("NonsenseESPTag")
                    if bb then bb:Destroy() end
                end
            end
        end
        espElements = {}
        notify("ESP", "Disabled", 2)
    end
end, 3)

createSection(pages[3], "LIGHTING", 5)

createToggle(pages[3], "вҳҖпёҸ Fullbright", false, function(state)
    States.fullbright = state
    if state then
        origLighting.Ambient = Lighting.Ambient
        origLighting.Brightness = Lighting.Brightness
        origLighting.OutdoorAmbient = Lighting.OutdoorAmbient
        Lighting.Ambient = Color3.fromRGB(200, 200, 200)
        Lighting.Brightness = 2
        Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
    else
        Lighting.Ambient = origLighting.Ambient or Color3.fromRGB(127, 127, 127)
        Lighting.Brightness = origLighting.Brightness or 1
        Lighting.OutdoorAmbient = origLighting.OutdoorAmbient or Color3.fromRGB(127, 127, 127)
    end
    notify("Fullbright", state and "Enabled" or "Disabled", 2)
end, 7)

createToggle(pages[3], "рҹҢ«пёҸ No Fog", false, function(state)
    States.noFog = state
    if state then
        origLighting.FogEnd = Lighting.FogEnd
        origLighting.FogStart = Lighting.FogStart
        Lighting.FogEnd = 9e9
        Lighting.FogStart = 9e9
    else
        Lighting.FogEnd = origLighting.FogEnd or 1e5
        Lighting.FogStart = origLighting.FogStart or 0
    end
    notify("Fog", state and "Removed" or "Restored", 2)
end, 8)

createSection(pages[3], "CAMERA", 10)

createSlider(pages[3], "Field of View", 30, 120, 70, function(val)
    States.fov = val
    Camera.FieldOfView = val
end, 12)

createSection(pages[3], "WORLD CLEANUP", 14)

createButton(pages[3], "рҹ—‘пёҸ Remove Particles/Effects", function()
    local count = 0
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke")
        or v:IsA("Sparkles") or v:IsA("Trail") then
            v.Enabled = false
            count = count + 1
        end
    end
    notify("Cleanup", "Disabled " .. count .. " particle effects", 2)
end, 16)

createButton(pages[3], "рҹ–јпёҸ Remove Decals/Textures", function()
    local count = 0
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1
            count = count + 1
        end
    end
    notify("Cleanup", "Hidden " .. count .. " decals/textures", 2)
end, 17)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- PAGE 4: рҹҢҚ TELEPORT
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[4], "QUICK TELEPORT", 1)

createToggle(pages[4], "рҹ“Қ Click TP (Ctrl + Click)", false, function(state)
    States.clickTP = state
    notify("Click TP", state and "Ctrl + Left Click to teleport" or "Disabled", 2)
end, 3)

createButton(pages[4], "рҹҺҜ TP to Mouse Position", function()
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0, 3, 0))
        notify("Teleport", "Teleported to cursor", 2)
    end
end, 4)

createSection(pages[4], "PLAYERS", 6)

local playerBtns = {}

local function refreshPlayerList()
    for _, b in pairs(playerBtns) do
        if b and b.Parent then b:Destroy() end
    end
    playerBtns = {}

    local ord = 8
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            ord = ord + 1
            local b = createButton(pages[4], "рҹ“Қ " .. plr.DisplayName .. " (@" .. plr.Name .. ")", function()
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = getHRP()
                    if hrp then
                        hrp.CFrame = plr.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                        notify("Teleport", "Teleported to " .. plr.DisplayName, 2)
                    end
                else
                    notify("Error", plr.DisplayName .. " character not found", 2)
                end
            end, ord)
            table.insert(playerBtns, b)
        end
    end

    if #playerBtns == 0 then
        createLabel(pages[4], "  No other players in server", ord + 1)
    end
end

createButton(pages[4], "рҹ”„ Refresh Player List", function()
    refreshPlayerList()
    notify("Teleport", "Player list refreshed", 2)
end, 7)

refreshPlayerList()

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- PAGE 5: рҹҺ® PLAYER
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[5], "SURVIVAL", 1)

createToggle(pages[5], "вқӨпёҸ God Mode (Client)", false, function(state)
    States.godMode = state
    notify("God Mode", state and "Enabled - healing every frame" or "Disabled", 2)
end, 3)

createToggle(pages[5], "рҹӣЎпёҸ No Fall Damage", false, function(state)
    States.noFallDmg = state
    local h = getHumanoid()
    if h then
        h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, not state)
        h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, not state)
    end
    notify("Fall Damage", state and "Disabled" or "Enabled", 2)
end, 4)

createSection(pages[5], "PHYSICS", 6)

createSlider(pages[5], "Jump Power", 50, 500, 50, function(val)
    States.jumpPower = val
    local h = getHumanoid()
    if h then
        h.UseJumpPower = true
        h.JumpPower = val
    end
end, 8)

createSlider(pages[5], "Gravity", 0, 500, 196, function(val)
    States.gravity = val
    Workspace.Gravity = val
end, 9)

createSection(pages[5], "CHARACTER", 11)

createButton(pages[5], "рҹ’Җ Reset Character", function()
    local h = getHumanoid()
    if h then
        h.Health = 0
        notify("Player", "Character reset", 2)
    end
end, 13)

createButton(pages[5], "рҹ§Ҡ Freeze Character", function()
    local hrp = getHRP()
    if hrp then
        hrp.Anchored = not hrp.Anchored
        notify("Player", hrp.Anchored and "Frozen" or "Unfrozen", 2)
    end
end, 14)

createButton(pages[5], "рҹ“Ҹ Normal Size", function()
    local char = LocalPlayer.Character
    if char then
        local h = char:FindFirstChildOfClass("Humanoid")
        if h then
            h.BodyDepthScale.Value = 1
            h.BodyHeightScale.Value = 1
            h.BodyWidthScale.Value = 1
            h.HeadScale.Value = 1
        end
    end
    notify("Player", "Size reset to normal", 2)
end, 15)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- PAGE 6: рҹ”§ MISC
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[6], "UTILITY", 1)

createToggle(pages[6], "рҹ’Ө Anti AFK", false, function(state)
    States.antiAFK = state
    if state then
        antiAFKConn = LocalPlayer.Idled:Connect(function()
            local vu = game:GetService("VirtualUser")
            vu:Button2Down(Vector2.zero, Camera.CFrame)
            task.wait(1)
            vu:Button2Up(Vector2.zero, Camera.CFrame)
        end)
    else
        if antiAFKConn then
            antiAFKConn:Disconnect()
            antiAFKConn = nil
        end
    end
    notify("Anti AFK", state and "You won't be kicked" or "Disabled", 2)
end, 3)

createButton(pages[6], "рҹҡҖ FPS Boost", function()
    local count = 0
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke")
        or v:IsA("Sparkles") or v:IsA("Trail") then
            v.Enabled = false
            count += 1
        elseif v:IsA("MeshPart") or v:IsA("Part") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
        end
    end

    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9

    for _, v in pairs(Lighting:GetDescendants()) do
        if v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or
           v:IsA("BloomEffect") or v:IsA("DepthOfFieldEffect") then
            v.Enabled = false
        end
    end

    notify("FPS Boost", "Applied! Disabled " .. count .. " effects", 3)
end, 4)

createSection(pages[6], "SERVER", 6)

createButton(pages[6], "рҹ”„ Rejoin Server", function()
    notify("Server", "Rejoining...", 2)
    task.wait(1)
    TeleportService:Teleport(game.PlaceId, LocalPlayer)
end, 8)

createButton(pages[6], "рҹҢҗ Server Hop", function()
    notify("Server", "Finding new server...", 2)
    task.wait(0.5)
    local servers = game:GetService("HttpService"):JSONDecode(
        game:HttpGetAsync(
            "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        )
    )
    if servers and servers.data then
        for _, server in pairs(servers.data) do
            if server.id ~= game.JobId and server.playing < server.maxPlayers then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                return
            end
        end
    end
    notify("Error", "No available servers found", 2)
end, 9)

createButton(pages[6], "рҹ“Ӣ Copy Server ID", function()
    if setclipboard then
        setclipboard(game.JobId)
        notify("Server", "Job ID copied to clipboard", 2)
    else
        notify("Error", "Clipboard not supported", 2)
    end
end, 10)

createSection(pages[6], "INFO", 12)

createLabel(pages[6], "  Game: " .. game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name, 13)
createLabel(pages[6], "  Server ID: " .. string.sub(game.JobId, 1, 20) .. "...", 14)
createLabel(pages[6], "  Players: " .. #Players:GetPlayers() .. "/" .. Players.MaxPlayers, 15)

