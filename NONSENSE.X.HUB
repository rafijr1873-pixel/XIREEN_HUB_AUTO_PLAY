createSection(pages[7], "RESET ALL", 7)

createButton(pages[7], "вҷ»пёҸ Reset All Features", function()
    -- Reset all states
    States.speed = false
    States.noclip = false
    States.fly = false
    States.infiniteJump = false
    States.esp = false
    States.fullbright = false
    States.noFog = false
    States.godMode = false
    States.clickTP = false
    States.autoClick = false
    States.antiAFK = false
    States.noFallDmg = false

    -- Cleanup fly
    if flyBV then flyBV:Destroy() flyBV = nil end
    if flyBG then flyBG:Destroy() flyBG = nil end

    -- Cleanup ESP
    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Character then
            local hl = plr.Character:FindFirstChild("NonsenseESP")
            if hl then hl:Destroy() end
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local bb = head:FindFirstChild("NonsenseESPTag")
                if bb then bb:Destroy() end
            end
        end
    end
    espElements = {}

    -- Reset humanoid
    local h = getHumanoid()
    if h then
        h.WalkSpeed = 16
        h.JumpPower = 50
        h.UseJumpPower = true
    end

    -- Reset lighting
    Lighting.Ambient = origLighting.Ambient or Color3.fromRGB(127, 127, 127)
    Lighting.Brightness = origLighting.Brightness or 1
    Lighting.OutdoorAmbient = origLighting.OutdoorAmbient or Color3.fromRGB(127, 127, 127)
    Lighting.FogEnd = origLighting.FogEnd or 1e5
    Lighting.FogStart = origLighting.FogStart or 0

    -- Reset camera
    Camera.FieldOfView = 70
    Workspace.Gravity = 196.2

    -- Anti AFK
    if antiAFKConn then antiAFKConn:Disconnect() antiAFKConn = nil end

    notify("Reset", "All features have been reset!", 3)
end, 9)

