-- ═══ REFRESH ═══
local function ref()
    pcall(function()tmL.Text=os.date("%H:%M")end)
    if _G._AD then togB.Text="⏸ Stop";togB.BackgroundColor3=C.red;sDot.BackgroundColor3=C.grn
    else togB.Text="▶ Play";togB.BackgroundColor3=C.grn;sDot.BackgroundColor3=C.tog end
    patB.Text=PATS[pIdx].n.." ▸"
    local bs=(pIdx==3 and mObj)and tostring(mObj.bpm)or(pIdx==3 and"--" or tostring(PATS[pIdx].b))
    npBpm.Text=bs.." BPM"
    if cSong~=""then npN.Text=cSong;npA.Text=bs.." BPM"
    elseif _G._AD then npN.Text=PATS[pIdx].n;npA.Text="Pattern"
    else npN.Text="Not Playing";npA.Text="Select a song"end
    local pc=math.clamp(mPr,0,1);pFl.Size=UDim2.new(pc,0,1,0);pFl.BackgroundColor3=pc>=1 and C.grn or C.acc
    pTm.Text=(pIdx==3 and mObj)and(mTm.." · "..math.floor(pc*100).."%")or"∞"
    sH.Text=tostring(tH);sN.Text=tostring(nps());sL.Text=tostring(lps);sB.Text=tostring(barN);sS.Text=secN
    if mObj and not mLd then mLb.Text="✅ "..mObj.cnt.."n · "..mObj.bpm.."BPM";mLb.TextColor3=C.grn
    elseif not mLd then mLb.Text="No MIDI";mLb.TextColor3=C.t3 end
end
task.spawn(function()while gui and gui.Parent do pcall(ref);task.wait(.25)end end)

-- ═══ ACTIONS ═══
local function tog()if _G._AD then stp()else go()end;ref()end
local function cyc()local w=_G._AD;if w then stp();task.wait(.15)end;local n=pIdx+1;if n>2 then n=1 end;if PATS[n].pm and not isPrem then n=1 end;pIdx=n;barN=0;introD=true;secN="IDLE";cSong="";lps=0;mPr=0;ref();if w then go();ref()end end

doLoad=function(u,nm)
    if mLd then return end;mLd=true;local w=_G._AD;if w then stp();task.wait(.15)end;ldB.Text="⏳"
    for i,q in ipairs(qBs)do for _,c in ipairs(q.row:GetChildren())do if c:IsA("UIStroke")then c:Destroy()end end end
    for i,q in ipairs(qBs)do if PS[i].n==nm then local s=Instance.new("UIStroke",q.row);s.Color=C.acc;s.Thickness=1.5 end end
    task.spawn(function()
        local d,e=loadMd(u,function(m)mLb.Text="⏳ "..m;mLb.TextColor3=C.acc end)
        mLd=false;ldB.Text="📥 Load"
        if d then mObj=d;cSong=nm or"Custom";pIdx=3;barN=0;secN="IDLE";lps=0;mPr=0
            for i,p in ipairs(PS)do if p.n==nm then aSg=i end end;ref();task.wait(.2)
            if not _G._AD then go();ref()end
            pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{Title="🥁 "..cSong,Text=d.cnt.." notes · "..d.bpm.." BPM",Duration=3})end)
        else mLb.Text="❌ "..tostring(e):sub(1,18);mLb.TextColor3=C.red end
    end)
end

