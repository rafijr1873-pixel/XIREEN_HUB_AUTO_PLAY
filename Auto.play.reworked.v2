-- ═══ ENGINE ═══
local function hm(f)return(f and RNG:NextInteger(5,15)or RNG:NextInteger(15,42))/1000*((RNG:NextInteger(0,1)==0)and 1 or-1)end
local function pr(k,f)if typeof(k)=="EnumItem"then k={k}end;for i=1,#k do VIM:SendKeyEvent(true,k[i],false,game)end;task.wait(f and RNG:NextInteger(20,40)/1000 or RNG:NextInteger(45,95)/1000);for i=1,#k do VIM:SendKeyEvent(false,k[i],false,game)end;tH=tH+1;local n=tick();rH[#rH+1]=n;while #rH>0 and n-rH[1]>3 do table.remove(rH,1)end end
local function nps()local n=tick();while #rH>0 and n-rH[1]>3 do table.remove(rH,1)end;return math.floor(#rH/3*10)/10 end
local function ok()return _G._AD end
local function br(p,s,b)barN=barN+1;local bs=(60/b/(s==16 and 4 or 2))/sM;local f=s==16;for i=1,#p do if not ok()then return false end;if p[i]then pr(p[i],f)end;local d=bs+hm(f)/sM;if d<.02 then d=.02 end;task.wait(d)end;return ok()end
local function sc(n,bs,s,b)secN=n;for i=1,#bs do if not br(bs[i],s,b)then return false end end;return ok()end

-- ═══ MIDI PARSER ═══
local M={}
function M.parse(r)if not r or #r<14 then return nil,"Small"end;local p,l=1,#r;local function rb()if p>l then error("E")end;local b=string.byte(r,p);p=p+1;return b end;local function rn(n)local v=0;for _=1,n do v=v*256+rb()end;return v end;local function rs(n)if p+n-1>l then error("E")end;local s=r:sub(p,p+n-1);p=p+n;return s end;local function rv()local v,c=0,0;repeat local b=rb();v=v*128+(b%128);c=c+1;if c>4 then error("V")end until b<128;return v end;local h=rs(4);if h~="MThd"then return nil,"Not MIDI"end;local hl=rn(4);rn(2);local nT=rn(2);local dv=rn(2);if hl>6 then p=p+(hl-6)end;if dv>=32768 then return nil,"SMPTE"end;local ppq,ns,ts=dv,{},{};for t=1,nT do if p+8>l then break end;local th=rs(4);if th~="MTrk"then return nil,"MTrk"end;local tl=rn(4);local te=p+tl;local at,rn2=0,0;while p<te and p<=l do local d=rv();at=at+d;if p>l then break end;local pk=string.byte(r,p);if not pk then break end;local st;if pk>=128 then st=rb();if st<0xF0 then rn2=st end else st=rn2;if st==0 then rb();break end end;local hi=math.floor(st/16);if hi==9 then local n2,v2=rb(),rb();if v2>0 and #ns<30000 then ns[#ns+1]={at,n2,v2,st%16}end elseif hi==8 or hi==10 or hi==11 or hi==14 then rb();rb()elseif hi==12 or hi==13 then rb()elseif st==0xFF then local mt=rb();local ml=rv();if mt==0x51 and ml>=3 then local us=0;for _=1,3 do us=us*256+rb()end;ts[#ts+1]={at,us};if ml>3 then p=p+(ml-3)end else p=p+ml end elseif st==0xF0 or st==0xF7 then p=p+rv()else p=te end end;p=te end;if #ns==0 then return nil,"No notes"end;table.sort(ns,function(a,b)return a[1]<b[1]end);table.sort(ts,function(a,b)return a[1]<b[1]end);return ns,ts,ppq end
function M.build(ns,ts,ppq)local h9=false;for _,n in ipairs(ns)do if n[4]==9 then h9=true;break end end;local dn={};for _,n in ipairs(ns)do if(h9 and n[4]==9)or not h9 then local k=GM[n[2]];if k then dn[#dn+1]={t=n[1],k=k}end end end;if #dn==0 then return nil,0,0,0 end;if #ts==0 or ts[1][1]~=0 then table.insert(ts,1,{0,500000})end;local tl={};local cs,pt,pm=0,0,500000;for _,tc in ipairs(ts)do cs=cs+(tc[1]-pt)*pm/ppq/1e6;tl[#tl+1]={t=tc[1],s=cs,m=tc[2]};pt=tc[1];pm=tc[2]end;local function t2s(tk)local s,p2,m2=0,0,500000;for _,t in ipairs(tl)do if t.t>tk then break end;s=t.s;p2=t.t;m2=t.m end;return s+(tk-p2)*m2/ppq/1e6 end;local gr,tks={},{};for _,d in ipairs(dn)do local t=d.t;if not gr[t]then gr[t]={};tks[#tks+1]=t end;local dp=false;for _,k in ipairs(gr[t])do if k==d.k then dp=true end end;if not dp then gr[t][#gr[t]+1]=d.k end end;table.sort(tks);local sq={};for _,t in ipairs(tks)do sq[#sq+1]={time=t2s(t),keys=gr[t]}end;return sq,sq[#sq]and sq[#sq].time or 0,math.floor(60e6/(ts[1][2]or 5e5)+.5),#dn end

local function fetch(u)local b;pcall(function()if syn and syn.request then b=syn.request({Url=u,Method="GET"}).Body elseif http_request then b=http_request({Url=u,Method="GET"}).Body elseif request then b=request({Url=u,Method="GET"}).Body elseif httpget then b=httpget(u)else b=game:HttpGet(u)end end);return b end
local function loadMd(u,cb)if not u then return nil,"No URL"end;cb("Fetching...");local r=fetch(u);if not r then return nil,"Fetch fail"end;cb("Parsing...");local ns,ts,ppq=M.parse(r);if not ns then return nil,ts end;cb("Building...");local sq,dur,bpm,cnt=M.build(ns,ts,ppq);if not sq then return nil,"Fail"end;return{sq=sq,dur=dur,bpm=bpm,cnt=cnt}end
local function fmt(s)s=math.max(0,math.floor(s));return string.format("%d:%02d",math.floor(s/60),s%60)end
local function avl()local a={};for i=1,#PS do if isPrem or isF(i)then a[#a+1]=i end end;return a end
local function pNx()local a=avl();if #a==0 then return nil end;if shuf then return a[RNG:NextInteger(1,#a)]end;if not aSg then return a[1]end;for i,x in ipairs(a)do if x==aSg then return a[(i%#a)+1]end end;return a[1]end
local function midiLp()if not mObj or #mObj.sq==0 then secN="NO MIDI";task.wait(1);return end;secN="♫ "..cSong;local sq=mObj.sq;local dur=mObj.dur/sM;local st=tick();for i=1,#sq do if not ok()then mPr=0;return end;local tg=st+sq[i].time/sM;if tg>tick()+.003 then task.wait(tg-tick())end;if not ok()then mPr=0;return end;pr(sq[i].keys,true);barN=math.floor(i/16);mPr=i/#sq;mTm=fmt(tick()-st).."/"..fmt(dur)end;lps=lps+1;mPr=1;if aNxt and ok()then secN="⏭";task.wait(.8);if ok()then local nx=pNx();if nx then _G._AD=false;task.wait(.15);aSg=nx;doLoad(PS[nx].u,PS[nx].n);return end end else secN="↻";task.wait(.5)end end

