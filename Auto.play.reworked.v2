-- ═══ DAILY KEY SYSTEM ═══
local CHARSET="ABCDEFGHJKLMNPQRSTUVWXYZ23456789"
local function genDailyKey(off)
    off=off or 0
    local t=os.time()+(off*86400)
    local d=tonumber(os.date("%d",t))
    local m=tonumber(os.date("%m",t))
    local y=tonumber(os.date("%Y",t))
    local seed=d*2731+m*1487+y*317+9973
    local function nxt()seed=(seed*16807+12345)%2147483647;return seed end
    local key=""
    for i=0,15 do
        if i>0 and i%4==0 then key=key.."-"end
        local idx=(nxt()%#CHARSET)+1
        key=key..CHARSET:sub(idx,idx)
    end
    return key
end
local function ckK(input)
    local k=input:upper():gsub("%s+","")
    if k==genDailyKey(0)then return true end
    if k==genDailyKey(-1)then return true end
    if k==genDailyKey(1)then return true end
    return false
end
local isPrem=_G._DP or false
local FS={1,8,9}
local function isF(i)for _,v in ipairs(FS)do if v==i then return true end end;return false end

local function copyToClip(txt)
    local ok2=false
    pcall(function()
        if setclipboard then setclipboard(txt);ok2=true
        elseif toclipboard then toclipboard(txt);ok2=true
        elseif Clipboard and Clipboard.set then Clipboard.set(txt);ok2=true end
    end)
    return ok2
end

