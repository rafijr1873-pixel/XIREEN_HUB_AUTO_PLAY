local function showK(done)
    local g=Instance.new("ScreenGui",pg);g.Name="DK";g.ResetOnSpawn=false
    local bg=Instance.new("Frame",g);bg.Size=UDim2.new(1,0,1,0);bg.BackgroundColor3=Color3.new(0,0,0);bg.BackgroundTransparency=.4;bg.BorderSizePixel=0
    local cd=Instance.new("Frame",bg);cd.Size=UDim2.new(0,290,0,305);cd.Position=UDim2.new(.5,-145,.5,-152);cd.BackgroundColor3=C.bg;cd.BorderSizePixel=0;cd.Active=true;cd.Draggable=true;cr(cd,4);Instance.new("UIStroke",cd).Color=C.div

    ln(cd,UDim2.new(1,0,0,18),UDim2.new(0,0,0,8),"🥁 Auto Drum [Reworked]",C.t1,13,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    ln(cd,UDim2.new(1,0,0,10),UDim2.new(0,0,0,28),"v8.5 · "..#PS.." songs · Daily Key",C.t3,7).TextXAlignment=Enum.TextXAlignment.Center

    local bdR=Instance.new("Frame",cd);bdR.Size=UDim2.new(1,0,0,14);bdR.Position=UDim2.new(0,0,0,42);bdR.BackgroundTransparency=1
    local bds={"v8.5",#PS.." songs","daily key"}
    local bCols={C.acc,C.grn,C.blu}
    for i,tx in ipairs(bds)do local bb=Instance.new("Frame",bdR);bb.Size=UDim2.new(0,#tx*5+12,0,14);bb.Position=UDim2.new(.5,-48+(i-1)*56,0,0);bb.BackgroundColor3=bCols[i];bb.BackgroundTransparency=.2;bb.BorderSizePixel=0;cr(bb,3);local bl=ln(bb,UDim2.new(1,0,1,0),UDim2.new(),tx,C.w,7,Enum.Font.GothamBold);bl.TextXAlignment=Enum.TextXAlignment.Center end

    dv(cd,UDim2.new(.85,0,0,1),UDim2.new(.075,0,0,62))

    local function cl2(t,x,y,c2)local l=ln(cd,UDim2.new(.44,0,0,10),UDim2.new(x,0,0,y),t,c2,7);l.TextXAlignment=Enum.TextXAlignment.Center end
    ln(cd,UDim2.new(.44,0,0,11),UDim2.new(.03,0,0,68),"🆓 Free",C.t2,9,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    ln(cd,UDim2.new(.44,0,0,11),UDim2.new(.53,0,0,68),"⭐ Premium",C.acc,9,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    cl2("✅ Rock + 3 Songs",.03,82,C.grn);cl2("❌ All "..#PS.." Songs",.03,94,C.red);cl2("❌ Shuffle/Next",.03,106,C.red)
    cl2("✅ Rock + "..#PS.." Songs",.53,82,C.grn);cl2("✅ All Features",.53,94,C.grn);cl2("✅ Shuffle/Next",.53,106,C.grn)

    dv(cd,UDim2.new(.85,0,0,1),UDim2.new(.075,0,0,122))

    ln(cd,UDim2.new(1,0,0,12),UDim2.new(0,0,0,128),"🔑 Enter Daily Key",C.t1,10,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center

    local kb=Instance.new("TextBox",cd);kb.Size=UDim2.new(.78,0,0,26);kb.Position=UDim2.new(.11,0,0,144);kb.BackgroundColor3=C.card;kb.BorderSizePixel=0;kb.Text="";kb.PlaceholderText="  XXXX-XXXX-XXXX-XXXX";kb.PlaceholderColor3=C.t4;kb.TextColor3=C.t1;kb.TextSize=11;kb.Font=Enum.Font.GothamBold;kb.ClearTextOnFocus=false;cr(kb,4);Instance.new("UIStroke",kb).Color=C.div;Instance.new("UIPadding",kb).PaddingLeft=UDim.new(0,6)

    -- ═══ GET KEY LINK + COPY ═══
    local lkBtn=bt(cd,UDim2.new(.86,0,0,22),UDim2.new(.07,0,0,178),C.blu,"🌐 Get Key → key-conturer.netlify.app",C.w,7)
    local cpBtn=bt(cd,UDim2.new(.86,0,0,20),UDim2.new(.07,0,0,204),C.card,"📋 Copy Link to Clipboard",C.t2,7)
    Instance.new("UIStroke",cpBtn).Color=C.div

    cpBtn.MouseButton1Click:Connect(function()
        if copyToClip(KEY_URL)then
            cpBtn.Text="✅ Link Copied!";cpBtn.TextColor3=C.grn
            cpBtn.BackgroundColor3=Color3.fromRGB(230,248,232)
        else
            cpBtn.Text="⚠ Copy manually from above";cpBtn.TextColor3=C.acc
        end
        task.wait(2)
        cpBtn.Text="📋 Copy Link to Clipboard";cpBtn.TextColor3=C.t2;cpBtn.BackgroundColor3=C.card
    end)

    lkBtn.MouseButton1Click:Connect(function()
        copyToClip(KEY_URL)
        lkBtn.Text="✅ Copied! Open in browser"
        task.wait(2)
        lkBtn.Text="🌐 Get Key → key-conturer.netlify.app"
    end)

    -- Unlock & Free
    local ub=bt(cd,UDim2.new(.36,0,0,26),UDim2.new(.07,0,0,234),C.dark,"🔓 Unlock",C.w,9)
    local fb=bt(cd,UDim2.new(.36,0,0,26),UDim2.new(.57,0,0,234),C.card,"▶ Free",C.t1,9);Instance.new("UIStroke",fb).Color=C.div
    local st=ln(cd,UDim2.new(.9,0,0,10),UDim2.new(.05,0,0,268),"",C.t3,8);st.TextXAlignment=Enum.TextXAlignment.Center
    ln(cd,UDim2.new(1,0,0,9),UDim2.new(0,0,0,282),"Free: Eyeless · Duality · Before I Forget",C.t4,6).TextXAlignment=Enum.TextXAlignment.Center
    ln(cd,UDim2.new(1,0,0,9),UDim2.new(0,0,0,294),"made by me n team",C.t4,7).TextXAlignment=Enum.TextXAlignment.Center

    ub.MouseButton1Click:Connect(function()
        if kb.Text==""then st.Text="⚠ Get key from website!";st.TextColor3=C.acc;return end
        st.Text="⏳ Validating...";st.TextColor3=C.t3;task.wait(.5)
        if ckK(kb.Text)then isPrem=true;_G._DP=true;_G._DV=true;st.Text="✅ Premium Unlocked!";st.TextColor3=C.grn;task.wait(.8);g:Destroy();done()
        else st.Text="❌ Invalid or expired!";st.TextColor3=C.red end
    end)
    fb.MouseButton1Click:Connect(function()isPrem=false;_G._DP=false;_G._DV=true;task.wait(.3);g:Destroy();done()end)
end

