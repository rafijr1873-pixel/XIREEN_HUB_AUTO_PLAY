local function eyeL()if introD then introD=false;if not sc("INTRO",{iA,iB,iC,iD},8,E)then return end end;if not sc("VERSE",{vA,vA,vB,vC,vA,vB,vD,vC},8,E)then return end;if not sc("PRE",{pA2,pB2,pF2},8,E)then return end;if not sc("CHORUS",{cA,cA,cB,cA,cFl},16,E)then return end;if not sc("VRS2",{vB,vD,vC,vB},8,E)then return end;if not sc("PRE2",{pB2,pA2,pF2},8,E)then return end;if not sc("CHR2",{cA,cC,cB,cC,cFl},16,E)then return end;if not sc("BREAK",{bA,bA,bB,bC2,bF},8,E)then return end;if not sc("BLAST",{xA,xB},16,E)then return end;if not sc("FILL",{fA},16,E)then return end;sc("LOOP",{tA2},8,E)end
local PATS={{n="Rock",b=120,f=rockL},{n="Eyeless",b=142,f=eyeL,pm=true},{n="MIDI",b=0,f=midiLp}}
local function go()if _G._AD then return end;_G._AD=true;barN=0;mPr=0;task.spawn(function()while _G._AD do pcall(PATS[pIdx].f)end end)end
local function stp()_G._AD=false;secN="IDLE";mPr=0;pcall(function()for _,v in pairs(K)do VIM:SendKeyEvent(false,v,false,game)end end)end
task.spawn(function()while true do if aAfk then pcall(function()VIM:SendKeyEvent(true,Enum.KeyCode.Space,false,game);task.wait(.05);VIM:SendKeyEvent(false,Enum.KeyCode.Space,false,game)end)end;task.wait(180)end end)
pcall(function()plr.Idled:Connect(function()if aAfk then VIM:SendKeyEvent(true,Enum.KeyCode.Return,false,game);task.wait(.1);VIM:SendKeyEvent(false,Enum.KeyCode.Return,false,game)end end)end)
local function doSit()local c=plr.Character;if not c then return"No char"end;local r=c:FindFirstChild("HumanoidRootPart");local h=c:FindFirstChildOfClass("Humanoid");if not r or not h then return"Err"end;if h.Sit then return"Already"end;local best,dist=nil,999;for _,o in ipairs(workspace:GetDescendants())do pcall(function()if(o:IsA("Seat")or o:IsA("VehicleSeat"))and not o.Occupant then local d=(o.Position-r.Position).Magnitude;if d<dist then best=o;dist=d end end end)end;if best and dist<100 then r.CFrame=best.CFrame+Vector3.new(0,3,0);task.wait(.5);pcall(function()best:Sit(h)end);return"Seated!"end;return"No seat"end

-- ═══ GUI UTILS ═══
local function cr(p,r)Instance.new("UICorner",p).CornerRadius=UDim.new(0,r or 4)end
local function ln(p,s,ps,t,cl,ts,fn)local l=Instance.new("TextLabel",p);l.Size=s or UDim2.new(1,0,0,12);l.Position=ps or UDim2.new();l.BackgroundTransparency=1;l.Text=t or"";l.TextColor3=cl or C.t1;l.TextSize=ts or 9;l.Font=fn or Enum.Font.Gotham;l.TextXAlignment=Enum.TextXAlignment.Left;l.TextTruncate=Enum.TextTruncate.AtEnd;return l end
local function bt(p,s,ps,bg,t,tc,ts)local b=Instance.new("TextButton",p);b.Size=s;b.Position=ps;b.BackgroundColor3=bg;b.Text=t;b.TextColor3=tc or C.w;b.TextSize=ts or 8;b.Font=Enum.Font.GothamBold;b.AutoButtonColor=true;b.BorderSizePixel=0;cr(b,4);return b end
local function dv(p,s,ps)local d=Instance.new("Frame",p);d.Size=s;d.Position=ps;d.BackgroundColor3=C.div;d.BorderSizePixel=0;return d end
local function mkBadge(par,txt,col,xOff)local bg=Instance.new("Frame",par);bg.Size=UDim2.new(0,#txt*5+8,0,12);bg.Position=UDim2.new(1,-#txt*5-14-xOff,0,2);bg.BackgroundColor3=col;bg.BackgroundTransparency=.15;bg.BorderSizePixel=0;bg.ZIndex=3;cr(bg,3);local l=ln(bg,UDim2.new(1,0,1,0),UDim2.new(),"",C.w,7,Enum.Font.GothamBold);l.Text=txt;l.TextXAlignment=Enum.TextXAlignment.Center;l.ZIndex=4 end

