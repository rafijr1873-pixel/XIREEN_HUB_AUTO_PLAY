local qBs={}
for i,ps in ipairs(PS)do local fr=isF(i);local lk=not isPrem and not fr;local row=Instance.new("Frame",t1f);row.Size=UDim2.new(1,-4,0,30);row.BackgroundColor3=C.card;row.BorderSizePixel=0;row.LayoutOrder=i;cr(row,4);if lk then row.BackgroundTransparency=.3 end;local st2=Instance.new("Frame",row);st2.Size=UDim2.new(0,3,.5,0);st2.Position=UDim2.new(0,0,.25,0);st2.BackgroundColor3=lk and C.tog or ps.c;st2.BorderSizePixel=0;cr(st2,1);ln(row,UDim2.new(0,170,0,12),UDim2.new(0,9,0,2),lk and"🔒 "..ps.n or ps.n,lk and C.t4 or C.t1,9,Enum.Font.GothamBold);ln(row,UDim2.new(0,150,0,9),UDim2.new(0,9,0,16),lk and"Premium" or ps.a,lk and C.t4 or C.t3,7);if ps.p and not lk then mkBadge(row,ps.p=="🔥" and"🔥 Popular" or"⭐ Special",ps.p=="🔥" and C.pop or C.spc,40)end;local pb=bt(row,UDim2.new(0,36,0,20),UDim2.new(1,-42,0,5),lk and C.tog or C.grn,lk and"🔒" or"▶",C.w,9);pb.MouseButton1Click:Connect(function()if lk then return end;aSg=i;doLoad(PS[i].u,PS[i].n)end);qBs[i]={row=row}end
local cSp=Instance.new("Frame",t1f);cSp.Size=UDim2.new(1,-8,0,1);cSp.BackgroundColor3=C.div;cSp.BorderSizePixel=0;cSp.LayoutOrder=50
local cWr=Instance.new("Frame",t1f);cWr.Size=UDim2.new(1,-4,0,58);cWr.BackgroundTransparency=1;cWr.LayoutOrder=51
ln(cWr,UDim2.new(1,0,0,10),UDim2.new(),"🔗 Custom MIDI",C.t2,8,Enum.Font.GothamBold)
local uBox=Instance.new("TextBox",cWr);uBox.Size=UDim2.new(1,0,0,20);uBox.Position=UDim2.new(0,0,0,12);uBox.BackgroundColor3=C.card;uBox.BorderSizePixel=0;uBox.Text="";uBox.PlaceholderText="  .mid URL...";uBox.PlaceholderColor3=C.t4;uBox.TextColor3=C.t1;uBox.TextSize=7;uBox.Font=Enum.Font.Gotham;uBox.ClearTextOnFocus=false;uBox.TextXAlignment=Enum.TextXAlignment.Left;uBox.TextTruncate=Enum.TextTruncate.AtEnd;cr(uBox,3);Instance.new("UIStroke",uBox).Color=C.div;Instance.new("UIPadding",uBox).PaddingLeft=UDim.new(0,5)
local ldB=bt(cWr,UDim2.new(0,50,0,16),UDim2.new(0,0,0,36),C.dark,"📥 Load",C.w,7)
local mLb=ln(cWr,UDim2.new(0,220,0,16),UDim2.new(0,54,0,36),"No MIDI",C.t3,7)
local function aFl(nm)for i,fb in ipairs(fBs)do fb.BackgroundColor3=FN[i]==nm and C.dark or C.card;fb.TextColor3=FN[i]==nm and C.w or C.t3 end;local tg=TM[nm];for i,q in ipairs(qBs)do if tg=="All"then q.row.Visible=true elseif tg=="*"then q.row.Visible=(PS[i].t~="SK"and PS[i].t~="MG"and PS[i].t~="A7X")else q.row.Visible=(PS[i].t==tg)end end end
for i,fb in ipairs(fBs)do fb.MouseButton1Click:Connect(function()aFl(FN[i])end)end

