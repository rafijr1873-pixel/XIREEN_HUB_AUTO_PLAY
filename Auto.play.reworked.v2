    local bx=Instance.new("Frame",ov);bx.Size=UDim2.new(0,210,0,105);bx.Position=UDim2.new(.5,-105,.5,-52);bx.BackgroundColor3=C.bg;bx.BorderSizePixel=0;bx.ZIndex=51;cr(bx,4);Instance.new("UIStroke",bx).Color=C.div
    local tl=ln(bx,UDim2.new(1,0,0,14),UDim2.new(0,0,0,10),"⚠️ Close Auto Drum?",C.t1,10,Enum.Font.GothamBold);tl.TextXAlignment=Enum.TextXAlignment.Center;tl.ZIndex=52
    local m1=ln(bx,UDim2.new(.85,0,0,10),UDim2.new(.075,0,0,28),"Stop playback and remove",C.t2,8);m1.TextXAlignment=Enum.TextXAlignment.Center;m1.ZIndex=52
    local m2=ln(bx,UDim2.new(.85,0,0,10),UDim2.new(.075,0,0,40),"the script entirely?",C.t2,8);m2.TextXAlignment=Enum.TextXAlignment.Center;m2.ZIndex=52
    local yB=bt(bx,UDim2.new(0,74,0,26),UDim2.new(0,18,0,62),C.red,"Yes, close",C.w,9);yB.ZIndex=52
    local nB=bt(bx,UDim2.new(0,74,0,26),UDim2.new(0,118,0,62),C.card,"Cancel",C.t1,9);nB.ZIndex=52;Instance.new("UIStroke",nB).Color=C.div
    yB.MouseButton1Click:Connect(function()ov:Destroy();stp();task.wait(.1);gui:Destroy();if kC then kC:Disconnect()end;_G._AD=nil end)
    nB.MouseButton1Click:Connect(function()ov:Destroy()end)
end

