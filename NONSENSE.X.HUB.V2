-- Corner accents
local function crnr(p, px, py, sx, sy, col)
    local f = Instance.new("Frame", p)
    f.BackgroundColor3 = col; f.BackgroundTransparency = 0.2
    f.BorderSizePixel = 0; f.Size = UDim2.new(0, sx, 0, sy)
    f.Position = UDim2.new(px, 0, py, 0); f.ZIndex = 16
    return f
end
crnr(splashCard, 0, 0, 45, 2, Color3.fromRGB(100, 190, 255))
crnr(splashCard, 0, 0, 2, 45, Color3.fromRGB(100, 190, 255))
crnr(splashCard, 0, 0, 45, 2, Color3.fromRGB(90, 150, 230)).Position = UDim2.new(1, -45, 1, -2)
crnr(splashCard, 0, 0, 2, 45, Color3.fromRGB(90, 150, 230)).Position = UDim2.new(1, -2, 1, -45)

-- Logo
local logoCont = Instance.new("Frame", splashCard)
logoCont.BackgroundTransparency = 1
logoCont.Size = UDim2.new(0, 88, 0, 88)
logoCont.Position = UDim2.new(0.5, -44, 0, 18)
logoCont.ZIndex = 14

local outerRing = Instance.new("Frame", logoCont)
outerRing.BackgroundColor3 = Color3.fromRGB(60, 140, 220)
outerRing.BackgroundTransparency = 0.65
outerRing.Size = UDim2.new(1, 0, 1, 0); outerRing.ZIndex = 14
Instance.new("UICorner", outerRing).CornerRadius = UDim.new(1, 0)
local oRS = Instance.new("UIStroke", outerRing)
