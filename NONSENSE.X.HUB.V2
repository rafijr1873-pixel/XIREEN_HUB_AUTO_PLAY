-- ‚ēź‚ēź‚ēź Notify System ‚ēź‚ēź‚ēź
local notifY = 0
local function notify(title, text, dur)
    dur = dur or 3
    local n = Instance.new("Frame", screenGui)
    n.BackgroundColor3 = Color3.fromRGB(12,22,45); n.BorderSizePixel = 0
    n.Size = UDim2.new(0,250,0,58); n.Position = UDim2.new(1,10,1,-68-notifY)
    n.ZIndex = 50; n.ClipsDescendants = true
    Instance.new("UICorner", n).CornerRadius = UDim.new(0,10)
    local ns = Instance.new("UIStroke", n); ns.Color = Color3.fromRGB(90,170,255); ns.Transparency = 0.4
    local nA = Instance.new("Frame", n); nA.BackgroundColor3 = Color3.fromRGB(90,180,255)
    nA.BorderSizePixel = 0; nA.Size = UDim2.new(0,3,1,0); nA.ZIndex = 51
    local nT = Instance.new("TextLabel", n); nT.BackgroundTransparency = 1; nT.Position = UDim2.new(0,12,0,5)
    nT.Size = UDim2.new(1,-16,0,16); nT.Font = Enum.Font.GothamBold; nT.Text = title
    nT.TextColor3 = Color3.fromRGB(120,195,255); nT.TextSize = 12; nT.TextXAlignment = Enum.TextXAlignment.Left; nT.ZIndex = 51
    local nD = Instance.new("TextLabel", n); nD.BackgroundTransparency = 1; nD.Position = UDim2.new(0,12,0,22)
    nD.Size = UDim2.new(1,-16,0,30); nD.Font = Enum.Font.Gotham; nD.Text = text
    nD.TextColor3 = Color3.fromRGB(190,210,240); nD.TextSize = 11
    nD.TextXAlignment = Enum.TextXAlignment.Left; nD.TextWrapped = true; nD.ZIndex = 51
    local yOff = notifY; notifY += 64
    TweenService:Create(n, tweenSmooth, {Position = UDim2.new(1,-260,1,-68-yOff)}):Play()
    task.delay(dur, function()
        TweenService:Create(n, tweenSmooth, {Position = UDim2.new(1,10,1,-68-yOff)}):Play()
        task.delay(0.5, function() n:Destroy(); notifY = math.max(0, notifY-64) end)
    end)
end

-- ‚ēź‚ēź‚ēź UI Builders ‚ēź‚ēź‚ēź
local function createPage(nm)
    local pg = Instance.new("ScrollingFrame", contentArea)
    pg.Name = "P_"..nm; pg.BackgroundTransparency = 1; pg.BorderSizePixel = 0
    pg.Position = UDim2.new(0,0,0,40); pg.Size = UDim2.new(1,0,1,-40)
    pg.ScrollBarThickness = 3; pg.ScrollBarImageColor3 = Color3.fromRGB(90,170,255)
    pg.ScrollBarImageTransparency = 0.3; pg.CanvasSize = UDim2.new(0,0,0,0)
    pg.AutomaticCanvasSize = Enum.AutomaticSize.Y; pg.Visible = false; pg.ZIndex = 6
    local l = Instance.new("UIListLayout", pg); l.Padding = UDim.new(0,5); l.SortOrder = Enum.SortOrder.LayoutOrder
    local pd = Instance.new("UIPadding", pg); pd.PaddingTop = UDim.new(0,4); pd.PaddingBottom = UDim.new(0,8)
    pd.PaddingLeft = UDim.new(0,10); pd.PaddingRight = UDim.new(0,12)
    return pg
end

local function createSection(p, t, o)
    local l = Instance.new("TextLabel", p); l.BackgroundTransparency = 1; l.Size = UDim2.new(1,0,0,20)
    l.Font = Enum.Font.GothamBold; l.Text = "  "..t; l.TextColor3 = Color3.fromRGB(110,195,255)
    l.TextSize = 12; l.TextXAlignment = Enum.TextXAlignment.Left; l.LayoutOrder = o; l.ZIndex = 7
    local s = Instance.new("Frame", p); s.BackgroundColor3 = Color3.fromRGB(50,80,130); s.BackgroundTransparency = 0.4
    s.BorderSizePixel = 0; s.Size = UDim2.new(1,0,0,1); s.LayoutOrder = o+1; s.ZIndex = 7
end

local function createToggle(p, text, def, cb, ord)
    local tog = def or false
    local btn = Instance.new("TextButton", p)
    btn.BackgroundColor3 = Color3.fromRGB(15,28,55); btn.BackgroundTransparency = 0.2
    btn.BorderSizePixel = 0; btn.Size = UDim2.new(1,0,0,34); btn.Text = ""
    btn.AutoButtonColor = false; btn.LayoutOrder = ord; btn.ZIndex = 7
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    local st = Instance.new("UIStroke", btn); st.Color = Color3.fromRGB(45,70,110); st.Transparency = 0.3
    local lb = Instance.new("TextLabel", btn); lb.BackgroundTransparency = 1; lb.Position = UDim2.new(0,12,0,0)
    lb.Size = UDim2.new(0.65,0,1,0); lb.Font = Enum.Font.GothamMedium; lb.Text = text
    lb.TextColor3 = Color3.fromRGB(200,220,245); lb.TextSize = 12; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.ZIndex = 8
    local ind = Instance.new("Frame", btn); ind.BackgroundColor3 = tog and Color3.fromRGB(50,190,120) or Color3.fromRGB(40,55,90)
    ind.BorderSizePixel = 0; ind.Size = UDim2.new(0,34,0,17); ind.Position = UDim2.new(1,-46,0.5,-8); ind.ZIndex = 8
    Instance.new("UICorner", ind).CornerRadius = UDim.new(1,0)
    local cir = Instance.new("Frame", ind); cir.BackgroundColor3 = Color3.new(1,1,1); cir.BorderSizePixel = 0
    cir.Size = UDim2.new(0,13,0,13); cir.Position = tog and UDim2.new(1,-15,0.5,-6) or UDim2.new(0,2,0.5,-6); cir.ZIndex = 9
    Instance.new("UICorner", cir).CornerRadius = UDim.new(1,0)
    local function ref()
        if tog then
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(50,190,120)}):Play()
            TweenService:Create(cir, tweenFast, {Position = UDim2.new(1,-15,0.5,-6)}):Play()
            TweenService:Create(st, tweenFast, {Color = Color3.fromRGB(50,190,120)}):Play()
        else
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(40,55,90)}):Play()
            TweenService:Create(cir, tweenFast, {Position = UDim2.new(0,2,0.5,-6)}):Play()
            TweenService:Create(st, tweenFast, {Color = Color3.fromRGB(45,70,110)}):Play()
        end
    end
    btn.MouseButton1Click:Connect(function() tog = not tog; ref(); cb(tog) end)
    btn.MouseEnter:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.05}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.2}):Play() end)
    if tog then ref(); cb(true) end; return btn
end

local function createSlider(p, text, mn, mx, def, cb, ord)
    local val = def or mn
    local c = Instance.new("Frame", p); c.BackgroundColor3 = Color3.fromRGB(15,28,55); c.BackgroundTransparency = 0.2
    c.BorderSizePixel = 0; c.Size = UDim2.new(1,0,0,50); c.LayoutOrder = ord; c.ZIndex = 7
    Instance.new("UICorner", c).CornerRadius = UDim.new(0,8); Instance.new("UIStroke", c).Color = Color3.fromRGB(45,70,110)
    local lb = Instance.new("TextLabel", c); lb.BackgroundTransparency = 1; lb.Position = UDim2.new(0,12,0,2)
    lb.Size = UDim2.new(0.55,0,0,20); lb.Font = Enum.Font.GothamMedium; lb.Text = text
    lb.TextColor3 = Color3.fromRGB(200,220,245); lb.TextSize = 12; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.ZIndex = 8
    local vL = Instance.new("TextLabel", c); vL.BackgroundTransparency = 1; vL.Position = UDim2.new(0.6,0,0,2)
    vL.Size = UDim2.new(0.35,0,0,20); vL.Font = Enum.Font.GothamBold; vL.Text = tostring(val)
    vL.TextColor3 = Color3.fromRGB(110,195,255); vL.TextSize = 12; vL.TextXAlignment = Enum.TextXAlignment.Right; vL.ZIndex = 8
    local bg = Instance.new("Frame", c); bg.BackgroundColor3 = Color3.fromRGB(10,18,35); bg.BorderSizePixel = 0
    bg.Position = UDim2.new(0,12,0,28); bg.Size = UDim2.new(1,-24,0,6); bg.ZIndex = 8
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1,0)
    local fl = Instance.new("Frame", bg); fl.BackgroundColor3 = Color3.fromRGB(80,170,255); fl.BorderSizePixel = 0
    fl.Size = UDim2.new((val-mn)/(mx-mn),0,1,0); fl.ZIndex = 9; Instance.new("UICorner", fl).CornerRadius = UDim.new(1,0)
    local kn = Instance.new("Frame", bg); kn.BackgroundColor3 = Color3.new(1,1,1); kn.BorderSizePixel = 0
    kn.Size = UDim2.new(0,14,0,14); kn.Position = UDim2.new((val-mn)/(mx-mn),-7,0.5,-7); kn.ZIndex = 10
    Instance.new("UICorner", kn).CornerRadius = UDim.new(1,0)
    local dr = false
    local function upd(pos) local r = math.clamp((pos.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
        val = math.floor(mn+(mx-mn)*r); vL.Text = tostring(val); fl.Size = UDim2.new(r,0,1,0); kn.Position = UDim2.new(r,-7,0.5,-7); cb(val) end
    bg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dr = true; upd(i.Position) end end)
    kn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dr = true end end)
    UserInputService.InputChanged:Connect(function(i) if dr and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then upd(i.Position) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dr = false end end)
    return c
end

local function createButton(p, text, cb, ord)
    local b = Instance.new("TextButton", p); b.BackgroundColor3 = Color3.fromRGB(40,95,210); b.BackgroundTransparency = 0.15
    b.BorderSizePixel = 0; b.Size = UDim2.new(1,0,0,32); b.Font = Enum.Font.GothamMedium; b.Text = text
    b.TextColor3 = Color3.fromRGB(225,240,255); b.TextSize = 12; b.AutoButtonColor = false; b.LayoutOrder = ord; b.ZIndex = 7
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,8)
    b.MouseButton1Click:Connect(cb)
    b.MouseEnter:Connect(function() TweenService:Create(b, tweenFast, {BackgroundTransparency = 0}):Play() end)
    b.MouseLeave:Connect(function() TweenService:Create(b, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
    return b
end

local function createLabel(p, text, ord)
    local l = Instance.new("TextLabel", p); l.BackgroundTransparency = 1; l.Size = UDim2.new(1,0,0,18)
    l.Font = Enum.Font.Gotham; l.Text = text; l.TextColor3 = Color3.fromRGB(140,170,210)
    l.TextSize = 11; l.TextWrapped = true; l.TextXAlignment = Enum.TextXAlignment.Left; l.LayoutOrder = ord; l.ZIndex = 7
    return l
end

-- ‚ēź‚ēź‚ēź TABS ‚ēź‚ēź‚ēź
local tabNames = {"ūüŹ† Main", "‚öĒÔłŹ Combat", "ūüĎĀÔłŹ Visuals", "ūüĆć Teleport", "ūüéģ Player", "ūüĒß Misc", "‚öôÔłŹ Settings"}
local tabBtns, pages = {}, {}

for i, nm in ipairs(tabNames) do
    local tab = Instance.new("TextButton", sidebar)
    tab.Name = "Tab_"..i
    tab.BackgroundColor3 = (i==1) and Color3.fromRGB(50,115,235) or Color3.fromRGB(18,30,55)
    tab.BackgroundTransparency = (i==1) and 0.1 or 0.3
    tab.BorderSizePixel = 0; tab.Size = UDim2.new(1,0,0,32)
    tab.Font = (i==1) and Enum.Font.GothamSemibold or Enum.Font.Gotham
    tab.Text = nm; tab.TextColor3 = (i==1) and Color3.fromRGB(230,245,255) or Color3.fromRGB(140,160,195)
    tab.TextSize = 11; tab.AutoButtonColor = false; tab.LayoutOrder = i; tab.ZIndex = 6
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 8)
    tabBtns[i] = tab
end

for i in ipairs(tabNames) do
    pages[i] = createPage(tabNames[i])
    if i == 1 then pages[i].Visible = true end
end

