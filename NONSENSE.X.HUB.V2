-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- TAB SWITCHING
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local function switchTab(idx)
    for i, page in ipairs(pages) do page.Visible = (i == idx) end
    for i, btn in ipairs(tabBtns) do
        if i == idx then
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(55, 110, 255), BackgroundTransparency = 0.15}):Play()
            btn.Font = Enum.Font.GothamSemibold; btn.TextColor3 = Color3.fromRGB(225, 240, 255)
        else
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(35, 35, 50), BackgroundTransparency = 0.45}):Play()
            btn.Font = Enum.Font.Gotham; btn.TextColor3 = Color3.fromRGB(135, 135, 160)
        end
    end
    pageTitle.Text = tabNames[idx]; activeTab = idx
end

for i, btn in ipairs(tabBtns) do
    btn.MouseButton1Click:Connect(function() switchTab(i) end)
    btn.MouseEnter:Connect(function()
        if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.25}):Play() end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.45}):Play() end
    end)
end

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- RUNTIME LOOPS (All Features)
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

-- Speed + God Mode
RunService.Heartbeat:Connect(function()
    if States.speed then local h = getHumanoid(); if h then h.WalkSpeed = States.walkSpeed end end
    if States.godMode then local h = getHumanoid(); if h then h.Health = h.MaxHealth end end
end)

-- Noclip + No Fall
RunService.Stepped:Connect(function()
    if States.noclip then
        local c = LocalPlayer.Character
        if c then for _, p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
    end
    if States.noFallDmg then
        local h = getHumanoid()
        if h then
            h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
    end
end)

-- Fly + ESP + FOV
RunService.RenderStepped:Connect(function()
    if States.fly and flyBV and flyBG then
        flyBG.CFrame = Camera.CFrame
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.new(0, 1, 0) end
        flyBV.Velocity = dir.Magnitude > 0 and dir.Unit * States.flySpeed or Vector3.zero
    end

    if States.esp then
        local myHRP = getHRP()
        if myHRP then
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local head = plr.Character:FindFirstChild("Head")
                    if head then
                        local bb = head:FindFirstChild("NonsenseESPTag")
                        if bb then
                            local dist = bb:FindFirstChild("Dist")
                            if dist then
                                local d = math.floor((myHRP.Position - head.Position).Magnitude)
                                dist.Text = d .. "m"
                                dist.TextColor3 = d < 30 and Color3.fromRGB(255, 80, 80)
                                    or d < 80 and Color3.fromRGB(255, 200, 80)
                                    or Color3.fromRGB(80, 255, 80)
                            end
                        end
                    end
                end
            end
        end
    end

    Camera.FieldOfView = States.fov
end)

-- Infinite Jump
UserInputService.JumpRequest:Connect(function()
    if States.infiniteJump then
        local h = getHumanoid()
        if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

-- Click TP
Mouse.Button1Down:Connect(function()
    if States.clickTP and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        local hrp = getHRP()
        if hrp then hrp.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0, 3, 0)) end
    end
end)

-- Auto Click
task.spawn(function()
    while screenGui.Parent do
        if States.autoClick then
            local c = LocalPlayer.Character
            if c then local t = c:FindFirstChildOfClass("Tool"); if t then t:Activate() end end
        end
        task.wait(States.clickDelay / 1000)
    end
end)

-- ESP on new players
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(1)
        if States.esp then
            local hl = Instance.new("Highlight")
            hl.Name = "NonsenseESP"
            hl.FillColor = Color3.fromRGB(255, 50, 50)
            hl.FillTransparency = 0.5
            hl.OutlineColor = Color3.fromRGB(255, 255, 255)
            hl.Parent = plr.Character

            local head = plr.Character:FindFirstChild("Head")
            if head then
                local bb = Instance.new("BillboardGui")
                bb.Name = "NonsenseESPTag"
                bb.Adornee = head
                bb.Size = UDim2.new(0, 200, 0, 40)
                bb.StudsOffset = Vector3.new(0, 2.5, 0)
                bb.AlwaysOnTop = true
                bb.Parent = head

                local nt = Instance.new("TextLabel", bb)
                nt.BackgroundTransparency = 1
                nt.Size = UDim2.new(1, 0, 0.5, 0)
                nt.Font = Enum.Font.GothamBold
                nt.Text = plr.DisplayName
                nt.TextColor3 = Color3.fromRGB(255, 255, 255)
                nt.TextStrokeTransparency = 0
                nt.TextSize = 14

                local dt = Instance.new("TextLabel", bb)
                dt.Name = "Dist"
                dt.BackgroundTransparency = 1
                dt.Position = UDim2.new(0, 0, 0.5, 0)
                dt.Size = UDim2.new(1, 0, 0.5, 0)
                dt.Font = Enum.Font.Gotham
                dt.Text = "0m"
                dt.TextColor3 = Color3.fromRGB(200, 200, 200)
                dt.TextStrokeTransparency = 0.3
                dt.TextSize = 12
            end
            espElements[plr] = true
        end
    end)
end)

Players.PlayerRemoving:Connect(function(plr) espElements[plr] = nil end)

-- Respawn handler
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1)
    if States.fly then
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if hrp then
            if flyBV then flyBV:Destroy() end
            if flyBG then flyBG:Destroy() end
            flyBV = Instance.new("BodyVelocity", hrp)
            flyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            flyBV.Velocity = Vector3.zero
            flyBG = Instance.new("BodyGyro", hrp)
            flyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            flyBG.D = 200; flyBG.P = 10000
        end
    end
    if States.noFallDmg then
        local h = char:WaitForChild("Humanoid", 5)
        if h then
            h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
    end
end)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- DRAGGING
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local dragging, dragInput, dragStart, startPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        TweenService:Create(mainFrame, TweenInfo.new(0.06), {
            Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        }):Play()
    end
end)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- TOGGLE BUTTON
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.BackgroundColor3 = Color3.fromRGB(55, 110, 255)
toggleBtn.BorderSizePixel = 0
toggleBtn.Size = UDim2.new(0, 46, 0, 46)
toggleBtn.Position = UDim2.new(0, 10, 0.5, -23)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.Text = "рҹҢҖ"
toggleBtn.TextSize = 22
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.ZIndex = 20
toggleBtn.AutoButtonColor = false
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
local tgStroke = Instance.new("UIStroke", toggleBtn)
tgStroke.Color = Color3.fromRGB(100, 160, 255)
tgStroke.Thickness = 2
tgStroke.Transparency = 0.3

local isOpen = true

local function toggleGUI()
    isOpen = not isOpen
    if isOpen then
        mainFrame.Visible = true; mainScale.Scale = 0.85
        TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play()
        TweenService:Create(toggleBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(55, 110, 255), Rotation = 0}):Play()
    else
        TweenService:Create(mainScale, tweenFast, {Scale = 0.85}):Play()
        TweenService:Create(toggleBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(255, 70, 70), Rotation = 180}):Play()
        task.delay(0.25, function() if not isOpen then mainFrame.Visible = false end end)
    end
end

toggleBtn.MouseButton1Click:Connect(toggleGUI)

toggleBtn.MouseEnter:Connect(function()
    TweenService:Create(toggleBtn, tweenFast, {Size = UDim2.new(0, 52, 0, 52), Position = UDim2.new(0, 7, 0.5, -26)}):Play()
end)
toggleBtn.MouseLeave:Connect(function()
    TweenService:Create(toggleBtn, tweenFast, {Size = UDim2.new(0, 46, 0, 46), Position = UDim2.new(0, 10, 0.5, -23)}):Play()
end)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- CLOSE & MINIMIZE
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
closeBtn.MouseButton1Click:Connect(function()
    TweenService:Create(mainScale, tweenFast, {Scale = 0}):Play()
    task.delay(0.3, function() screenGui:Destroy() end)
end)
closeBtn.MouseEnter:Connect(function()
    TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.2, BackgroundColor3 = Color3.fromRGB(255, 40, 40)}):Play()
end)
closeBtn.MouseLeave:Connect(function()
    TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.85, BackgroundColor3 = Color3.fromRGB(255, 55, 55)}):Play()
end)

local isMinimized = false
local savedSize

minBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    if isMinimized then
        savedSize = mainFrame.Size
        TweenService:Create(mainFrame, tweenSmooth, {Size = UDim2.new(0, 580, 0, 40)}):Play()
        minBtn.Text = "в–Ў"
    else
        TweenService:Create(mainFrame, tweenBounce, {Size = savedSize or UDim2.new(0, 580, 0, 380)}):Play()
        minBtn.Text = "в”Җ"
    end
end)
minBtn.MouseEnter:Connect(function()
    TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.2, BackgroundColor3 = Color3.fromRGB(255, 210, 40)}):Play()
end)
minBtn.MouseLeave:Connect(function()
    TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.85, BackgroundColor3 = Color3.fromRGB(255, 200, 50)}):Play()
end)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- KEYBIND (RightShift)
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then toggleGUI() end
end)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- MAIN GUI ENTRANCE ANIMATION
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
mainScale.Scale = 0
mainFrame.Visible = true

task.delay(0.15, function()
    TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play()
end)

-- Welcome notification
task.delay(1, function()
    notify("рҹҢҖ Nonsense Hub", "Loaded! RightShift to toggle. 7 tabs ready.", 4)
end)

print("рҹҢҖ Nonsense Hub v2.0 - Fully Loaded!")
print("   7 Tabs | 20+ Features | All Working")

return screenGui
