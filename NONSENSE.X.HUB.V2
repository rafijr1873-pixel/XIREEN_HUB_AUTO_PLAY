-- ═══════════════════════════════════════
-- Side Preview Cards
-- ═══════════════════════════════════════
local function makePreview(px, py, icon, title, desc, col)
    local card = Instance.new("Frame", splashGui)
    card.BackgroundColor3 = Color3.fromRGB(10, 18, 35)
    card.BackgroundTransparency = 0.25
    card.BorderSizePixel = 0
    card.Position = UDim2.new(px, 0, py, 0)
    card.Size = UDim2.new(0, 150, 0, 68)
    card.ZIndex = 8
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    local cs = Instance.new("UIStroke", card)
    cs.Color = col; cs.Thickness = 1; cs.Transparency = 0.55

    local acc = Instance.new("Frame", card)
    acc.BackgroundColor3 = col
    acc.BorderSizePixel = 0
    acc.Size = UDim2.new(0, 3, 0.6, 0)
    acc.Position = UDim2.new(0, 0, 0.2, 0)
    acc.ZIndex = 9

    local ic = Instance.new("TextLabel", card)
    ic.BackgroundTransparency = 1
    ic.Position = UDim2.new(0, 12, 0, 8)
    ic.Size = UDim2.new(0, 28, 0, 22)
    ic.Font = Enum.Font.SourceSansBold
    ic.Text = icon; ic.TextSize = 18; ic.ZIndex = 9

    local ti = Instance.new("TextLabel", card)
    ti.BackgroundTransparency = 1
    ti.Position = UDim2.new(0, 40, 0, 10)
    ti.Size = UDim2.new(1, -50, 0, 16)
    ti.Font = Enum.Font.GothamBold
    ti.Text = title
    ti.TextColor3 = Color3.fromRGB(220, 235, 255)
    ti.TextSize = 11
    ti.TextXAlignment = Enum.TextXAlignment.Left
    ti.ZIndex = 9

    local de = Instance.new("TextLabel", card)
    de.BackgroundTransparency = 1
    de.Position = UDim2.new(0, 12, 0, 34)
    de.Size = UDim2.new(1, -20, 0, 26)
    de.Font = Enum.Font.Gotham
    de.Text = desc
    de.TextColor3 = Color3.fromRGB(120, 150, 190)
    de.TextSize = 9
    de.TextWrapped = true
    de.TextXAlignment = Enum.TextXAlignment.Left
    de.ZIndex = 9

    task.spawn(function()
        while card.Parent do
            TweenService:Create(cs, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.3}):Play()
            task.wait(2)
            TweenService:Create(cs, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.7}):Play()
            task.wait(2)
        end
    end)
    return card
end

local sideCards = {
    makePreview(0.03, 0.18, "⚡", "Speed", "Custom walkspeed control", Color3.fromRGB(255, 190, 60)),
    makePreview(0.05, 0.42, "🕊️", "FlyGuiV3", "Advanced flight system", Color3.fromRGB(100, 200, 255)),
