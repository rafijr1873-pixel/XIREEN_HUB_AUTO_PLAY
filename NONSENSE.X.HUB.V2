--[=[
 РќѕРќѕРќѕРЋЌ   РќѕРќѕРЋЌ РќѕРќѕРќѕРќѕРќѕРќѕРЋЌ РќѕРќѕРќѕРЋЌ   РќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРЋЌ   РќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌ
 РќѕРќѕРќѕРќѕРЋЌ  РќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРЋљРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРЋЌ  РќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮРќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮРќѕРќѕРќѕРќѕРЋЌ  РќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮРќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮ
 РќѕРќѕРЋћРќѕРќѕРЋЌ РќѕРќѕРЋЉРќѕРќѕРЋЉ   РќѕРќѕРЋЉРќѕРќѕРЋћРќѕРќѕРЋЌ РќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРЋЌ  РќѕРќѕРЋћРќѕРќѕРЋЌ РќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРЋЌ  
 РќѕРќѕРЋЉРЋџРќѕРќѕРЋЌРќѕРќѕРЋЉРќѕРќѕРЋЉ   РќѕРќѕРЋЉРќѕРќѕРЋЉРЋџРќѕРќѕРЋЌРќѕРќѕРЋЉРЋџРЋљРЋљРЋљРЋљРќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРЋЮ  РќѕРќѕРЋЉРЋџРќѕРќѕРЋЌРќѕРќѕРЋЉРЋџРЋљРЋљРЋљРЋљРќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРЋЮ  
 РќѕРќѕРЋЉ РЋџРќѕРќѕРќѕРќѕРЋЉРЋџРќѕРќѕРќѕРќѕРќѕРќѕРЋћРЋЮРќѕРќѕРЋЉ РЋџРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРЋЉ РЋџРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌ
 РЋџРЋљРЋЮ  РЋџРЋљРЋљРЋљРЋЮ РЋџРЋљРЋљРЋљРЋљРЋљРЋЮ РЋџРЋљРЋЮ  РЋџРЋљРЋљРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋљРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮ
  Рюд Nonsense Hub v2.0 - Fixed Wallpaper + Custom Audio ID Рюд
]=]

-- РЋћРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋЌ
-- РЋЉ  РџЎ№ИЈ CONFIGURATION                                      РЋЉ
-- РЋЉ                                                         РЋЉ
-- РЋЉ  CARA DAPAT WALLPAPER ID:                               РЋЉ
-- РЋЉ  1. Buka https://create.roblox.com/dashboard/creations  РЋЉ
-- РЋЉ  2. Klik "Development Items" Рєњ "Decals"                 РЋЉ
-- РЋЉ  3. Upload gambar gunung kamu                           РЋЉ
-- РЋЉ  4. Setelah approved, klik decal nya                    РЋЉ
-- РЋЉ  5. Di URL ada angka, ITU decal ID                      РЋЉ
-- РЋЉ  6. Untuk dapat IMAGE ID:                               РЋЉ
-- РЋЉ     - Buka game, insert decal, cek Properties           РЋЉ
-- РЋЉ     - Atau pakai: rbxthumb://type=Asset&id=DECAL_ID     РЋЉ
-- РЋЉ                   &w=420&h=420                          РЋЉ
-- РЋЉ                                                         РЋЉ
-- РЋЉ  ATAU ganti di Settings tab langsung di dalam GUI!      РЋЉ
-- РЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋЮ

local CONFIG = {
    -- Wallpaper: Ganti dengan ID gambar kamu
    -- Contoh ID yang biasa work:
    -- "rbxassetid://9438453972"
    -- "rbxassetid://6071575925"  
    -- "rbxassetid://7072706620"
    -- Atau bisa pakai thumbnail: "rbxthumb://type=Asset&id=DECAL_ID&w=420&h=420"
    WallpaperID = "rbxthumb://type=Asset&id=6034287594&w=420&h=420",
    
    -- Music: Langsung play saat execute
    MusicID = "rbxassetid://132701552263784",
    
    -- Volume default (0 - 1)
    Volume = 0.5,
    
    -- Fly script URL
    FlyURL = "https://raw.githubusercontent.com/XNEOFF/FlyGuiV3/main/FlyGuiV3.txt",
}

-- РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ SERVICES РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local TeleportService = game:GetService("TeleportService")
local SoundService = game:GetService("SoundService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

local tweenFast = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tweenSmooth = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local tweenBounce = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

-- Cleanup old
for _, g in pairs(LocalPlayer.PlayerGui:GetChildren()) do
    if g.Name == "NonsenseHub" or g.Name == "NonsenseSplash" then g:Destroy() end
end
for _, s in pairs(SoundService:GetChildren()) do if s.Name == "NonsenseMusic" then s:Destroy() end end
for _, s in pairs(Workspace:GetChildren()) do if s.Name == "NonsenseMusic" then s:Destroy() end end

-- РЋћРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋЌ
-- РЋЉ  ­Ъјх CREATE MUSIC SOUND                       РЋЉ
-- РЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋЮ
local musicSound = Instance.new("Sound")
musicSound.Name = "NonsenseMusic"
musicSound.SoundId = CONFIG.MusicID
musicSound.Volume = CONFIG.Volume
musicSound.Looped = true
musicSound.PlayOnRemove = false

local parentOk = pcall(function() musicSound.Parent = SoundService end)
if not parentOk then musicSound.Parent = Workspace end

local musicPlaying = false

-- Track all wallpaper ImageLabels so we can update them
local wallpaperElements = {}

local function setWallpaper(id)
    CONFIG.WallpaperID = id
    for _, img in pairs(wallpaperElements) do
        if img and img.Parent then
            img.Image = id
        end
    end
end

local function registerWallpaper(img)
    table.insert(wallpaperElements, img)
    img.Image = CONFIG.WallpaperID
end

-- РЋћРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋЌ
-- РЋЉ           PART 1: SPLASH SCREEN                         РЋЉ
-- РЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋЮ

local splashGui = Instance.new("ScreenGui")
splashGui.Name = "NonsenseSplash"
splashGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
splashGui.ResetOnSpawn = false
splashGui.IgnoreGuiInset = true
splashGui.DisplayOrder = 999
splashGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

-- РЋљРЋљРЋљ Full Wallpaper BG РЋљРЋљРЋљ
local splashBG = Instance.new("ImageLabel", splashGui)
splashBG.BackgroundColor3 = Color3.fromRGB(20, 45, 85) -- Fallback color if image fails
splashBG.BorderSizePixel = 0
splashBG.Size = UDim2.new(1.15, 0, 1.15, 0)
splashBG.Position = UDim2.new(-0.075, 0, -0.075, 0)
splashBG.ImageTransparency = 0
splashBG.ScaleType = Enum.ScaleType.Crop
splashBG.ZIndex = 1
registerWallpaper(splashBG)

-- Fallback gradient if wallpaper fails
local splashBGGrad = Instance.new("UIGradient", splashBG)
splashBGGrad.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(40, 80, 140)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(25, 50, 100)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 25, 55))
})
splashBGGrad.Rotation = 180

-- Overlay
local splashOvl = Instance.new("Frame", splashGui)
splashOvl.BackgroundColor3 = Color3.fromRGB(5, 10, 25)
splashOvl.BackgroundTransparency = 0.5
splashOvl.BorderSizePixel = 0
splashOvl.Size = UDim2.new(1, 0, 1, 0)
splashOvl.ZIndex = 2

Instance.new("UIGradient", splashOvl).Transparency = NumberSequence.new({
    NumberSequenceKeypoint.new(0, 0.7),
    NumberSequenceKeypoint.new(0.4, 0.4),
    NumberSequenceKeypoint.new(1, 0.15)
})

-- Slow zoom
TweenService:Create(splashBG, TweenInfo.new(10, Enum.EasingStyle.Linear), {
    Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 0, 0)
}):Play()

-- Particles
local partH = Instance.new("Frame", splashGui)
partH.BackgroundTransparency = 1; partH.Size = UDim2.new(1,0,1,0)
partH.ZIndex = 3; partH.ClipsDescendants = true

for i = 1, 25 do
    local d = Instance.new("Frame", partH)
    d.BackgroundColor3 = Color3.fromRGB(200,225,255)
    d.BackgroundTransparency = math.random(55,88)/100
    d.BorderSizePixel = 0
    local sz = math.random(2,6)
    d.Size = UDim2.new(0,sz,0,sz)
    d.Position = UDim2.new(math.random(0,100)/100, 0, math.random(0,100)/100, 0)
    d.ZIndex = 3
    Instance.new("UICorner", d).CornerRadius = UDim.new(1, 0)
end

for i = 1, 10 do
    local p = Instance.new("Frame", partH)
    p.BackgroundColor3 = Color3.fromRGB(200,230,255)
    p.BackgroundTransparency = 0.5; p.BorderSizePixel = 0
    local sz = math.random(4,9)
    p.Size = UDim2.new(0,sz,0,sz)
    local sX = math.random(0,100)/100
    p.Position = UDim2.new(sX,0,1.1,0); p.ZIndex = 3
    Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
    task.spawn(function()
        task.wait(math.random(0,25)/10)
        while splashGui.Parent do
            p.Position = UDim2.new(sX + math.random(-5,5)/100, 0, 1.1, 0)
            p.BackgroundTransparency = 0.5
            TweenService:Create(p, TweenInfo.new(math.random(7,12), Enum.EasingStyle.Linear), {
                Position = UDim2.new(sX + math.random(-8,8)/100, 0, -0.1, 0),
                BackgroundTransparency = 1
            }):Play()
            task.wait(math.random(7,12))
        end
    end)
end

-- РЋљРЋљРЋљ Center Card РЋљРЋљРЋљ
local splashCard = Instance.new("Frame", splashGui)
splashCard.BackgroundColor3 = Color3.fromRGB(15, 28, 55)
splashCard.BackgroundTransparency = 0.25
splashCard.BorderSizePixel = 0
splashCard.Size = UDim2.new(0, 520, 0, 350)
splashCard.Position = UDim2.new(0.5, -260, 0.5, -175)
splashCard.ZIndex = 10

Instance.new("UICorner", splashCard).CornerRadius = UDim.new(0, 16)
local cStroke = Instance.new("UIStroke", splashCard)
cStroke.Color = Color3.fromRGB(100,180,255); cStroke.Thickness = 1.5; cStroke.Transparency = 0.2

-- Card wallpaper peek
local cardWP = Instance.new("ImageLabel", splashCard)
cardWP.BackgroundColor3 = Color3.fromRGB(20,40,70)
cardWP.Size = UDim2.new(1,0,1,0)
cardWP.ImageTransparency = 0.7
cardWP.ScaleType = Enum.ScaleType.Crop; cardWP.ZIndex = 10
Instance.new("UICorner", cardWP).CornerRadius = UDim.new(0, 16)
registerWallpaper(cardWP)

-- Shadow
local cShd = Instance.new("ImageLabel", splashCard)
cShd.BackgroundTransparency = 1; cShd.Position = UDim2.new(0,-22,0,-22)
cShd.Size = UDim2.new(1,44,1,44); cShd.ZIndex = 9
cShd.Image = "rbxassetid://5554236805"; cShd.ImageColor3 = Color3.fromRGB(20,50,130)
cShd.ImageTransparency = 0.6; cShd.ScaleType = Enum.ScaleType.Slice
cShd.SliceCenter = Rect.new(23,23,277,277)

-- Corner accents
local function mkLine(p, px, py, sx, sy, col)
    local f = Instance.new("Frame", p)
    f.BackgroundColor3 = col; f.BackgroundTransparency = 0.2
    f.BorderSizePixel = 0; f.Size = UDim2.new(0,sx,0,sy)
    f.Position = UDim2.new(px,0,py,0); f.ZIndex = 16; return f
end
mkLine(splashCard, 0, 0, 45, 2, Color3.fromRGB(100,190,255))
mkLine(splashCard, 0, 0, 2, 45, Color3.fromRGB(100,190,255))
mkLine(splashCard, 0, 0, 45, 2, Color3.fromRGB(90,150,230)).Position = UDim2.new(1,-45,1,-2)
mkLine(splashCard, 0, 0, 2, 45, Color3.fromRGB(90,150,230)).Position = UDim2.new(1,-2,1,-45)

-- Logo
local logoCont = Instance.new("Frame", splashCard)
logoCont.BackgroundTransparency = 1; logoCont.Size = UDim2.new(0,88,0,88)
logoCont.Position = UDim2.new(0.5,-44,0,18); logoCont.ZIndex = 14

local outerR = Instance.new("Frame", logoCont)
outerR.BackgroundColor3 = Color3.fromRGB(60,140,220); outerR.BackgroundTransparency = 0.6
outerR.Size = UDim2.new(1,0,1,0); outerR.ZIndex = 14
Instance.new("UICorner", outerR).CornerRadius = UDim.new(1, 0)
local oRS = Instance.new("UIStroke", outerR)
oRS.Color = Color3.fromRGB(110,190,255); oRS.Thickness = 3; oRS.Transparency = 0.1
Instance.new("UIGradient", outerR).Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(70,150,230)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(130,90,210)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(70,150,230))
})

local innerR = Instance.new("Frame", logoCont)
innerR.BackgroundColor3 = Color3.fromRGB(10,18,35)
innerR.Size = UDim2.new(0.7,0,0.7,0); innerR.Position = UDim2.new(0.15,0,0.15,0)
innerR.ZIndex = 15; Instance.new("UICorner", innerR).CornerRadius = UDim.new(1, 0)

local logoMtn = Instance.new("ImageLabel", innerR)
logoMtn.BackgroundColor3 = Color3.fromRGB(20,40,70)
logoMtn.Size = UDim2.new(0.88,0,0.88,0); logoMtn.Position = UDim2.new(0.06,0,0.06,0)
logoMtn.ImageTransparency = 0.2; logoMtn.ScaleType = Enum.ScaleType.Crop; logoMtn.ZIndex = 15
Instance.new("UICorner", logoMtn).CornerRadius = UDim.new(1, 0)
registerWallpaper(logoMtn)

local logoE = Instance.new("TextLabel", logoCont)
logoE.BackgroundTransparency = 1; logoE.Size = UDim2.new(1,0,1,0)
logoE.Font = Enum.Font.SourceSansBold; logoE.Text = "­Ъїђ"; logoE.TextSize = 32; logoE.ZIndex = 16

-- Orbit dots
for idx = 1, 3 do
    local od = Instance.new("Frame", logoCont)
    od.Name = "O"..idx
    od.BackgroundColor3 = idx==1 and Color3.fromRGB(100,210,255) or idx==2 and Color3.fromRGB(150,100,240) or Color3.fromRGB(80,230,180)
    od.BorderSizePixel = 0; od.Size = UDim2.new(0,7,0,7); od.ZIndex = 17
    Instance.new("UICorner", od).CornerRadius = UDim.new(1, 0)
end

task.spawn(function() while splashGui.Parent do
    TweenService:Create(outerR, TweenInfo.new(5, Enum.EasingStyle.Linear), {Rotation = outerR.Rotation+360}):Play(); task.wait(5)
end end)

task.spawn(function()
