innerRing.BackgroundColor3 = Color3.fromRGB(10, 18, 35)
innerRing.Size = UDim2.new(0.7, 0, 0.7, 0)
innerRing.Position = UDim2.new(0.15, 0, 0.15, 0); innerRing.ZIndex = 15
Instance.new("UICorner", innerRing).CornerRadius = UDim.new(1, 0)

local logoMtn = Instance.new("ImageLabel", innerRing)
logoMtn.BackgroundTransparency = 1
logoMtn.Size = UDim2.new(0.88, 0, 0.88, 0)
logoMtn.Position = UDim2.new(0.06, 0, 0.06, 0)
logoMtn.Image = WALLPAPER_ID; logoMtn.ImageTransparency = 0.25
logoMtn.ScaleType = Enum.ScaleType.Crop; logoMtn.ZIndex = 15
Instance.new("UICorner", logoMtn).CornerRadius = UDim.new(1, 0)

local logoEmoji = Instance.new("TextLabel", logoCont)
logoEmoji.BackgroundTransparency = 1; logoEmoji.Size = UDim2.new(1, 0, 1, 0)
logoEmoji.Font = Enum.Font.SourceSansBold; logoEmoji.Text = "ūüĆÄ"
logoEmoji.TextSize = 32; logoEmoji.ZIndex = 16

for idx = 1, 3 do
    local od = Instance.new("Frame", logoCont)
    od.Name = "Orb"..idx
    od.BackgroundColor3 = idx==1 and Color3.fromRGB(100,210,255) or idx==2 and Color3.fromRGB(150,100,240) or Color3.fromRGB(80,230,180)
    od.BorderSizePixel = 0; od.Size = UDim2.new(0, 7, 0, 7); od.ZIndex = 17
    Instance.new("UICorner", od).CornerRadius = UDim.new(1, 0)
end

task.spawn(function()
    while splashGui.Parent do
        TweenService:Create(outerRing, TweenInfo.new(5, Enum.EasingStyle.Linear), {Rotation = outerRing.Rotation + 360}):Play()
        task.wait(5)
    end
end)

task.spawn(function()
    local dots = {}
    for _, ch in pairs(logoCont:GetChildren()) do if ch.Name:find("Orb") then table.insert(dots, ch) end end
    local t = 0
    while splashGui.Parent do
        t += 0.04
        for i, d in ipairs(dots) do
            local a = t*1.5 + ((i-1)*2*math.pi/#dots)
            d.Position = UDim2.new(0.5+math.cos(a)*0.44, -3, 0.5+math.sin(a)*0.44, -3)
        end; task.wait(0.02)
    end
end)

-- Title
local splashTitle = Instance.new("TextLabel", splashCard)
splashTitle.BackgroundTransparency = 1
splashTitle.Position = UDim2.new(0, 0, 0, 115)
