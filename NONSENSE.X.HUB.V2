-- тХРтХРтХР Splash Animations тХРтХРтХР
local cardScale = Instance.new("UIScale", splashCard)
cardScale.Scale = 0

task.delay(0.2, function()
    TweenService:Create(cardScale, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
end)

for i, c in ipairs(sCards) do
    local saved = c.Position
    c.Position = (i <= 3) and UDim2.new(-0.3, 0, saved.Y.Scale, 0) or UDim2.new(1.3, 0, saved.Y.Scale, 0)
    task.delay(0.5 + i*0.1, function()
        TweenService:Create(c, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Position = saved}):Play()
    end)
end

wm.Position = UDim2.new(1, 10, 0, 10)
stBadge.Position = UDim2.new(0, -210, 0, 10)
task.delay(0.3, function()
    TweenService:Create(wm, tweenSmooth, {Position = UDim2.new(1, -182, 0, 10)}):Play()
    TweenService:Create(stBadge, tweenSmooth, {Position = UDim2.new(0, 10, 0, 10)}):Play()
end)

-- Card stroke pulse
task.spawn(function()
    while splashGui.Parent do
        TweenService:Create(cStroke, TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Color = Color3.fromRGB(110, 190, 255), Transparency = 0.15
        }):Play()
        task.wait(2.5)
        TweenService:Create(cStroke, TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Color = Color3.fromRGB(150, 110, 240), Transparency = 0.4
        }):Play()
        task.wait(2.5)
    end
end)

-- тХРтХРтХР LOADING тХРтХРтХР
local steps = {
    {p=0.08, t="Initializing core..."}, {p=0.18, t="Loading services..."},
    {p=0.30, t="Building UI..."}, {p=0.42, t="Creating tabs..."},
    {p=0.55, t="Loading FlyGuiV3 module..."}, {p=0.65, t="Setting up ESP..."},
    {p=0.78, t="Loading visuals..."}, {p=0.88, t="Registering keybinds..."},
    {p=0.96, t="Finalizing..."}, {p=1.00, t="Ready! тЬУ"},
}

for _, s in ipairs(steps) do
    task.wait(math.random(2,5)/10)
    loadText.Text = s.t
    loadPerc.Text = math.floor(s.p*100).."%"
    TweenService:Create(loadFill, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(s.p, 0, 1, 0)}):Play()
    if s.p >= 1 then
        loadText.TextColor3 = Color3.fromRGB(80, 255, 140)
        loadPerc.TextColor3 = Color3.fromRGB(80, 255, 140)
        TweenService:Create(loadFill, tweenFast, {BackgroundColor3 = Color3.fromRGB(60, 215, 120)}):Play()
    end
end

task.wait(1.5)

-- Splash exit
TweenService:Create(cardScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0}):Play()
for i, c in ipairs(sCards) do
    TweenService:Create(c, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
        Position = (i<=3) and UDim2.new(-0.3, 0, c.Position.Y.Scale, 0) or UDim2.new(1.3, 0, c.Position.Y.Scale, 0)
    }):Play()
end
TweenService:Create(wm, tweenFast, {Position = UDim2.new(1, 10, 0, 10)}):Play()
TweenService:Create(stBadge, tweenFast, {Position = UDim2.new(0, -210, 0, 10)}):Play()
TweenService:Create(splashBG, TweenInfo.new(0.8), {ImageTransparency = 1}):Play()
TweenService:Create(splashOverlay, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()

task.wait(1)
splashGui:Destroy()

