    mkPreview(0.05, 0.44, "ЁЯХКя╕П", "FlyGuiV3", "Press E to fly", Color3.fromRGB(100,200,255)),
    mkPreview(0.03, 0.68, "ЁЯС╗", "Noclip", "Walk through walls", Color3.fromRGB(150,100,240)),
    mkPreview(0.85, 0.2, "ЁЯСБя╕П", "ESP", "See all players", Color3.fromRGB(255,90,90)),
