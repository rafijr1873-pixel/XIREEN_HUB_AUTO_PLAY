-- Splash Entrance Animations
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local cardScale = Instance.new("UIScale", splashCard)
cardScale.Scale = 0

task.delay(0.2, function()
    TweenService:Create(cardScale, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
end)

-- Side cards slide in
for i, card in ipairs(sideCards) do
    local saved = card.Position
    card.Position = (i <= 3) and UDim2.new(-0.3, 0, saved.Y.Scale, 0) or UDim2.new(1.3, 0, saved.Y.Scale, 0)
    task.delay(0.5 + i * 0.1, function()
        TweenService:Create(card, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Position = saved}):Play()
    end)
end

