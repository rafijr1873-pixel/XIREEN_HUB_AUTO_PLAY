    States.noclip = s
    notify("Noclip", s and "Walk through walls!" or "Disabled", 2)
end, 6)

createSection(pages[1], "FLIGHT (FlyGuiV3)", 7)

createButton(pages[1], "🕊️ Load FlyGuiV3 (Press E to Fly)", function()
    if not States.flyLoaded then
        States.flyLoaded = true
        notify("🕊️ FlyGuiV3", "Loading FlyGuiV3... Press E to toggle fly!", 4)
        task.spawn(function()
            local success, err = pcall(function()
                loadstring(game:HttpGet(FLY_SCRIPT_URL))()
            end)
            if success then
                notify("🕊️ FlyGuiV3", "Loaded! Press E to fly. Use WASD + Space/Shift", 5)
            else
                notify("❌ Error", "Failed to load FlyGuiV3: " .. tostring(err), 4)
                States.flyLoaded = false
            end
        end)
    else
        notify("🕊️ FlyGuiV3", "Already loaded! Press E to toggle fly", 3)
    end
end, 9)

createLabel(pages[1], "  ℹ️ FlyGuiV3: Press E to toggle fly on/off", 10)
createLabel(pages[1], "  ℹ️ WASD to move, Space=Up, Shift=Down", 11)

