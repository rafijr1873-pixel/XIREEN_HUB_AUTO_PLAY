        TweenService:Create(outerRing, TweenInfo.new(5, Enum.EasingStyle.Linear), {Rotation = outerRing.Rotation + 360}):Play()
        task.wait(5)
    end
end)

task.spawn(function()
    local dots = {}
    for _, ch in pairs(logoCont:GetChildren()) do if ch.Name:find("Orb") then table.insert(dots, ch) end end
    local t = 0
    while splashGui.Parent do
        t += 0.04
        for i, d in ipairs(dots) do
            local angle = t * 1.5 + ((i-1) * 2 * math.pi / #dots)
            d.Position = UDim2.new(0.5 + math.cos(angle)*0.44, -3, 0.5 + math.sin(angle)*0.44, -3)
        end
        task.wait(0.02)
    end
end)

