local function mkPrev(px, py, ic, ti, de, col)
    local c = Instance.new("Frame", splashGui)
    c.BackgroundColor3 = Color3.fromRGB(12,22,42); c.BackgroundTransparency = 0.2
    c.BorderSizePixel = 0; c.Position = UDim2.new(px, 0, py, 0)
    c.Size = UDim2.new(0, 148, 0, 66); c.ZIndex = 8
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 10)
    Instance.new("UIStroke", c).Color = col

    local a = Instance.new("Frame", c)
    a.BackgroundColor3 = col; a.BorderSizePixel = 0
    a.Size = UDim2.new(0, 3, 0.6, 0); a.Position = UDim2.new(0, 0, 0.2, 0); a.ZIndex = 9

    local i2 = Instance.new("TextLabel", c)
    i2.BackgroundTransparency = 1; i2.Position = UDim2.new(0, 11, 0, 7)
    i2.Size = UDim2.new(0, 26, 0, 20); i2.Font = Enum.Font.SourceSansBold
    i2.Text = ic; i2.TextSize = 17; i2.ZIndex = 9

    local t2 = Instance.new("TextLabel", c)
    t2.BackgroundTransparency = 1; t2.Position = UDim2.new(0, 38, 0, 9)
    t2.Size = UDim2.new(1, -48, 0, 15); t2.Font = Enum.Font.GothamBold
    t2.Text = ti; t2.TextColor3 = Color3.fromRGB(225,240,255)
    t2.TextSize = 11; t2.TextXAlignment = Enum.TextXAlignment.Left; t2.ZIndex = 9

    local d2 = Instance.new("TextLabel", c)
    d2.BackgroundTransparency = 1; d2.Position = UDim2.new(0, 11, 0, 32)
    d2.Size = UDim2.new(1, -18, 0, 26); d2.Font = Enum.Font.Gotham
    d2.Text = de; d2.TextColor3 = Color3.fromRGB(130,160,200)
    d2.TextSize = 9; d2.TextWrapped = true; d2.TextXAlignment = Enum.TextXAlignment.Left; d2.ZIndex = 9
    return c
end

