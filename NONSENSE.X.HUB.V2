    while splashGui.Parent do
        TweenService:Create(splashCardStroke, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Transparency = 0.2, Color = Color3.fromRGB(100, 160, 255)
        }):Play()
        task.wait(2)
        TweenService:Create(splashCardStroke, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Transparency = 0.5, Color = Color3.fromRGB(140, 80, 255)
        }):Play()
        task.wait(2)
    end
end)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- LOADING SEQUENCE
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local loadSteps = {
    {p = 0.08, t = "Initializing core..."},
    {p = 0.18, t = "Loading services..."},
    {p = 0.30, t = "Building UI framework..."},
    {p = 0.42, t = "Creating tab system..."},
    {p = 0.55, t = "Registering features..."},
    {p = 0.68, t = "Setting up combat modules..."},
    {p = 0.78, t = "Loading visual systems..."},
    {p = 0.88, t = "Registering keybinds..."},
    {p = 0.95, t = "Finalizing..."},
    {p = 1.00, t = "Ready! вң“"},
}

for _, step in ipairs(loadSteps) do
    task.wait(math.random(2, 5) / 10)
    loadText.Text = step.t
    loadPerc.Text = math.floor(step.p * 100) .. "%"
    TweenService:Create(loadBarFill, TweenInfo.new(0.35, Enum.EasingStyle.Quart), {
        Size = UDim2.new(step.p, 0, 1, 0)
    }):Play()

    if step.p >= 1 then
        loadText.TextColor3 = Color3.fromRGB(80, 255, 120)
        loadPerc.TextColor3 = Color3.fromRGB(80, 255, 120)
        TweenService:Create(loadBarFill, tweenFast, {BackgroundColor3 = Color3.fromRGB(60, 200, 100)}):Play()
    end
end

task.wait(1.5)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- SPLASH EXIT ANIMATION
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
TweenService:Create(cardScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0}):Play()

for i, card in ipairs(sideCards) do
    TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
        Position = (i <= 3)
            and UDim2.new(-0.3, 0, card.Position.Y.Scale, 0)
            or UDim2.new(1.3, 0, card.Position.Y.Scale, 0)
    }):Play()
end

TweenService:Create(wm, tweenFast, {Position = UDim2.new(1, 10, 0, 10)}):Play()
TweenService:Create(stats, tweenFast, {Position = UDim2.new(0, -210, 0, 10)}):Play()
TweenService:Create(splashBG, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()

for _, ch in pairs(splashBG:GetDescendants()) do
    if ch:IsA("Frame") then
        pcall(function() TweenService:Create(ch, TweenInfo.new(0.6), {BackgroundTransparency = 1}):Play() end)
    elseif ch:IsA("ImageLabel") then
        pcall(function() TweenService:Create(ch, TweenInfo.new(0.6), {ImageTransparency = 1}):Play() end)
    end
end

task.wait(1)
splashGui:Destroy()

