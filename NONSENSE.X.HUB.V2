-- ═══════════════════════════════════════
-- Entrance Animations
-- ═══════════════════════════════════════
local cardScale = Instance.new("UIScale", splashCard)
cardScale.Scale = 0

-- Wallpaper zoom in effect
splashBG.Size = UDim2.new(1.2, 0, 1.2, 0)
splashBG.Position = UDim2.new(-0.1, 0, -0.1, 0)
TweenService:Create(splashBG, TweenInfo.new(8, Enum.EasingStyle.Linear), {
    Size = UDim2.new(1, 0, 1, 0),
    Position = UDim2.new(0, 0, 0, 0)
}):Play()

task.delay(0.2, function()
    TweenService:Create(cardScale, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
end)

for i, card in ipairs(sideCards) do
    local saved = card.Position
    card.Position = (i <= 3) and UDim2.new(-0.3, 0, saved.Y.Scale, 0) or UDim2.new(1.3, 0, saved.Y.Scale, 0)
    task.delay(0.5 + i * 0.1, function()
        TweenService:Create(card, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Position = saved}):Play()
    end)
end

wm.Position = UDim2.new(1, 10, 0, 10)
statsBadge.Position = UDim2.new(0, -220, 0, 10)
task.delay(0.3, function()
    TweenService:Create(wm, tweenSmooth, {Position = UDim2.new(1, -185, 0, 10)}):Play()
    TweenService:Create(statsBadge, tweenSmooth, {Position = UDim2.new(0, 10, 0, 10)}):Play()
end)

-- Card stroke pulse
task.spawn(function()
    while splashGui.Parent do
        TweenService:Create(cardStroke, TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Color = Color3.fromRGB(100, 180, 255), Transparency = 0.2
        }):Play()
        task.wait(2.5)
        TweenService:Create(cardStroke, TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Color = Color3.fromRGB(140, 100, 230), Transparency = 0.45
        }):Play()
        task.wait(2.5)
    end
end)

-- ═══════════════════════════════════════
-- LOADING SEQUENCE
-- ═══════════════════════════════════════
local loadSteps = {
    {p = 0.08, t = "Initializing core..."},
    {p = 0.18, t = "Loading services..."},
    {p = 0.28, t = "Building UI framework..."},
    {p = 0.40, t = "Creating tab system..."},
    {p = 0.52, t = "Registering features..."},
    {p = 0.62, t = "Loading FlyGuiV3 module..."},
    {p = 0.72, t = "Setting up ESP system..."},
    {p = 0.82, t = "Loading visual systems..."},
    {p = 0.90, t = "Registering keybinds..."},
    {p = 0.96, t = "Finalizing..."},
    {p = 1.00, t = "Ready! ✓"},
}

for _, step in ipairs(loadSteps) do
    task.wait(math.random(2, 5) / 10)
    loadText.Text = step.t
    loadPerc.Text = math.floor(step.p * 100) .. "%"
    TweenService:Create(loadBarFill, TweenInfo.new(0.35, Enum.EasingStyle.Quart), {
        Size = UDim2.new(step.p, 0, 1, 0)
    }):Play()

    if step.p >= 1 then
        loadText.TextColor3 = Color3.fromRGB(80, 255, 140)
        loadPerc.TextColor3 = Color3.fromRGB(80, 255, 140)
        TweenService:Create(loadBarFill, tweenFast, {BackgroundColor3 = Color3.fromRGB(60, 210, 120)}):Play()
    end
end

task.wait(1.5)

-- ═══════════════════════════════════════
-- SPLASH EXIT
-- ═══════════════════════════════════════
TweenService:Create(cardScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0}):Play()

for i, card in ipairs(sideCards) do
    TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
        Position = (i <= 3) and UDim2.new(-0.3, 0, card.Position.Y.Scale, 0)
            or UDim2.new(1.3, 0, card.Position.Y.Scale, 0)
    }):Play()
end

TweenService:Create(wm, tweenFast, {Position = UDim2.new(1, 10, 0, 10)}):Play()
TweenService:Create(statsBadge, tweenFast, {Position = UDim2.new(0, -220, 0, 10)}):Play()
TweenService:Create(splashBG, TweenInfo.new(0.8), {ImageTransparency = 1}):Play()
TweenService:Create(splashOverlay, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()

task.wait(1)
splashGui:Destroy()

