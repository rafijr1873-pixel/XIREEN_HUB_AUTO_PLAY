    vIcn.Text = r > 0.5 and "­Ъћі" or r > 0.1 and "­ЪћЅ" or "­Ъћѕ"
end end)
UserInputService.InputChanged:Connect(function(i) if vDrag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
    local r = math.clamp((i.Position.X - vBG.AbsolutePosition.X) / vBG.AbsoluteSize.X, 0, 1)
    musicSound.Volume = r; vFl.Size = UDim2.new(r,0,1,0)
    vIcn.Text = r > 0.5 and "­Ъћі" or r > 0.1 and "­ЪћЅ" or "­Ъћѕ"
end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then vDrag = false end end)

-- Play/Pause
ppBtn.MouseButton1Click:Connect(function()
    if musicPlaying then musicSound:Pause(); musicPlaying = false; ppBtn.Text = "РќХ"
        ppBtn.BackgroundColor3 = Color3.fromRGB(80,160,255); npLbl.Text = "Paused"
        npLbl.TextColor3 = Color3.fromRGB(150,170,200)
    else musicSound:Resume(); musicPlaying = true; ppBtn.Text = "РЈИ"
        ppBtn.BackgroundColor3 = Color3.fromRGB(60,180,120); npLbl.Text = "Playing"
        npLbl.TextColor3 = Color3.fromRGB(180,140,255) end
end)
ppBtn.MouseEnter:Connect(function() TweenService:Create(ppBtn, tweenFast, {BackgroundTransparency = 0}):Play() end)
ppBtn.MouseLeave:Connect(function() TweenService:Create(ppBtn, tweenFast, {BackgroundTransparency = 0.25}):Play() end)

stBtn.MouseButton1Click:Connect(function()
    musicSound:Stop(); musicPlaying = false; ppBtn.Text = "РќХ"
    npLbl.Text = "Stopped"; npLbl.TextColor3 = Color3.fromRGB(120,130,155)
end)
stBtn.MouseEnter:Connect(function() TweenService:Create(stBtn, tweenFast, {BackgroundTransparency = 0.05}):Play() end)
stBtn.MouseLeave:Connect(function() TweenService:Create(stBtn, tweenFast, {BackgroundTransparency = 0.35}):Play() end)

-- Music icon animation
task.spawn(function() while screenGui.Parent do
    if musicPlaying then
        TweenService:Create(mIcn, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Rotation = 15}):Play(); task.wait(0.4)
        TweenService:Create(mIcn, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Rotation = -15}):Play(); task.wait(0.4)
    else TweenService:Create(mIcn, TweenInfo.new(0.3), {Rotation = 0}):Play(); task.wait(0.8) end
end end)

