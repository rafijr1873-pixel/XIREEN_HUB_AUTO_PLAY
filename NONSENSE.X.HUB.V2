-- Loading
local steps = {
    {p=0.08, t="Initializing core..."}, {p=0.18, t="Loading services..."},
    {p=0.30, t="ūüéĶ Loading audio system..."}, {p=0.42, t="Creating tabs..."},
    {p=0.55, t="Loading FlyGuiV3 module..."}, {p=0.65, t="Setting up ESP..."},
    {p=0.78, t="Loading visuals..."}, {p=0.88, t="Registering keybinds..."},
    {p=0.96, t="Finalizing..."}, {p=1.00, t="Ready! ‚úď"},
}

for _, s in ipairs(steps) do
    task.wait(math.random(2,5)/10)
    loadText.Text = s.t; loadPerc.Text = math.floor(s.p*100).."%"
    TweenService:Create(loadFill, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(s.p, 0, 1, 0)}):Play()
    if s.p >= 1 then
        loadText.TextColor3 = Color3.fromRGB(80,255,140)
        loadPerc.TextColor3 = Color3.fromRGB(80,255,140)
    end
end

task.wait(1.5)

-- Splash exit
TweenService:Create(cardScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0}):Play()
for i, c in ipairs(sCards) do
    TweenService:Create(c, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
        Position = (i<=3) and UDim2.new(-0.3, 0, c.Position.Y.Scale, 0) or UDim2.new(1.3, 0, c.Position.Y.Scale, 0)
    }):Play()
end
TweenService:Create(splashBG, TweenInfo.new(0.8), {ImageTransparency = 1}):Play()
TweenService:Create(splashOverlay, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
task.wait(1); splashGui:Destroy()

