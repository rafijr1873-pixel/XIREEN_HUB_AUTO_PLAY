createSection(pages[5], "SURVIVAL", 1)

createToggle(pages[5], "вқӨпёҸ God Mode (Client)", false, function(s)
    States.godMode = s
    notify("God Mode", s and "Healing every frame" or "Disabled", 2)
end, 3)

createToggle(pages[5], "рҹӣЎпёҸ No Fall Damage", false, function(s)
    States.noFallDmg = s
    local h = getHumanoid()
    if h then
        h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, not s)
        h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, not s)
    end
    notify("Fall Damage", s and "Disabled" or "Enabled", 2)
end, 4)

createSection(pages[5], "PHYSICS", 6)

createSlider(pages[5], "Jump Power", 50, 500, 50, function(v)
    States.jumpPower = v
    local h = getHumanoid()
    if h then h.UseJumpPower = true; h.JumpPower = v end
end, 8)

createSlider(pages[5], "Gravity", 0, 500, 196, function(v)
    States.gravity = v; Workspace.Gravity = v
end, 9)

createSection(pages[5], "CHARACTER", 11)

createButton(pages[5], "рҹ’Җ Reset Character", function()
    local h = getHumanoid()
    if h then h.Health = 0; notify("Player", "Reset", 2) end
end, 13)

createButton(pages[5], "рҹ§Ҡ Freeze/Unfreeze", function()
    local hrp = getHRP()
    if hrp then
        hrp.Anchored = not hrp.Anchored
        notify("Player", hrp.Anchored and "Frozen" or "Unfrozen", 2)
    end
end, 14)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- PAGE 6: рҹ”§ MISC
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[6], "UTILITY", 1)

createToggle(pages[6], "рҹ’Ө Anti AFK", false, function(s)
    States.antiAFK = s
    if s then
        antiAFKConn = LocalPlayer.Idled:Connect(function()
            local vu = game:GetService("VirtualUser")
            vu:Button2Down(Vector2.zero, Camera.CFrame)
            task.wait(1)
            vu:Button2Up(Vector2.zero, Camera.CFrame)
        end)
    else
        if antiAFKConn then antiAFKConn:Disconnect(); antiAFKConn = nil end
    end
    notify("Anti AFK", s and "Won't be kicked" or "Disabled", 2)
end, 3)

createButton(pages[6], "рҹҡҖ FPS Boost", function()
    local c = 0
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Trail") then
            v.Enabled = false; c += 1
        elseif v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic; v.Reflectance = 0
        end
    end
    Lighting.GlobalShadows = false; Lighting.FogEnd = 9e9
    for _, v in pairs(Lighting:GetDescendants()) do
        if v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("BloomEffect") or v:IsA("DepthOfFieldEffect") then
            v.Enabled = false
        end
    end
    notify("FPS Boost", "Applied! " .. c .. " effects disabled", 3)
end, 4)

createSection(pages[6], "SERVER", 6)

createButton(pages[6], "рҹ”„ Rejoin Server", function()
    notify("Server", "Rejoining...", 2)
    task.wait(1)
    TeleportService:Teleport(game.PlaceId, LocalPlayer)
end, 8)

createButton(pages[6], "рҹҢҗ Server Hop", function()
    notify("Server", "Finding new server...", 2)
    task.wait(0.5)
    pcall(function()
        local data = game:GetService("HttpService"):JSONDecode(
            game:HttpGetAsync("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
        )
        if data and data.data then
            for _, sv in pairs(data.data) do
                if sv.id ~= game.JobId and sv.playing < sv.maxPlayers then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, sv.id, LocalPlayer)
                    return
                end
            end
        end
        notify("Error", "No servers found", 2)
    end)
end, 9)

createButton(pages[6], "рҹ“Ӣ Copy Server ID", function()
    if setclipboard then setclipboard(game.JobId); notify("Server", "Copied!", 2)
    else notify("Error", "Not supported", 2) end
end, 10)

createSection(pages[6], "INFO", 12)
createLabel(pages[6], "  Players: " .. #Players:GetPlayers() .. "/" .. Players.MaxPlayers, 13)
createLabel(pages[6], "  Job: " .. string.sub(game.JobId, 1, 20) .. "...", 14)

