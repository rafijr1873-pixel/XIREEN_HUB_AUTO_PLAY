createButton(pages[7], "♻️ Reset All Features", function()
    States.speed = false; States.noclip = false; States.infiniteJump = false
    States.esp = false; States.fullbright = false; States.noFog = false
    States.godMode = false; States.clickTP = false; States.autoClick = false
    States.antiAFK = false; States.noFallDmg = false

    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Character then
            local hl = plr.Character:FindFirstChild("NonsenseESP"); if hl then hl:Destroy() end
            local head = plr.Character:FindFirstChild("Head")
            if head then local bb = head:FindFirstChild("NonsenseESPTag"); if bb then bb:Destroy() end end
        end
    end
    espElements = {}

    local h = getHumanoid()
    if h then h.WalkSpeed = 16; h.JumpPower = 50; h.UseJumpPower = true end

    Lighting.Ambient = origLighting.Ambient or Color3.fromRGB(127, 127, 127)
    Lighting.Brightness = origLighting.Brightness or 1
    Lighting.OutdoorAmbient = origLighting.OutdoorAmbient or Color3.fromRGB(127, 127, 127)
    Lighting.FogEnd = origLighting.FogEnd or 1e5
    Lighting.FogStart = origLighting.FogStart or 0
    Camera.FieldOfView = 70; Workspace.Gravity = 196.2

    if antiAFKConn then antiAFKConn:Disconnect(); antiAFKConn = nil end
    notify("♻️ Reset", "All features reset!", 3)
end, 10)

createSection(pages[7], "CREDITS", 12)
createLabel(pages[7], "  🌀 Nonsense Hub v2.0 ⛰️ Mountain Edition", 14)
createLabel(pages[7], "  🕊️ Fly system: FlyGuiV3 by XNEOFF", 15)
createLabel(pages[7], "  Made with ❤️ • 7 Tabs • 20+ Features", 16)

-- ═══════════════════════════════════════
-- TAB SWITCHING
-- ═══════════════════════════════════════
local function switchTab(idx)
    for i, page in ipairs(pages) do page.Visible = (i == idx) end
    for i, btn in ipairs(tabBtns) do
        if i == idx then
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(50, 110, 230), BackgroundTransparency = 0.12}):Play()
            btn.Font = Enum.Font.GothamSemibold; btn.TextColor3 = Color3.fromRGB(225, 240, 255)
        else
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(20, 32, 55), BackgroundTransparency = 0.35}):Play()
            btn.Font = Enum.Font.Gotham; btn.TextColor3 = Color3.fromRGB(120, 140, 175)
        end
    end
    pageTitle.Text = tabNames[idx]; activeTab = idx
end

for i, btn in ipairs(tabBtns) do
    btn.MouseButton1Click:Connect(function() switchTab(i) end)
    btn.MouseEnter:Connect(function() if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.2}):Play() end end)
    btn.MouseLeave:Connect(function() if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.35}):Play() end end)
end

-- ═══════════════════════════════════════
-- RUNTIME LOOPS
-- ═══════════════════════════════════════
RunService.Heartbeat:Connect(function()
    if States.speed then local h = getHumanoid(); if h then h.WalkSpeed = States.walkSpeed end end
    if States.godMode then local h = getHumanoid(); if h then h.Health = h.MaxHealth end end
end)

RunService.Stepped:Connect(function()
    if States.noclip then
        local c = LocalPlayer.Character
        if c then for _, p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
    end
    if States.noFallDmg then
        local h = getHumanoid()
        if h then
            h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if States.esp then
        local myHRP = getHRP()
        if myHRP then
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local head = plr.Character:FindFirstChild("Head")
                    if head then
                        local bb = head:FindFirstChild("NonsenseESPTag")
                        if bb then
                            local dist = bb:FindFirstChild("Dist")
                            if dist then
                                local d = math.floor((myHRP.Position - head.Position).Magnitude)
                                dist.Text = d .. "m"
                                dist.TextColor3 = d < 30 and Color3.fromRGB(255, 80, 80)
                                    or d < 80 and Color3.fromRGB(255, 200, 80)
                                    or Color3.fromRGB(80, 255, 80)
                            end
                        end
                    end
                end
            end
        end
    end
    Camera.FieldOfView = States.fov
end)

UserInputService.JumpRequest:Connect(function()
    if States.infiniteJump then
        local h = getHumanoid(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

Mouse.Button1Down:Connect(function()
    if States.clickTP and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        local hrp = getHRP()
        if hrp then hrp.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0, 3, 0)) end
    end
end)

task.spawn(function()
    while screenGui.Parent do
        if States.autoClick then
            local c = LocalPlayer.Character
            if c then local t = c:FindFirstChildOfClass("Tool"); if t then t:Activate() end end
        end
        task.wait(States.clickDelay / 1000)
    end
end)

-- ESP for new players
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(1)
        if States.esp and plr.Character then
            local hl = Instance.new("Highlight"); hl.Name = "NonsenseESP"
            hl.FillColor = Color3.fromRGB(255, 50, 50); hl.FillTransparency = 0.5
            hl.OutlineColor = Color3.fromRGB(255, 255, 255); hl.Parent = plr.Character

            local head = plr.Character:FindFirstChild("Head")
            if head then
                local bb = Instance.new("BillboardGui"); bb.Name = "NonsenseESPTag"
                bb.Adornee = head; bb.Size = UDim2.new(0, 200, 0, 40)
                bb.StudsOffset = Vector3.new(0, 2.5, 0); bb.AlwaysOnTop = true; bb.Parent = head

                local nt = Instance.new("TextLabel", bb); nt.BackgroundTransparency = 1
                nt.Size = UDim2.new(1, 0, 0.5, 0); nt.Font = Enum.Font.GothamBold
                nt.Text = plr.DisplayName; nt.TextColor3 = Color3.fromRGB(255, 255, 255)
                nt.TextStrokeTransparency = 0; nt.TextSize = 14

                local dt = Instance.new("TextLabel", bb); dt.Name = "Dist"
                dt.BackgroundTransparency = 1; dt.Position = UDim2.new(0, 0, 0.5, 0)
                dt.Size = UDim2.new(1, 0, 0.5, 0); dt.Font = Enum.Font.Gotham
                dt.Text = "0m"; dt.TextColor3 = Color3.fromRGB(200, 200, 200)
                dt.TextStrokeTransparency = 0.3; dt.TextSize = 12
            end
        end
    end)
end)

Players.PlayerRemoving:Connect(function(plr) espElements[plr] = nil end)

-- Respawn handler
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1)
    if States.noFallDmg then
        local h = char:WaitForChild("Humanoid", 5)
        if h then
            h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
    end
end)

-- ═══════════════════════════════════════
-- DRAGGING
-- ═══════════════════════════════════════
local dragging, dragInput, dragStart, startPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        TweenService:Create(mainFrame, TweenInfo.new(0.06), {
            Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        }):Play()
    end
end)

-- ═══════════════════════════════════════
-- TOGGLE BUTTON
-- ═══════════════════════════════════════
local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 90, 200)
toggleBtn.BorderSizePixel = 0
toggleBtn.Size = UDim2.new(0, 48, 0, 48)
toggleBtn.Position = UDim2.new(0, 10, 0.5, -24)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.Text = "🌀"
toggleBtn.TextSize = 22
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.ZIndex = 20
toggleBtn.AutoButtonColor = false
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
local tgS = Instance.new("UIStroke", toggleBtn)
tgS.Color = Color3.fromRGB(100, 170, 255); tgS.Thickness = 2; tgS.Transparency = 0.25

local isOpen = true
local function toggleGUI()
    isOpen = not isOpen
    if isOpen then
        mainFrame.Visible = true; mainScale.Scale = 0.85
        TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play()
        TweenService:Create(toggleBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(40, 90, 200), Rotation = 0}):Play()
    else
        TweenService:Create(mainScale, tweenFast, {Scale = 0.85}):Play()
        TweenService:Create(toggleBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(220, 60, 60), Rotation = 180}):Play()
        task.delay(0.25, function() if not isOpen then mainFrame.Visible = false end end)
    end
end

toggleBtn.MouseButton1Click:Connect(toggleGUI)
toggleBtn.MouseEnter:Connect(function()
    TweenService:Create(toggleBtn, tweenFast, {Size = UDim2.new(0, 54, 0, 54), Position = UDim2.new(0, 7, 0.5, -27)}):Play()
end)
toggleBtn.MouseLeave:Connect(function()
    TweenService:Create(toggleBtn, tweenFast, {Size = UDim2.new(0, 48, 0, 48), Position = UDim2.new(0, 10, 0.5, -24)}):Play()
end)

-- ═══════════════════════════════════════
-- CLOSE & MINIMIZE
-- ═══════════════════════════════════════
closeBtn.MouseButton1Click:Connect(function()
    TweenService:Create(mainScale, tweenFast, {Scale = 0}):Play()
    task.delay(0.3, function() screenGui:Destroy() end)
end)
closeBtn.MouseEnter:Connect(function() TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
closeBtn.MouseLeave:Connect(function() TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.82}):Play() end)

local isMinimized = false; local savedSize
minBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    if isMinimized then
        savedSize = mainFrame.Size
        TweenService:Create(mainFrame, tweenSmooth, {Size = UDim2.new(0, 600, 0, 42)}):Play()
        minBtn.Text = "□"
    else
        TweenService:Create(mainFrame, tweenBounce, {Size = savedSize or UDim2.new(0, 600, 0, 400)}):Play()
        minBtn.Text = "─"
    end
end)
minBtn.MouseEnter:Connect(function() TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
minBtn.MouseLeave:Connect(function() TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.82}):Play() end)

-- ═══════════════════════════════════════
-- KEYBIND
-- ═══════════════════════════════════════
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then toggleGUI() end
end)

-- ═══════════════════════════════════════
-- ENTRANCE ANIMATION
-- ═══════════════════════════════════════
mainScale.Scale = 0; mainFrame.Visible = true
task.delay(0.15, function()
    TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play()
end)

task.delay(1, function()
    notify("🌀 Nonsense Hub", "Loaded! ⛰️ Mountain Edition • RightShift to toggle", 4)
end)

print("🌀 Nonsense Hub v2.0 ⛰️ Mountain Edition - Loaded!")
print("   7 Tabs | 20+ Features | FlyGuiV3 Integrated")
print("   🕊️ Load FlyGuiV3 from Main tab, press E to fly")

return screenGui
