-- Side preview cards
local function mkPreview(px, py, icon, title, desc, col)
    local c = Instance.new("Frame", splashGui)
    c.BackgroundColor3 = Color3.fromRGB(12, 22, 42)
    c.BackgroundTransparency = 0.2
    c.BorderSizePixel = 0
    c.Position = UDim2.new(px, 0, py, 0)
    c.Size = UDim2.new(0, 148, 0, 66)
    c.ZIndex = 8
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 10)
    local cs = Instance.new("UIStroke", c)
    cs.Color = col; cs.Transparency = 0.5

    local a = Instance.new("Frame", c)
    a.BackgroundColor3 = col; a.BorderSizePixel = 0
    a.Size = UDim2.new(0, 3, 0.6, 0); a.Position = UDim2.new(0, 0, 0.2, 0); a.ZIndex = 9

    local ic = Instance.new("TextLabel", c)
    ic.BackgroundTransparency = 1; ic.Position = UDim2.new(0, 11, 0, 7)
    ic.Size = UDim2.new(0, 26, 0, 20); ic.Font = Enum.Font.SourceSansBold
    ic.Text = icon; ic.TextSize = 17; ic.ZIndex = 9

    local ti = Instance.new("TextLabel", c)
    ti.BackgroundTransparency = 1; ti.Position = UDim2.new(0, 38, 0, 9)
    ti.Size = UDim2.new(1, -48, 0, 15); ti.Font = Enum.Font.GothamBold
    ti.Text = title; ti.TextColor3 = Color3.fromRGB(225, 240, 255)
    ti.TextSize = 11; ti.TextXAlignment = Enum.TextXAlignment.Left; ti.ZIndex = 9

    local de = Instance.new("TextLabel", c)
    de.BackgroundTransparency = 1; de.Position = UDim2.new(0, 11, 0, 32)
    de.Size = UDim2.new(1, -18, 0, 26); de.Font = Enum.Font.Gotham
    de.Text = desc; de.TextColor3 = Color3.fromRGB(130, 160, 200)
    de.TextSize = 9; de.TextWrapped = true; de.TextXAlignment = Enum.TextXAlignment.Left; de.ZIndex = 9

    return c
end

