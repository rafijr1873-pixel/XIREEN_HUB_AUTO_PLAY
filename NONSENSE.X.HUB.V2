local playerBtns = {}
local function refreshPlayerList()
    for _, b in pairs(playerBtns) do if b and b.Parent then b:Destroy() end end
    playerBtns = {}
    local ord = 8
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            ord += 1
            local b = createButton(pages[4], "📍 " .. plr.DisplayName .. " (@" .. plr.Name .. ")", function()
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = getHRP()
                    if hrp then hrp.CFrame = plr.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                        notify("Teleport", "Went to " .. plr.DisplayName, 2)
                    end
                end
            end, ord)
            table.insert(playerBtns, b)
        end
    end
end

