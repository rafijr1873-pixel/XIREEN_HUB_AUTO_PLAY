local WALLPAPER_ID = "rbxassetid://6034287594"
local FLY_SCRIPT_URL = "https://raw.githubusercontent.com/XNEOFF/FlyGuiV3/main/FlyGuiV3.txt"
local MUSIC_ID = "rbxassetid://132701552263784"
local DEFAULT_VOLUME = 0.5

-- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź SERVICES ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local TeleportService = game:GetService("TeleportService")
local SoundService = game:GetService("SoundService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

local tweenFast = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tweenSmooth = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local tweenBounce = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

-- Cleanup
for _, g in pairs(LocalPlayer.PlayerGui:GetChildren()) do
    if g.Name == "NonsenseHub" or g.Name == "NonsenseSplash" then g:Destroy() end
end

-- ‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó
-- ‚ēĎ  ūüéĶ AUDIO SYSTEM - CREATE SOUND OBJECT       ‚ēĎ
-- ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
-- Remove old sounds
for _, s in pairs(SoundService:GetChildren()) do
    if s.Name == "NonsenseMusic" then s:Destroy() end
end
for _, s in pairs(Workspace:GetChildren()) do
    if s.Name == "NonsenseMusic" then s:Destroy() end
end

local musicSound = Instance.new("Sound")
musicSound.Name = "NonsenseMusic"
musicSound.SoundId = MUSIC_ID
musicSound.Volume = DEFAULT_VOLUME
musicSound.Looped = true
musicSound.PlayOnRemove = false

-- Try SoundService first, fallback to Workspace
pcall(function()
    musicSound.Parent = SoundService
end)
if not musicSound.Parent then
    musicSound.Parent = Workspace
end

local musicPlaying = false
local musicVolume = DEFAULT_VOLUME

-- ‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó
-- ‚ēĎ           PART 1: SPLASH SCREEN                         ‚ēĎ
-- ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ

local splashGui = Instance.new("ScreenGui")
splashGui.Name = "NonsenseSplash"
splashGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
splashGui.ResetOnSpawn = false
splashGui.IgnoreGuiInset = true
splashGui.DisplayOrder = 999
splashGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

-- Full Wallpaper BG
local splashBG = Instance.new("ImageLabel", splashGui)
splashBG.BackgroundColor3 = Color3.fromRGB(30, 60, 100)
splashBG.BorderSizePixel = 0
splashBG.Size = UDim2.new(1.15, 0, 1.15, 0)
splashBG.Position = UDim2.new(-0.075, 0, -0.075, 0)
splashBG.Image = WALLPAPER_ID
splashBG.ImageTransparency = 0
splashBG.ScaleType = Enum.ScaleType.Crop
splashBG.ZIndex = 1

local splashOverlay = Instance.new("Frame", splashGui)
splashOverlay.BackgroundColor3 = Color3.fromRGB(5, 10, 25)
splashOverlay.BackgroundTransparency = 0.55
splashOverlay.BorderSizePixel = 0
splashOverlay.Size = UDim2.new(1, 0, 1, 0)
splashOverlay.ZIndex = 2

local oGrad = Instance.new("UIGradient", splashOverlay)
oGrad.Transparency = NumberSequence.new({
    NumberSequenceKeypoint.new(0, 0.7),
    NumberSequenceKeypoint.new(0.4, 0.45),
    NumberSequenceKeypoint.new(1, 0.2)
})
oGrad.Rotation = 180

TweenService:Create(splashBG, TweenInfo.new(10, Enum.EasingStyle.Linear), {
    Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 0, 0)
}):Play()

-- Particles
local partHolder = Instance.new("Frame", splashGui)
partHolder.BackgroundTransparency = 1
partHolder.Size = UDim2.new(1, 0, 1, 0)
partHolder.ZIndex = 3; partHolder.ClipsDescendants = true

for i = 1, 25 do
    local d = Instance.new("Frame", partHolder)
    d.BackgroundColor3 = Color3.fromRGB(200, 225, 255)
    d.BackgroundTransparency = math.random(60, 88)/100
    d.BorderSizePixel = 0
    local s = math.random(2, 6)
    d.Size = UDim2.new(0, s, 0, s)
    d.Position = UDim2.new(math.random(0,100)/100, 0, math.random(0,100)/100, 0)
    d.ZIndex = 3
    Instance.new("UICorner", d).CornerRadius = UDim.new(1, 0)
end

for i = 1, 10 do
    local p = Instance.new("Frame", partHolder)
    p.BackgroundColor3 = Color3.fromRGB(200, 230, 255)
    p.BackgroundTransparency = 0.55; p.BorderSizePixel = 0
    local sz = math.random(4, 9)
    p.Size = UDim2.new(0, sz, 0, sz)
    local sX = math.random(0, 100)/100
    p.Position = UDim2.new(sX, 0, 1.1, 0); p.ZIndex = 3
    Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)

    task.spawn(function()
        task.wait(math.random(0,25)/10)
        while splashGui.Parent do
            p.Position = UDim2.new(sX + math.random(-5,5)/100, 0, 1.1, 0)
            p.BackgroundTransparency = 0.55
            TweenService:Create(p, TweenInfo.new(math.random(7,12), Enum.EasingStyle.Linear), {
                Position = UDim2.new(sX + math.random(-8,8)/100, 0, -0.1, 0),
                BackgroundTransparency = 1
            }):Play()
            task.wait(math.random(7, 12))
        end
    end)
end

-- Center Card
local splashCard = Instance.new("Frame", splashGui)
splashCard.BackgroundColor3 = Color3.fromRGB(15, 28, 55)
splashCard.BackgroundTransparency = 0.3
splashCard.BorderSizePixel = 0
splashCard.Size = UDim2.new(0, 520, 0, 340)
splashCard.Position = UDim2.new(0.5, -260, 0.5, -170)
