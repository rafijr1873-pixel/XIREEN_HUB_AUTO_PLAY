createSection(pages[3], "PLAYERS", 1)

createToggle(pages[3], "👁️ ESP Highlight", false, function(s)
    States.esp = s
    if s then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local hl = Instance.new("Highlight")
                hl.Name = "NonsenseESP"
                hl.FillColor = Color3.fromRGB(255, 50, 50)
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.FillTransparency = 0.5
                hl.Parent = plr.Character

                local head = plr.Character:FindFirstChild("Head")
                if head then
                    local bb = Instance.new("BillboardGui")
                    bb.Name = "NonsenseESPTag"
                    bb.Adornee = head
                    bb.Size = UDim2.new(0, 200, 0, 40)
                    bb.StudsOffset = Vector3.new(0, 2.5, 0)
                    bb.AlwaysOnTop = true
                    bb.Parent = head

                    local nt = Instance.new("TextLabel", bb)
                    nt.BackgroundTransparency = 1
                    nt.Size = UDim2.new(1, 0, 0.5, 0)
                    nt.Font = Enum.Font.GothamBold
                    nt.Text = plr.DisplayName
                    nt.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nt.TextStrokeTransparency = 0
                    nt.TextSize = 14

                    local dt = Instance.new("TextLabel", bb)
                    dt.Name = "Dist"
                    dt.BackgroundTransparency = 1
                    dt.Position = UDim2.new(0, 0, 0.5, 0)
                    dt.Size = UDim2.new(1, 0, 0.5, 0)
                    dt.Font = Enum.Font.Gotham
                    dt.Text = "0m"
                    dt.TextColor3 = Color3.fromRGB(200, 200, 200)
                    dt.TextStrokeTransparency = 0.3
                    dt.TextSize = 12
                end
                espElements[plr] = true
            end
        end
        notify("ESP", "Showing all players", 2)
    else
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Character then
                local hl = plr.Character:FindFirstChild("NonsenseESP"); if hl then hl:Destroy() end
                local head = plr.Character:FindFirstChild("Head")
                if head then local bb = head:FindFirstChild("NonsenseESPTag"); if bb then bb:Destroy() end end
            end
        end
        espElements = {}
        notify("ESP", "Disabled", 2)
    end
end, 3)

createSection(pages[3], "LIGHTING", 5)

createToggle(pages[3], "☀️ Fullbright", false, function(s)
    States.fullbright = s
    if s then
        origLighting.Ambient = Lighting.Ambient
        origLighting.Brightness = Lighting.Brightness
        origLighting.OutdoorAmbient = Lighting.OutdoorAmbient
        Lighting.Ambient = Color3.fromRGB(200, 200, 200)
        Lighting.Brightness = 2
        Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
    else
        Lighting.Ambient = origLighting.Ambient or Color3.fromRGB(127, 127, 127)
        Lighting.Brightness = origLighting.Brightness or 1
        Lighting.OutdoorAmbient = origLighting.OutdoorAmbient or Color3.fromRGB(127, 127, 127)
    end
    notify("Fullbright", s and "Enabled" or "Disabled", 2)
end, 7)

createToggle(pages[3], "🌫️ No Fog", false, function(s)
    States.noFog = s
    if s then
        origLighting.FogEnd = Lighting.FogEnd
        origLighting.FogStart = Lighting.FogStart
        Lighting.FogEnd = 9e9; Lighting.FogStart = 9e9
    else
        Lighting.FogEnd = origLighting.FogEnd or 1e5
        Lighting.FogStart = origLighting.FogStart or 0
    end
    notify("Fog", s and "Removed" or "Restored", 2)
end, 8)

