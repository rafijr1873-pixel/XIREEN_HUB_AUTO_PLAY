mkSec(pages[7], "­Ъјх CUSTOM MUSIC", 1)
mkLbl(pages[7], "  Current: "..CONFIG.MusicID, 3)
mkLbl(pages[7], "  Enter new music ID below (numbers only):", 4)

local musicInput = mkTextInput(pages[7], "Enter Music ID (e.g. 132701552263784)", 5)

mkBtn(pages[7], "РќХ№ИЈ Apply & Play Music ID", function()
    local rawID = musicInput.Text
    if rawID == "" then notify("РЮї", "Enter an ID first!", 2); return end

    -- Clean input - only keep numbers
    local cleanID = rawID:gsub("%D", "")
    if cleanID == "" then notify("РЮї", "Invalid ID! Use numbers only", 2); return end

    local newID = "rbxassetid://" .. cleanID
    musicSound:Stop()
    musicSound.SoundId = newID
    CONFIG.MusicID = newID

    task.wait(0.3)
    musicSound:Play()
    musicPlaying = true
    ppBtn.Text = "РЈИ"
    ppBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 120)
    npLbl.Text = "Playing"
    npLbl.TextColor3 = Color3.fromRGB(180, 140, 255)

    notify("­Ъјх Music", "Now playing ID: " .. cleanID, 3)
end, 6)

mkBtn(pages[7], "РЈИ№ИЈ Pause Music", function()
    musicSound:Pause(); musicPlaying = false; ppBtn.Text = "РќХ"
    npLbl.Text = "Paused"; notify("­Ъјх", "Paused", 2)
end, 7)

