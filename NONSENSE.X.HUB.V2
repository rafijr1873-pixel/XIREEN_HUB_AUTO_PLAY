splashOverlay.ZIndex = 2

-- Gradient overlay (top lighter → bottom darker)
local overlayGrad = Instance.new("UIGradient", splashOverlay)
overlayGrad.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 40, 80)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 0, 0)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 10, 25))
})
overlayGrad.Transparency = NumberSequence.new({
    NumberSequenceKeypoint.new(0, 0.6),
    NumberSequenceKeypoint.new(0.5, 0.3),
    NumberSequenceKeypoint.new(1, 0.1)
})
overlayGrad.Rotation = 180

-- ═══════════════════════════════════════
-- Floating Particles over wallpaper
-- ═══════════════════════════════════════
local particleHolder = Instance.new("Frame", splashGui)
particleHolder.BackgroundTransparency = 1
particleHolder.Size = UDim2.new(1, 0, 1, 0)
particleHolder.ZIndex = 3
particleHolder.ClipsDescendants = true

for i = 1, 40 do
    local dot = Instance.new("Frame", particleHolder)
    dot.BackgroundColor3 = Color3.fromRGB(180, 210, 255)
    dot.BackgroundTransparency = math.random(70, 92) / 100
    dot.BorderSizePixel = 0
    local s = math.random(2, 6)
    dot.Size = UDim2.new(0, s, 0, s)
    dot.Position = UDim2.new(math.random(0, 100)/100, 0, math.random(0, 100)/100, 0)
    dot.ZIndex = 3
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
end

-- Rising mist particles
for i = 1, 15 do
    local p = Instance.new("Frame", particleHolder)
    p.BackgroundColor3 = Color3.fromRGB(180, 220, 255)
    p.BackgroundTransparency = math.random(60, 85) / 100
    p.BorderSizePixel = 0
    local sz = math.random(4, 10)
    p.Size = UDim2.new(0, sz, 0, sz)
    local sX = math.random(0, 100) / 100
    p.Position = UDim2.new(sX, 0, 1.1, 0)
    p.ZIndex = 3
    Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)

    task.spawn(function()
        task.wait(math.random(0, 30) / 10)
        while splashGui.Parent do
            p.Position = UDim2.new(sX + math.random(-5, 5)/100, 0, 1.1, 0)
            p.BackgroundTransparency = 0.6
            TweenService:Create(p, TweenInfo.new(math.random(6, 12), Enum.EasingStyle.Linear), {
                Position = UDim2.new(sX + math.random(-10, 10)/100, 0, -0.1, 0),
                BackgroundTransparency = 1
            }):Play()
            task.wait(math.random(6, 12))
        end
    end)
end

