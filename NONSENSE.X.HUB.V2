-- Mini visualizer bars in title bar
local miniVizCont = Instance.new("Frame", musicCont)
miniVizCont.BackgroundTransparency = 1
miniVizCont.Position = UDim2.new(0, 94, 0.5, -8)
miniVizCont.Size = UDim2.new(0, 32, 0, 16)
miniVizCont.ZIndex = 13

local miniVizBars = {}
for i = 1, 5 do
    local mb = Instance.new("Frame", miniVizCont)
    mb.BackgroundColor3 = Color3.fromRGB(150, 100, 255)
    mb.BorderSizePixel = 0
    mb.Size = UDim2.new(0, 4, 0, 3)
    mb.Position = UDim2.new(0, (i-1)*6, 1, -3)
    mb.ZIndex = 14
    Instance.new("UICorner", mb).CornerRadius = UDim.new(0, 1)

    Instance.new("UIGradient", mb).Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 180, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 100, 255))
    })

    miniVizBars[i] = mb
end

-- Animate mini viz bars
task.spawn(function()
    while screenGui.Parent do
        if musicPlaying then
            for i, mb in ipairs(miniVizBars) do
                local h = math.random(3, 14)
                TweenService:Create(mb, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {
                    Size = UDim2.new(0, 4, 0, h),
                    Position = UDim2.new(0, (i-1)*6, 1, -h)
                }):Play()
            end
        else
            for i, mb in ipairs(miniVizBars) do
                TweenService:Create(mb, TweenInfo.new(0.3), {
                    Size = UDim2.new(0, 4, 0, 2),
                    Position = UDim2.new(0, (i-1)*6, 1, -2)
                }):Play()
            end
        end
        task.wait(0.12)
    end
end)

