cardWP.ScaleType = Enum.ScaleType.Crop; cardWP.ZIndex = 10
Instance.new("UICorner", cardWP).CornerRadius = UDim.new(0, 16)

local cShadow = Instance.new("ImageLabel", splashCard)
cShadow.BackgroundTransparency = 1
cShadow.Position = UDim2.new(0, -22, 0, -22)
cShadow.Size = UDim2.new(1, 44, 1, 44)
cShadow.ZIndex = 9; cShadow.Image = "rbxassetid://5554236805"
cShadow.ImageColor3 = Color3.fromRGB(20, 50, 130)
cShadow.ImageTransparency = 0.6
