-- в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—
-- в•‘                        SERVICES                             в•‘
-- в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local StarterGui = game:GetService("StarterGui")
local TeleportService = game:GetService("TeleportService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

-- Tween Presets
local tweenFast = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tweenSmooth = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local tweenBounce = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

-- Cleanup old
for _, g in pairs(LocalPlayer.PlayerGui:GetChildren()) do
    if g.Name == "NonsenseHub" or g.Name == "NonsenseSplash" then
        g:Destroy()
    end
end

-- в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—
-- в•‘              PART 1: SPLASH / THUMBNAIL SCREEN              в•‘
-- в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ

local splashGui = Instance.new("ScreenGui")
splashGui.Name = "NonsenseSplash"
splashGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
splashGui.ResetOnSpawn = false
splashGui.IgnoreGuiInset = true
splashGui.DisplayOrder = 999
splashGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Background
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local splashBG = Instance.new("Frame", splashGui)
splashBG.Name = "BG"
splashBG.BackgroundColor3 = Color3.fromRGB(8, 8, 18)
splashBG.BorderSizePixel = 0
splashBG.Size = UDim2.new(1, 0, 1, 0)
splashBG.ZIndex = 1

local splashBGGrad = Instance.new("UIGradient", splashBG)
splashBGGrad.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(5, 5, 20)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(12, 12, 35)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 5, 15))
})
splashBGGrad.Rotation = 135

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Floating Particles
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local particleHolder = Instance.new("Frame", splashBG)
particleHolder.BackgroundTransparency = 1
particleHolder.Size = UDim2.new(1, 0, 1, 0)
particleHolder.ZIndex = 2
particleHolder.ClipsDescendants = true

-- Grid dots
for i = 1, 50 do
    local dot = Instance.new("Frame", particleHolder)
    dot.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
    dot.BackgroundTransparency = math.random(75, 95) / 100
    dot.BorderSizePixel = 0
    local s = math.random(2, 5)
    dot.Size = UDim2.new(0, s, 0, s)
    dot.Position = UDim2.new(math.random(0, 100)/100, 0, math.random(0, 100)/100, 0)
    dot.ZIndex = 2
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
end

-- Rising particles
for i = 1, 20 do
    local p = Instance.new("Frame", particleHolder)
    p.BackgroundColor3 = i % 3 == 0 and Color3.fromRGB(160, 80, 255)
        or i % 2 == 0 and Color3.fromRGB(80, 200, 255)
        or Color3.fromRGB(60, 130, 255)
    p.BackgroundTransparency = math.random(50, 80) / 100
    p.BorderSizePixel = 0
    local sz = math.random(3, 7)
    p.Size = UDim2.new(0, sz, 0, sz)
    local sX = math.random(0, 100) / 100
    p.Position = UDim2.new(sX, 0, 1.1, 0)
    p.ZIndex = 2
    Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)

    task.spawn(function()
        task.wait(math.random(0, 25) / 10)
        while splashGui.Parent do
            p.Position = UDim2.new(sX + math.random(-5, 5)/100, 0, 1.1, 0)
            p.BackgroundTransparency = 0.7
            TweenService:Create(p, TweenInfo.new(math.random(5, 9), Enum.EasingStyle.Linear), {
                Position = UDim2.new(sX + math.random(-8, 8)/100, 0, -0.1, 0),
                BackgroundTransparency = 1
            }):Play()
            task.wait(math.random(5, 9))
        end
    end)
end

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Glow Orbs
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local function makeGlowOrb(px, py, col, sz)
    local orb = Instance.new("ImageLabel", splashBG)
    orb.BackgroundTransparency = 1
    orb.Position = UDim2.new(px, -sz/2, py, -sz/2)
    orb.Size = UDim2.new(0, sz, 0, sz)
    orb.Image = "rbxassetid://5554236805"
    orb.ImageColor3 = col
    orb.ImageTransparency = 0.65
    orb.ZIndex = 2
    return orb
end

local orbB = makeGlowOrb(0.2, 0.35, Color3.fromRGB(30, 80, 255), 500)
local orbP = makeGlowOrb(0.8, 0.6, Color3.fromRGB(120, 40, 200), 400)
local orbC = makeGlowOrb(0.5, 0.85, Color3.fromRGB(0, 180, 255), 350)

-- Orb breathing
task.spawn(function()
    while splashGui.Parent do
        local t = tick()
        TweenService:Create(orbB, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            ImageTransparency = 0.55 + math.sin(t) * 0.15
        }):Play()
        TweenService:Create(orbP, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            ImageTransparency = 0.6 + math.cos(t * 0.8) * 0.15
        }):Play()
        task.wait(3)
    end
end)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Center Card
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local splashCard = Instance.new("Frame", splashGui)
splashCard.Name = "Card"
splashCard.BackgroundColor3 = Color3.fromRGB(18, 18, 30)
splashCard.BackgroundTransparency = 0.15
splashCard.BorderSizePixel = 0
splashCard.Size = UDim2.new(0, 520, 0, 340)
splashCard.Position = UDim2.new(0.5, -260, 0.5, -170)
splashCard.ZIndex = 10

Instance.new("UICorner", splashCard).CornerRadius = UDim.new(0, 18)

local splashCardStroke = Instance.new("UIStroke", splashCard)
splashCardStroke.Color = Color3.fromRGB(70, 130, 255)
splashCardStroke.Thickness = 2
splashCardStroke.Transparency = 0.3

Instance.new("UIGradient", splashCard).Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(25, 25, 45)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(18, 18, 35)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(12, 12, 25))
})

-- Card shadow
local cShadow = Instance.new("ImageLabel", splashCard)
cShadow.BackgroundTransparency = 1
cShadow.Position = UDim2.new(0, -25, 0, -25)
cShadow.Size = UDim2.new(1, 50, 1, 50)
cShadow.ZIndex = 9
cShadow.Image = "rbxassetid://5554236805"
cShadow.ImageColor3 = Color3.fromRGB(30, 60, 180)
cShadow.ImageTransparency = 0.75
cShadow.ScaleType = Enum.ScaleType.Slice
cShadow.SliceCenter = Rect.new(23, 23, 277, 277)

-- Corner decorations
local function cornerDeco(px, py, sx, sy, col)
    local c = Instance.new("Frame", splashCard)
    c.BackgroundColor3 = col
    c.BorderSizePixel = 0
    c.Size = UDim2.new(0, sx, 0, sy)
    c.Position = UDim2.new(px, 0, py, 0)
    c.ZIndex = 15
    return c
end
cornerDeco(0, 0, 40, 2, Color3.fromRGB(60, 120, 255))
cornerDeco(0, 0, 2, 40, Color3.fromRGB(60, 120, 255))
cornerDeco(1, 1, 40, 2, Color3.fromRGB(140, 70, 255)).Position = UDim2.new(1, -40, 1, -2)
cornerDeco(1, 1, 2, 40, Color3.fromRGB(140, 70, 255)).Position = UDim2.new(1, -2, 1, -40)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Logo
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
local logoCont = Instance.new("Frame", splashCard)
logoCont.BackgroundTransparency = 1
logoCont.Size = UDim2.new(0, 90, 0, 90)
logoCont.Position = UDim2.new(0.5, -45, 0, 25)
logoCont.ZIndex = 12

local outerRing = Instance.new("Frame", logoCont)
outerRing.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
outerRing.BackgroundTransparency = 0.7
outerRing.Size = UDim2.new(1, 0, 1, 0)
outerRing.ZIndex = 12
Instance.new("UICorner", outerRing).CornerRadius = UDim.new(1, 0)

local outerS = Instance.new("UIStroke", outerRing)
outerS.Color = Color3.fromRGB(80, 150, 255)
outerS.Thickness = 3
outerS.Transparency = 0.2

Instance.new("UIGradient", outerRing).Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 120, 255)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(150, 80, 255)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 120, 255))
})

local innerRing = Instance.new("Frame", logoCont)
innerRing.BackgroundColor3 = Color3.fromRGB(15, 15, 30)
innerRing.Size = UDim2.new(0.72, 0, 0.72, 0)
innerRing.Position = UDim2.new(0.14, 0, 0.14, 0)
innerRing.ZIndex = 13
Instance.new("UICorner", innerRing).CornerRadius = UDim.new(1, 0)
