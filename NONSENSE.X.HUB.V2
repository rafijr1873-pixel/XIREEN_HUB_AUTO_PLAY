-- Volume slider interaction
local volDragging = false
volBG.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        volDragging = true
        local rel = math.clamp((i.Position.X - volBG.AbsolutePosition.X) / volBG.AbsoluteSize.X, 0, 1)
        musicVolume = rel; musicSound.Volume = rel
        volFill.Size = UDim2.new(rel, 0, 1, 0)
        volIcon.Text = rel > 0.5 and "ūüĒä" or rel > 0.1 and "ūüĒČ" or "ūüĒą"
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if volDragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local rel = math.clamp((i.Position.X - volBG.AbsolutePosition.X) / volBG.AbsoluteSize.X, 0, 1)
        musicVolume = rel; musicSound.Volume = rel
        volFill.Size = UDim2.new(rel, 0, 1, 0)
        volIcon.Text = rel > 0.5 and "ūüĒä" or rel > 0.1 and "ūüĒČ" or "ūüĒą"
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        volDragging = false
    end
end)

-- Play/Pause logic
playPauseBtn.MouseButton1Click:Connect(function()
    if musicPlaying then
        musicSound:Pause()
        musicPlaying = false
        playPauseBtn.Text = "‚Ė∂"
        playPauseBtn.BackgroundColor3 = Color3.fromRGB(80, 160, 255)
        nowPlayingLbl.Text = "Paused"
        nowPlayingLbl.TextColor3 = Color3.fromRGB(150, 170, 200)
        TweenService:Create(mcStroke, tweenFast, {Color = Color3.fromRGB(80, 80, 100)}):Play()
    else
        musicSound:Resume()
        musicPlaying = true
        playPauseBtn.Text = "‚Źł"
        playPauseBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 120)
        nowPlayingLbl.Text = "Playing"
        nowPlayingLbl.TextColor3 = Color3.fromRGB(180, 140, 255)
        TweenService:Create(mcStroke, tweenFast, {Color = Color3.fromRGB(120, 80, 255)}):Play()
    end
end)

playPauseBtn.MouseEnter:Connect(function() TweenService:Create(playPauseBtn, tweenFast, {BackgroundTransparency = 0.05}):Play() end)
playPauseBtn.MouseLeave:Connect(function() TweenService:Create(playPauseBtn, tweenFast, {BackgroundTransparency = 0.3}):Play() end)

-- Stop logic
stopBtn.MouseButton1Click:Connect(function()
    musicSound:Stop()
    musicPlaying = false
    playPauseBtn.Text = "‚Ė∂"
    playPauseBtn.BackgroundColor3 = Color3.fromRGB(80, 160, 255)
    nowPlayingLbl.Text = "Stopped"
    nowPlayingLbl.TextColor3 = Color3.fromRGB(120, 130, 155)
    TweenService:Create(mcStroke, tweenFast, {Color = Color3.fromRGB(60, 60, 80)}):Play()
end)

stopBtn.MouseEnter:Connect(function() TweenService:Create(stopBtn, tweenFast, {BackgroundTransparency = 0.1}):Play() end)
stopBtn.MouseLeave:Connect(function() TweenService:Create(stopBtn, tweenFast, {BackgroundTransparency = 0.4}):Play() end)

-- Music icon bounce animation
task.spawn(function()
    while screenGui.Parent do
        if musicPlaying then
            TweenService:Create(musicIcon, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Rotation = 15
            }):Play(); task.wait(0.4)
            TweenService:Create(musicIcon, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Rotation = -15
            }):Play(); task.wait(0.4)
        else
            TweenService:Create(musicIcon, TweenInfo.new(0.3), {Rotation = 0}):Play()
            task.wait(0.8)
        end
    end
end)

-- Music stroke pulse when playing
task.spawn(function()
    while screenGui.Parent do
        if musicPlaying then
            TweenService:Create(mcStroke, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Color = Color3.fromRGB(150, 100, 255), Transparency = 0.3
            }):Play(); task.wait(1)
            TweenService:Create(mcStroke, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Color = Color3.fromRGB(80, 180, 255), Transparency = 0.5
            }):Play(); task.wait(1)
        else task.wait(0.5) end
    end
end)

