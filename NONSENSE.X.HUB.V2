createLabel(pages[7], "  Press RightShift to toggle GUI", 3)
createLabel(pages[7], "  Drag top bar to move window", 4)

createButton(pages[7], "рҹ—‘пёҸ Destroy GUI", function()
    notify("Goodbye", "Destroying Nonsense Hub...", 1)
    task.wait(1.2); screenGui:Destroy()
end, 5)

createSection(pages[7], "RESET", 7)

createButton(pages[7], "вҷ»пёҸ Reset All Features", function()
    States.speed = false; States.noclip = false; States.fly = false
    States.infiniteJump = false; States.esp = false; States.fullbright = false
    States.noFog = false; States.godMode = false; States.clickTP = false
    States.autoClick = false; States.antiAFK = false; States.noFallDmg = false

    if flyBV then flyBV:Destroy(); flyBV = nil end
    if flyBG then flyBG:Destroy(); flyBG = nil end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Character then
            local hl = plr.Character:FindFirstChild("NonsenseESP"); if hl then hl:Destroy() end
            local head = plr.Character:FindFirstChild("Head")
            if head then local bb = head:FindFirstChild("NonsenseESPTag"); if bb then bb:Destroy() end end
        end
    end
    espElements = {}

    local h = getHumanoid()
    if h then h.WalkSpeed = 16; h.JumpPower = 50; h.UseJumpPower = true end

    Lighting.Ambient = origLighting.Ambient or Color3.fromRGB(127, 127, 127)
    Lighting.Brightness = origLighting.Brightness or 1
    Lighting.OutdoorAmbient = origLighting.OutdoorAmbient or Color3.fromRGB(127, 127, 127)
    Lighting.FogEnd = origLighting.FogEnd or 1e5; Lighting.FogStart = origLighting.FogStart or 0

    Camera.FieldOfView = 70; Workspace.Gravity = 196.2

    if antiAFKConn then antiAFKConn:Disconnect(); antiAFKConn = nil end
    notify("Reset", "All features reset!", 3)
end, 9)

createSection(pages[7], "CREDITS", 11)
createLabel(pages[7], "  рҹҢҖ Nonsense Hub v2.0", 13)
createLabel(pages[7], "  Made with вқӨпёҸ for Roblox", 14)
