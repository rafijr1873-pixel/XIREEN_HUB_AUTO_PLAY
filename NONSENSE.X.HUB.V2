-- Corner accents
local function cLine(parent, px, py, sx, sy, col)
    local f = Instance.new("Frame", parent)
    f.BackgroundColor3 = col
    f.BackgroundTransparency = 0.2
    f.BorderSizePixel = 0
    f.Size = UDim2.new(0, sx, 0, sy)
    f.Position = UDim2.new(px, 0, py, 0)
    f.ZIndex = 16
    return f
end
