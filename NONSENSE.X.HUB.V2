-- PAGE 4: рҹҢҚ TELEPORT
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
createSection(pages[4], "QUICK TP", 1)

createToggle(pages[4], "рҹ“Қ Click TP (Ctrl+Click)", false, function(s)
    States.clickTP = s
    notify("Click TP", s and "Ctrl + Left Click" or "Disabled", 2)
end, 3)

createButton(pages[4], "рҹҺҜ TP to Mouse", function()
    local hrp = getHRP()
    if hrp then
        hrp.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0, 3, 0))
        notify("Teleport", "Teleported to cursor", 2)
    end
end, 4)

createSection(pages[4], "PLAYERS", 6)

local playerBtns = {}
local function refreshPlayerList()
    for _, b in pairs(playerBtns) do if b and b.Parent then b:Destroy() end end
    playerBtns = {}
    local ord = 8
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            ord += 1
            local b = createButton(pages[4], "рҹ“Қ " .. plr.DisplayName, function()
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = getHRP()
                    if hrp then
                        hrp.CFrame = plr.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                        notify("Teleport", "Went to " .. plr.DisplayName, 2)
                    end
                end
            end, ord)
            table.insert(playerBtns, b)
        end
    end
end

createButton(pages[4], "рҹ”„ Refresh Players", function()
    refreshPlayerList(); notify("Teleport", "Refreshed", 2)
end, 7)

refreshPlayerList()

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
