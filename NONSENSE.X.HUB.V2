-- тХРтХРтХР Notification System тХРтХРтХР
local notifY = 0
local function notify(title, text, duration)
    duration = duration or 3
    local n = Instance.new("Frame", screenGui)
    n.BackgroundColor3 = Color3.fromRGB(12, 22, 45)
    n.BorderSizePixel = 0
    n.Size = UDim2.new(0, 250, 0, 58)
    n.Position = UDim2.new(1, 10, 1, -68 - notifY)
    n.ZIndex = 50; n.ClipsDescendants = true
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 10)
    local ns = Instance.new("UIStroke", n); ns.Color = Color3.fromRGB(90, 170, 255); ns.Transparency = 0.4

    -- Wallpaper in notif
    local nWP = Instance.new("ImageLabel", n)
    nWP.BackgroundTransparency = 1; nWP.Size = UDim2.new(1, 0, 1, 0)
    nWP.Image = WALLPAPER_ID; nWP.ImageTransparency = 0.85
    nWP.ScaleType = Enum.ScaleType.Crop; nWP.ZIndex = 50
    Instance.new("UICorner", nWP).CornerRadius = UDim.new(0, 10)

    local nAcc = Instance.new("Frame", n)
    nAcc.BackgroundColor3 = Color3.fromRGB(90, 180, 255)
    nAcc.BorderSizePixel = 0; nAcc.Size = UDim2.new(0, 3, 1, 0); nAcc.ZIndex = 51

    local nTi = Instance.new("TextLabel", n)
    nTi.BackgroundTransparency = 1; nTi.Position = UDim2.new(0, 12, 0, 5)
    nTi.Size = UDim2.new(1, -16, 0, 16); nTi.Font = Enum.Font.GothamBold
    nTi.Text = title; nTi.TextColor3 = Color3.fromRGB(120, 195, 255)
    nTi.TextSize = 12; nTi.TextXAlignment = Enum.TextXAlignment.Left; nTi.ZIndex = 51

    local nDe = Instance.new("TextLabel", n)
    nDe.BackgroundTransparency = 1; nDe.Position = UDim2.new(0, 12, 0, 22)
    nDe.Size = UDim2.new(1, -16, 0, 30); nDe.Font = Enum.Font.Gotham
    nDe.Text = text; nDe.TextColor3 = Color3.fromRGB(190, 210, 240)
    nDe.TextSize = 11; nDe.TextXAlignment = Enum.TextXAlignment.Left
    nDe.TextWrapped = true; nDe.ZIndex = 51

    local yOff = notifY; notifY += 64
    TweenService:Create(n, tweenSmooth, {Position = UDim2.new(1, -260, 1, -68 - yOff)}):Play()

    task.delay(duration, function()
        TweenService:Create(n, tweenSmooth, {Position = UDim2.new(1, 10, 1, -68 - yOff)}):Play()
        task.delay(0.5, function() n:Destroy(); notifY = math.max(0, notifY - 64) end)
    end)
end

-- тХРтХРтХР UI Builders тХРтХРтХР
local function createPage(name)
    local page = Instance.new("ScrollingFrame", contentArea)
    page.Name = "Page_"..name
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.Position = UDim2.new(0, 0, 0, 40)
    page.Size = UDim2.new(1, 0, 1, -40)
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Color3.fromRGB(90, 170, 255)
    page.ScrollBarImageTransparency = 0.3
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false; page.ZIndex = 6

    local l = Instance.new("UIListLayout", page)
    l.Padding = UDim.new(0, 5); l.SortOrder = Enum.SortOrder.LayoutOrder

    local pd = Instance.new("UIPadding", page)
    pd.PaddingTop = UDim.new(0, 4); pd.PaddingBottom = UDim.new(0, 8)
    pd.PaddingLeft = UDim.new(0, 10); pd.PaddingRight = UDim.new(0, 12)
    return page
end

local function createSection(parent, text, order)
    local lbl = Instance.new("TextLabel", parent)
    lbl.BackgroundTransparency = 1; lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Font = Enum.Font.GothamBold; lbl.Text = "  "..text
    lbl.TextColor3 = Color3.fromRGB(110, 195, 255)
    lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.LayoutOrder = order; lbl.ZIndex = 7

    local sep = Instance.new("Frame", parent)
    sep.BackgroundColor3 = Color3.fromRGB(50, 80, 130)
    sep.BackgroundTransparency = 0.4
    sep.BorderSizePixel = 0; sep.Size = UDim2.new(1, 0, 0, 1)
    sep.LayoutOrder = order + 1; sep.ZIndex = 7
end

local function createToggle(parent, text, default, callback, order)
    local toggled = default or false
    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = Color3.fromRGB(15, 28, 55)
    btn.BackgroundTransparency = 0.2
    btn.BorderSizePixel = 0; btn.Size = UDim2.new(1, 0, 0, 34)
    btn.Text = ""; btn.AutoButtonColor = false
    btn.LayoutOrder = order; btn.ZIndex = 7
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(45, 70, 110)
    stroke.Thickness = 1; stroke.Transparency = 0.3

    local lbl = Instance.new("TextLabel", btn)
    lbl.BackgroundTransparency = 1; lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.Size = UDim2.new(0.65, 0, 1, 0); lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text; lbl.TextColor3 = Color3.fromRGB(200, 220, 245)
    lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 8

    local ind = Instance.new("Frame", btn)
    ind.BackgroundColor3 = toggled and Color3.fromRGB(50, 190, 120) or Color3.fromRGB(40, 55, 90)
    ind.BorderSizePixel = 0; ind.Size = UDim2.new(0, 34, 0, 17)
    ind.Position = UDim2.new(1, -46, 0.5, -8); ind.ZIndex = 8
    Instance.new("UICorner", ind).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", ind)
    circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    circle.BorderSizePixel = 0; circle.Size = UDim2.new(0, 13, 0, 13)
    circle.Position = toggled and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
    circle.ZIndex = 9
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local function refresh()
        if toggled then
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(50, 190, 120)}):Play()
            TweenService:Create(circle, tweenFast, {Position = UDim2.new(1, -15, 0.5, -6)}):Play()
            TweenService:Create(stroke, tweenFast, {Color = Color3.fromRGB(50, 190, 120), Transparency = 0.2}):Play()
        else
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(40, 55, 90)}):Play()
            TweenService:Create(circle, tweenFast, {Position = UDim2.new(0, 2, 0.5, -6)}):Play()
            TweenService:Create(stroke, tweenFast, {Color = Color3.fromRGB(45, 70, 110), Transparency = 0.3}):Play()
        end
    end

    btn.MouseButton1Click:Connect(function()
        toggled = not toggled; refresh(); callback(toggled)
    end)
    btn.MouseEnter:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.05}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.2}):Play() end)

    if toggled then refresh(); callback(true) end
    return btn
end

local function createSlider(parent, text, min, max, default, callback, order)
    local value = default or min
    local c = Instance.new("Frame", parent)
    c.BackgroundColor3 = Color3.fromRGB(15, 28, 55); c.BackgroundTransparency = 0.2
    c.BorderSizePixel = 0; c.Size = UDim2.new(1, 0, 0, 50)
    c.LayoutOrder = order; c.ZIndex = 7
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", c).Color = Color3.fromRGB(45, 70, 110)

    local lbl = Instance.new("TextLabel", c)
    lbl.BackgroundTransparency = 1; lbl.Position = UDim2.new(0, 12, 0, 2)
    lbl.Size = UDim2.new(0.55, 0, 0, 20); lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text; lbl.TextColor3 = Color3.fromRGB(200, 220, 245)
    lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 8

    local vL = Instance.new("TextLabel", c)
    vL.BackgroundTransparency = 1; vL.Position = UDim2.new(0.6, 0, 0, 2)
    vL.Size = UDim2.new(0.35, 0, 0, 20); vL.Font = Enum.Font.GothamBold
    vL.Text = tostring(value); vL.TextColor3 = Color3.fromRGB(110, 195, 255)
    vL.TextSize = 12; vL.TextXAlignment = Enum.TextXAlignment.Right; vL.ZIndex = 8

    local bg = Instance.new("Frame", c)
    bg.BackgroundColor3 = Color3.fromRGB(10, 18, 35); bg.BorderSizePixel = 0
    bg.Position = UDim2.new(0, 12, 0, 28); bg.Size = UDim2.new(1, -24, 0, 6); bg.ZIndex = 8
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", bg)
    fill.BackgroundColor3 = Color3.fromRGB(80, 170, 255); fill.BorderSizePixel = 0
    fill.Size = UDim2.new((value-min)/(max-min), 0, 1, 0); fill.ZIndex = 9
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    Instance.new("UIGradient", fill).Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 140, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(130, 220, 255))
    })

    local knob = Instance.new("Frame", bg)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255); knob.BorderSizePixel = 0
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new((value-min)/(max-min), -7, 0.5, -7); knob.ZIndex = 10
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local isDragging = false
    local function update(pos)
        local rel = math.clamp((pos.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max-min)*rel)
        vL.Text = tostring(value)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -7, 0.5, -7)
        callback(value)
    end

    bg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDragging = true; update(i.Position) end end)
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDragging = true end end)
    UserInputService.InputChanged:Connect(function(i) if isDragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDragging = false end end)
    return c
end

local function createButton(parent, text, callback, order)
    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = Color3.fromRGB(40, 95, 210); btn.BackgroundTransparency = 0.15
    btn.BorderSizePixel = 0; btn.Size = UDim2.new(1, 0, 0, 32)
    btn.Font = Enum.Font.GothamMedium; btn.Text = text
    btn.TextColor3 = Color3.fromRGB(225, 240, 255); btn.TextSize = 12
    btn.AutoButtonColor = false; btn.LayoutOrder = order; btn.ZIndex = 7
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(callback)
    btn.MouseEnter:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
    return btn
end

local function createLabel(parent, text, order)
    local lbl = Instance.new("TextLabel", parent)
    lbl.BackgroundTransparency = 1; lbl.Size = UDim2.new(1, 0, 0, 18)
    lbl.Font = Enum.Font.Gotham; lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(140, 170, 210)
    lbl.TextSize = 11; lbl.TextWrapped = true
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.LayoutOrder = order; lbl.ZIndex = 7
    return lbl
end

-- тХРтХРтХР TAB SYSTEM (тЬЕ Now inside clean sidebar) тХРтХРтХР
local tabNames = {"ЁЯПа Main", "тЪФя╕П Combat", "ЁЯСБя╕П Visuals", "ЁЯМН Teleport", "ЁЯОо Player", "ЁЯФз Misc", "тЪЩя╕П Settings"}
local tabBtns = {}
local pages = {}

for i, name in ipairs(tabNames) do
    local tab = Instance.new("TextButton", sidebar) -- тЬЕ Inside sidebar (no ImageLabel conflict)
    tab.Name = "Tab_"..i
    tab.BackgroundColor3 = (i == 1) and Color3.fromRGB(50, 115, 235) or Color3.fromRGB(18, 30, 55)
    tab.BackgroundTransparency = (i == 1) and 0.1 or 0.3
    tab.BorderSizePixel = 0
    tab.Size = UDim2.new(1, 0, 0, 32) -- тЬЕ Sedikit lebih besar
    tab.Font = (i == 1) and Enum.Font.GothamSemibold or Enum.Font.Gotham
    tab.Text = name
    tab.TextColor3 = (i == 1) and Color3.fromRGB(230, 245, 255) or Color3.fromRGB(140, 160, 195)
    tab.TextSize = 11
    tab.AutoButtonColor = false
    tab.LayoutOrder = i
    tab.ZIndex = 6
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 8)
    tabBtns[i] = tab
end

for i in ipairs(tabNames) do
    pages[i] = createPage(tabNames[i])
    if i == 1 then pages[i].Visible = true end
end

-- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
-- PAGE 1: ЁЯПа MAIN
-- тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
createSection(pages[1], "MOVEMENT", 1)
createToggle(pages[1], "тЪб Speed Hack", false, function(s)
    States.speed = s
    if not s then local h = getHumanoid(); if h then h.WalkSpeed = 16 end end
    notify("Speed", s and "Enabled" or "Disabled", 2)
end, 3)
createSlider(pages[1], "Walk Speed", 16, 500, 16, function(v) States.walkSpeed = v end, 4)
createToggle(pages[1], "ЁЯжШ Infinite Jump", false, function(s)
    States.infiniteJump = s; notify("Infinite Jump", s and "Enabled" or "Disabled", 2)
end, 5)
createToggle(pages[1], "ЁЯС╗ Noclip", false, function(s)
    States.noclip = s; notify("Noclip", s and "Walk through walls!" or "Disabled", 2)
end, 6)

createSection(pages[1], "FLIGHT (FlyGuiV3)", 7)
createButton(pages[1], "ЁЯХКя╕П Load FlyGuiV3 (Press E to Fly)", function()
    if not States.flyLoaded then
        States.flyLoaded = true
        notify("ЁЯХКя╕П FlyGuiV3", "Loading... Press E to toggle fly!", 4)
        task.spawn(function()
            local ok, err = pcall(function()
                loadstring(game:HttpGet(FLY_SCRIPT_URL))()
            end)
            if ok then notify("ЁЯХКя╕П FlyGuiV3", "Loaded! Press E to fly!", 5)
            else notify("тЭМ Error", tostring(err), 4); States.flyLoaded = false end
        end)
    else notify("ЁЯХКя╕П FlyGuiV3", "Already loaded! Press E", 3) end
end, 9)
createLabel(pages[1], "  тД╣я╕П Press E = toggle fly | WASD = move", 10)
createLabel(pages[1], "  тД╣я╕П Space = up | Shift = down", 11)

-- тХРтХРтХР PAGE 2: тЪФя╕П COMBAT тХРтХРтХР
createSection(pages[2], "AUTO", 1)
createToggle(pages[2], "ЁЯЦ▒я╕П Auto Click (Tool)", false, function(s)
    States.autoClick = s; notify("Auto Click", s and "Equip a tool!" or "Disabled", 2)
end, 3)
createSlider(pages[2], "Click Delay (ms)", 50, 1000, 100, function(v) States.clickDelay = v end, 4)
createSection(pages[2], "REACH", 5)
createToggle(pages[2], "ЁЯЧбя╕П Extended Reach", false, function(s)
    local ch = LocalPlayer.Character
    if ch then for _, t in pairs(ch:GetChildren()) do
        if t:IsA("Tool") then local h = t:FindFirstChild("Handle")
            if h then h.Size = s and Vector3.new(1,1,50) or Vector3.new(1,1,1); h.Transparency = s and 0.8 or 0; h.Massless = true end
        end
    end end
    notify("Reach", s and "Extended!" or "Normal", 2)
end, 7)
createLabel(pages[2], "  тЪая╕П Combat depends on game type", 9)

-- тХРтХРтХР PAGE 3: ЁЯСБя╕П VISUALS тХРтХРтХР
createSection(pages[3], "PLAYERS", 1)
createToggle(pages[3], "ЁЯСБя╕П ESP Highlight", false, function(s)
    States.esp = s
    if s then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local hl = Instance.new("Highlight"); hl.Name = "NESP"
                hl.FillColor = Color3.fromRGB(255,50,50); hl.OutlineColor = Color3.fromRGB(255,255,255)
                hl.FillTransparency = 0.5; hl.Parent = plr.Character
                local head = plr.Character:FindFirstChild("Head")
                if head then
                    local bb = Instance.new("BillboardGui"); bb.Name = "NESPTag"
                    bb.Adornee = head; bb.Size = UDim2.new(0,200,0,40)
                    bb.StudsOffset = Vector3.new(0,2.5,0); bb.AlwaysOnTop = true; bb.Parent = head
                    local nt = Instance.new("TextLabel", bb); nt.BackgroundTransparency = 1
                    nt.Size = UDim2.new(1,0,0.5,0); nt.Font = Enum.Font.GothamBold
                    nt.Text = plr.DisplayName; nt.TextColor3 = Color3.new(1,1,1)
                    nt.TextStrokeTransparency = 0; nt.TextSize = 14
                    local dt = Instance.new("TextLabel", bb); dt.Name = "Dist"
                    dt.BackgroundTransparency = 1; dt.Position = UDim2.new(0,0,0.5,0)
                    dt.Size = UDim2.new(1,0,0.5,0); dt.Font = Enum.Font.Gotham
                    dt.Text = "0m"; dt.TextColor3 = Color3.fromRGB(200,200,200)
                    dt.TextStrokeTransparency = 0.3; dt.TextSize = 12
                end; espElements[plr] = true
            end
        end; notify("ESP", "Showing all players", 2)
    else
        for _, plr in pairs(Players:GetPlayers()) do if plr.Character then
            local hl = plr.Character:FindFirstChild("NESP"); if hl then hl:Destroy() end
            local h = plr.Character:FindFirstChild("Head"); if h then local bb = h:FindFirstChild("NESPTag"); if bb then bb:Destroy() end end
        end end; espElements = {}; notify("ESP", "Disabled", 2)
    end
end, 3)
createSection(pages[3], "LIGHTING", 5)
createToggle(pages[3], "тШАя╕П Fullbright", false, function(s)
    States.fullbright = s
    if s then
        origLighting.Ambient = Lighting.Ambient; origLighting.Brightness = Lighting.Brightness
        origLighting.OutdoorAmbient = Lighting.OutdoorAmbient
        Lighting.Ambient = Color3.fromRGB(200,200,200); Lighting.Brightness = 2
        Lighting.OutdoorAmbient = Color3.fromRGB(200,200,200)
    else
        Lighting.Ambient = origLighting.Ambient or Color3.fromRGB(127,127,127)
        Lighting.Brightness = origLighting.Brightness or 1
        Lighting.OutdoorAmbient = origLighting.OutdoorAmbient or Color3.fromRGB(127,127,127)
    end; notify("Fullbright", s and "Enabled" or "Disabled", 2)
end, 7)
createToggle(pages[3], "ЁЯМля╕П No Fog", false, function(s)
    States.noFog = s
    if s then origLighting.FogEnd = Lighting.FogEnd; origLighting.FogStart = Lighting.FogStart
        Lighting.FogEnd = 9e9; Lighting.FogStart = 9e9
    else Lighting.FogEnd = origLighting.FogEnd or 1e5; Lighting.FogStart = origLighting.FogStart or 0 end
    notify("Fog", s and "Removed" or "Restored", 2)
end, 8)
createSection(pages[3], "CAMERA", 10)
createSlider(pages[3], "Field of View", 30, 120, 70, function(v)
    States.fov = v; Camera.FieldOfView = v
end, 12)
createSection(pages[3], "CLEANUP", 14)
createButton(pages[3], "ЁЯЧСя╕П Remove Particles", function()
    local c = 0; for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Trail") then v.Enabled = false; c += 1 end
    end; notify("Cleanup", c.." effects disabled", 2)
end, 16)
createButton(pages[3], "ЁЯЦ╝я╕П Remove Decals", function()
    local c = 0; for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 1; c += 1 end
    end; notify("Cleanup", c.." decals hidden", 2)
end, 17)

-- тХРтХРтХР PAGE 4: ЁЯМН TELEPORT тХРтХРтХР
createSection(pages[4], "QUICK TP", 1)
createToggle(pages[4], "ЁЯУН Click TP (Ctrl+Click)", false, function(s)
    States.clickTP = s; notify("Click TP", s and "Ctrl + Click" or "Disabled", 2)
end, 3)
createButton(pages[4], "ЁЯОп TP to Mouse", function()
    local hrp = getHRP(); if hrp then hrp.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0,3,0)); notify("TP", "Done!", 2) end
end, 4)
createSection(pages[4], "PLAYERS", 6)
local pBtns = {}
local function refreshPlayers()
    for _, b in pairs(pBtns) do if b and b.Parent then b:Destroy() end end; pBtns = {}
    local ord = 8
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then ord += 1
            local b = createButton(pages[4], "ЁЯУН "..plr.DisplayName.." (@"..plr.Name..")", function()
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = getHRP(); if hrp then hrp.CFrame = plr.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3)
                    notify("TP", "Went to "..plr.DisplayName, 2) end
                end
            end, ord); table.insert(pBtns, b)
        end
    end
end
createButton(pages[4], "ЁЯФД Refresh Players", function() refreshPlayers(); notify("TP", "Refreshed!", 2) end, 7)
refreshPlayers()

-- тХРтХРтХР PAGE 5: ЁЯОо PLAYER тХРтХРтХР
createSection(pages[5], "SURVIVAL", 1)
createToggle(pages[5], "тЭдя╕П God Mode (Client)", false, function(s) States.godMode = s; notify("God Mode", s and "Enabled" or "Disabled", 2) end, 3)
createToggle(pages[5], "ЁЯЫбя╕П No Fall Damage", false, function(s)
    States.noFallDmg = s; local h = getHumanoid()
    if h then h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, not s); h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, not s) end
    notify("Fall Dmg", s and "Disabled" or "Enabled", 2)
end, 4)
createSection(pages[5], "PHYSICS", 6)
createSlider(pages[5], "Jump Power", 50, 500, 50, function(v)
    States.jumpPower = v; local h = getHumanoid(); if h then h.UseJumpPower = true; h.JumpPower = v end
end, 8)
createSlider(pages[5], "Gravity", 0, 500, 196, function(v) States.gravity = v; Workspace.Gravity = v end, 9)
createSection(pages[5], "CHARACTER", 11)
createButton(pages[5], "ЁЯТА Reset Character", function()
    local h = getHumanoid(); if h then h.Health = 0 end; notify("Player", "Reset", 2)
end, 13)
createButton(pages[5], "ЁЯзК Freeze / Unfreeze", function()
    local hrp = getHRP(); if hrp then hrp.Anchored = not hrp.Anchored; notify("Player", hrp.Anchored and "Frozen" or "Unfrozen", 2) end
end, 14)

-- тХРтХРтХР PAGE 6: ЁЯФз MISC тХРтХРтХР
createSection(pages[6], "UTILITY", 1)
createToggle(pages[6], "ЁЯТд Anti AFK", false, function(s)
    States.antiAFK = s
    if s then antiAFKConn = LocalPlayer.Idled:Connect(function()
        local vu = game:GetService("VirtualUser")
        vu:Button2Down(Vector2.zero, Camera.CFrame); task.wait(1)
        vu:Button2Up(Vector2.zero, Camera.CFrame)
    end) else if antiAFKConn then antiAFKConn:Disconnect(); antiAFKConn = nil end end
    notify("Anti AFK", s and "Won't be kicked!" or "Disabled", 2)
end, 3)
createButton(pages[6], "ЁЯЪА FPS Boost", function()
    local c = 0; pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Trail") then v.Enabled = false; c += 1
        elseif v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic; v.Reflectance = 0 end
    end; Lighting.GlobalShadows = false; Lighting.FogEnd = 9e9
    for _, v in pairs(Lighting:GetDescendants()) do
        if v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("BloomEffect") or v:IsA("DepthOfFieldEffect") then v.Enabled = false end
    end; notify("FPS Boost", c.." effects disabled!", 3)
end, 4)
createSection(pages[6], "SERVER", 6)
createButton(pages[6], "ЁЯФД Rejoin", function() notify("Server", "Rejoining...", 2); task.wait(1); TeleportService:Teleport(game.PlaceId, LocalPlayer) end, 8)
createButton(pages[6], "ЁЯМР Server Hop", function()
    notify("Server", "Finding...", 2); task.wait(0.5)
    pcall(function() local d = game:GetService("HttpService"):JSONDecode(game:HttpGetAsync("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
        if d and d.data then for _, sv in pairs(d.data) do if sv.id ~= game.JobId and sv.playing < sv.maxPlayers then TeleportService:TeleportToPlaceInstance(game.PlaceId, sv.id, LocalPlayer); return end end end
        notify("Error", "No servers", 2) end)
end, 9)
createButton(pages[6], "ЁЯУЛ Copy Server ID", function()
    if setclipboard then setclipboard(game.JobId); notify("Copied!", game.JobId, 2) else notify("Error", "Not supported", 2) end
end, 10)
createLabel(pages[6], "  Players: "..#Players:GetPlayers().."/"..Players.MaxPlayers, 12)

-- тХРтХРтХР PAGE 7: тЪЩя╕П SETTINGS тХРтХРтХР
createSection(pages[7], "CONTROLS", 1)
createLabel(pages[7], "  ЁЯФС RightShift = Toggle GUI", 3)
createLabel(pages[7], "  ЁЯЦ▒я╕П Drag top bar to move window", 4)
createLabel(pages[7], "  ЁЯХКя╕П Press E after loading FlyGuiV3", 5)
createSection(pages[7], "ACTIONS", 7)
createButton(pages[7], "ЁЯЧСя╕П Destroy GUI", function() notify("Bye!", "Destroying...", 1); task.wait(1.2); screenGui:Destroy() end, 9)
createButton(pages[7], "тЩ╗я╕П Reset All Features", function()
    States.speed = false; States.noclip = false; States.infiniteJump = false
    States.esp = false; States.fullbright = false; States.noFog = false
    States.godMode = false; States.clickTP = false; States.autoClick = false
    States.antiAFK = false; States.noFallDmg = false
    for _, plr in pairs(Players:GetPlayers()) do if plr.Character then
        local hl = plr.Character:FindFirstChild("NESP"); if hl then hl:Destroy() end
        local h = plr.Character:FindFirstChild("Head"); if h then local bb = h:FindFirstChild("NESPTag"); if bb then bb:Destroy() end end
    end end; espElements = {}
    local h = getHumanoid(); if h then h.WalkSpeed = 16; h.JumpPower = 50; h.UseJumpPower = true end
    Lighting.Ambient = origLighting.Ambient or Color3.fromRGB(127,127,127)
    Lighting.Brightness = origLighting.Brightness or 1
    Lighting.OutdoorAmbient = origLighting.OutdoorAmbient or Color3.fromRGB(127,127,127)
    Lighting.FogEnd = origLighting.FogEnd or 1e5; Lighting.FogStart = origLighting.FogStart or 0
    Camera.FieldOfView = 70; Workspace.Gravity = 196.2
    if antiAFKConn then antiAFKConn:Disconnect(); antiAFKConn = nil end
    notify("тЩ╗я╕П Reset", "All features reset!", 3)
end, 10)
createSection(pages[7], "CREDITS", 12)
createLabel(pages[7], "  ЁЯМА Nonsense Hub v2.0 тЫ░я╕П Mountain Edition", 14)
createLabel(pages[7], "  ЁЯХКя╕П Fly: FlyGuiV3 by XNEOFF", 15)
createLabel(pages[7], "  7 Tabs тАв 20+ Features тАв Made with тЭдя╕П", 16)

-- тХРтХРтХР TAB SWITCHING тХРтХРтХР
local function switchTab(idx)
    for i, page in ipairs(pages) do page.Visible = (i == idx) end
    for i, btn in ipairs(tabBtns) do
        if i == idx then
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(50, 115, 235), BackgroundTransparency = 0.1}):Play()
            btn.Font = Enum.Font.GothamSemibold; btn.TextColor3 = Color3.fromRGB(230, 245, 255)
        else
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(18, 30, 55), BackgroundTransparency = 0.3}):Play()
            btn.Font = Enum.Font.Gotham; btn.TextColor3 = Color3.fromRGB(140, 160, 195)
        end
    end; pageTitle.Text = tabNames[idx]; activeTab = idx
end

for i, btn in ipairs(tabBtns) do
    btn.MouseButton1Click:Connect(function() switchTab(i) end)
    btn.MouseEnter:Connect(function() if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.15}):Play() end end)
    btn.MouseLeave:Connect(function() if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.3}):Play() end end)
end

-- тХРтХРтХР RUNTIME LOOPS тХРтХРтХР
RunService.Heartbeat:Connect(function()
    if States.speed then local h = getHumanoid(); if h then h.WalkSpeed = States.walkSpeed end end
    if States.godMode then local h = getHumanoid(); if h then h.Health = h.MaxHealth end end
end)

RunService.Stepped:Connect(function()
    if States.noclip then local c = LocalPlayer.Character
        if c then for _, p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end end
    if States.noFallDmg then local h = getHumanoid()
        if h then h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false); h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end end
end)

RunService.RenderStepped:Connect(function()
    if States.esp then local myHRP = getHRP()
        if myHRP then for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then local head = plr.Character:FindFirstChild("Head")
                if head then local bb = head:FindFirstChild("NESPTag")
                    if bb then local dist = bb:FindFirstChild("Dist")
                        if dist then local d = math.floor((myHRP.Position - head.Position).Magnitude)
                            dist.Text = d.."m"
                            dist.TextColor3 = d < 30 and Color3.fromRGB(255,80,80) or d < 80 and Color3.fromRGB(255,200,80) or Color3.fromRGB(80,255,80)
                        end end end end end end end
    Camera.FieldOfView = States.fov
end)

UserInputService.JumpRequest:Connect(function()
    if States.infiniteJump then local h = getHumanoid(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end end
end)

Mouse.Button1Down:Connect(function()
    if States.clickTP and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        local hrp = getHRP(); if hrp then hrp.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0,3,0)) end end
end)

task.spawn(function()
    while screenGui.Parent do
        if States.autoClick then local c = LocalPlayer.Character
            if c then local t = c:FindFirstChildOfClass("Tool"); if t then t:Activate() end end end
        task.wait(States.clickDelay / 1000)
    end
end)

-- ESP new players
Players.PlayerAdded:Connect(function(plr) plr.CharacterAdded:Connect(function()
    task.wait(1); if States.esp and plr.Character then
        local hl = Instance.new("Highlight"); hl.Name = "NESP"
        hl.FillColor = Color3.fromRGB(255,50,50); hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.new(1,1,1); hl.Parent = plr.Character
        local head = plr.Character:FindFirstChild("Head"); if head then
            local bb = Instance.new("BillboardGui"); bb.Name = "NESPTag"; bb.Adornee = head
            bb.Size = UDim2.new(0,200,0,40); bb.StudsOffset = Vector3.new(0,2.5,0); bb.AlwaysOnTop = true; bb.Parent = head
            local nt = Instance.new("TextLabel", bb); nt.BackgroundTransparency = 1; nt.Size = UDim2.new(1,0,0.5,0)
            nt.Font = Enum.Font.GothamBold; nt.Text = plr.DisplayName; nt.TextColor3 = Color3.new(1,1,1)
            nt.TextStrokeTransparency = 0; nt.TextSize = 14
            local dt = Instance.new("TextLabel", bb); dt.Name = "Dist"; dt.BackgroundTransparency = 1
            dt.Position = UDim2.new(0,0,0.5,0); dt.Size = UDim2.new(1,0,0.5,0); dt.Font = Enum.Font.Gotham
            dt.Text = "0m"; dt.TextColor3 = Color3.fromRGB(200,200,200); dt.TextStrokeTransparency = 0.3; dt.TextSize = 12
        end end end) end)
Players.PlayerRemoving:Connect(function(plr) espElements[plr] = nil end)

LocalPlayer.CharacterAdded:Connect(function(ch) task.wait(1)
    if States.noFallDmg then local h = ch:WaitForChild("Humanoid", 5)
        if h then h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false); h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end end
end)

-- тХРтХРтХР DRAGGING тХРтХРтХР
local dragging, dragInput, dragStart, startPos
topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = mainFrame.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then local d = input.Position - dragStart
        TweenService:Create(mainFrame, TweenInfo.new(0.06), {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)}):Play()
    end
end)

-- тХРтХРтХР TOGGLE BUTTON тХРтХРтХР
local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 210); toggleBtn.BorderSizePixel = 0
toggleBtn.Size = UDim2.new(0, 48, 0, 48); toggleBtn.Position = UDim2.new(0, 10, 0.5, -24)
toggleBtn.Font = Enum.Font.GothamBold; toggleBtn.Text = "ЁЯМА"; toggleBtn.TextSize = 22
toggleBtn.TextColor3 = Color3.new(1,1,1); toggleBtn.ZIndex = 20; toggleBtn.AutoButtonColor = false
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
local tgS = Instance.new("UIStroke", toggleBtn); tgS.Color = Color3.fromRGB(110, 180, 255); tgS.Thickness = 2; tgS.Transparency = 0.2

local isOpen = true
local function toggleGUI()
    isOpen = not isOpen
    if isOpen then mainFrame.Visible = true; mainScale.Scale = 0.85
        TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play()
        TweenService:Create(toggleBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(40,100,210), Rotation = 0}):Play()
    else TweenService:Create(mainScale, tweenFast, {Scale = 0.85}):Play()
        TweenService:Create(toggleBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(220,60,60), Rotation = 180}):Play()
        task.delay(0.25, function() if not isOpen then mainFrame.Visible = false end end)
    end
end

toggleBtn.MouseButton1Click:Connect(toggleGUI)
toggleBtn.MouseEnter:Connect(function() TweenService:Create(toggleBtn, tweenFast, {Size = UDim2.new(0,54,0,54), Position = UDim2.new(0,7,0.5,-27)}):Play() end)
toggleBtn.MouseLeave:Connect(function() TweenService:Create(toggleBtn, tweenFast, {Size = UDim2.new(0,48,0,48), Position = UDim2.new(0,10,0.5,-24)}):Play() end)

-- Close & Min
closeBtn.MouseButton1Click:Connect(function() TweenService:Create(mainScale, tweenFast, {Scale = 0}):Play(); task.delay(0.3, function() screenGui:Destroy() end) end)
closeBtn.MouseEnter:Connect(function() TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
closeBtn.MouseLeave:Connect(function() TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.8}):Play() end)

local isMin = false; local savedSz
minBtn.MouseButton1Click:Connect(function()
    isMin = not isMin
    if isMin then savedSz = mainFrame.Size; TweenService:Create(mainFrame, tweenSmooth, {Size = UDim2.new(0,610,0,42)}):Play(); minBtn.Text = "тЦб"
    else TweenService:Create(mainFrame, tweenBounce, {Size = savedSz or UDim2.new(0,610,0,410)}):Play(); minBtn.Text = "тФА" end
end)
minBtn.MouseEnter:Connect(function() TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
minBtn.MouseLeave:Connect(function() TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.8}):Play() end)

-- Keybind
UserInputService.InputBegan:Connect(function(input, gpe) if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then toggleGUI() end
end)

-- Entrance
mainScale.Scale = 0; mainFrame.Visible = true
task.delay(0.15, function() TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play() end)
task.delay(1, function() notify("ЁЯМА Nonsense Hub", "Loaded! тЫ░я╕П Mountain Edition | RightShift toggle", 4) end)

print("ЁЯМА Nonsense Hub v2.0 тЫ░я╕П Mountain Edition - FIXED!")
print("   тЬЕ Tabs now visible | тЬЕ Wallpaper brighter")
print("   ЁЯХКя╕П Load FlyGuiV3 from Main tab тЖТ press E to fly")

return screenGui
