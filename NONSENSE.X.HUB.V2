-- ‚ēź‚ēź‚ēź TAB SWITCHING ‚ēź‚ēź‚ēź
local function switchTab(idx)
    for i, pg in ipairs(pages) do pg.Visible = (i == idx) end
    for i, btn in ipairs(tabBtns) do
        if i == idx then
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(50,115,235), BackgroundTransparency = 0.1}):Play()
            btn.Font = Enum.Font.GothamSemibold; btn.TextColor3 = Color3.fromRGB(230,245,255)
        else
            TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(18,30,55), BackgroundTransparency = 0.3}):Play()
            btn.Font = Enum.Font.Gotham; btn.TextColor3 = Color3.fromRGB(140,160,195)
        end
    end; pageTitle.Text = tabNames[idx]; activeTab = idx
end

for i, btn in ipairs(tabBtns) do
    btn.MouseButton1Click:Connect(function() switchTab(i) end)
    btn.MouseEnter:Connect(function() if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.15}):Play() end end)
    btn.MouseLeave:Connect(function() if activeTab ~= i then TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.3}):Play() end end)
end

-- ‚ēź‚ēź‚ēź RUNTIME ‚ēź‚ēź‚ēź
RunService.Heartbeat:Connect(function()
    if States.speed then local h = getHumanoid(); if h then h.WalkSpeed = States.walkSpeed end end
    if States.godMode then local h = getHumanoid(); if h then h.Health = h.MaxHealth end end
end)

RunService.Stepped:Connect(function()
    if States.noclip then local c = LocalPlayer.Character; if c then for _, p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end end
    if States.noFallDmg then local h = getHumanoid(); if h then h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false); h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end end
end)

RunService.RenderStepped:Connect(function()
    if States.esp then local my = getHRP(); if my then for _, plr in pairs(Players:GetPlayers()) do if plr ~= LocalPlayer and plr.Character then local head = plr.Character:FindFirstChild("Head"); if head then local bb = head:FindFirstChild("NESPTag"); if bb then local d = bb:FindFirstChild("Dist"); if d then local dist = math.floor((my.Position - head.Position).Magnitude); d.Text = dist.."m"; d.TextColor3 = dist < 30 and Color3.fromRGB(255,80,80) or dist < 80 and Color3.fromRGB(255,200,80) or Color3.fromRGB(80,255,80) end end end end end end end
    Camera.FieldOfView = States.fov
end)

UserInputService.JumpRequest:Connect(function() if States.infiniteJump then local h = getHumanoid(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end end end)
Mouse.Button1Down:Connect(function() if States.clickTP and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then local hrp = getHRP(); if hrp then hrp.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0,3,0)) end end end)

task.spawn(function() while screenGui.Parent do if States.autoClick then local c = LocalPlayer.Character; if c then local t = c:FindFirstChildOfClass("Tool"); if t then t:Activate() end end end; task.wait(States.clickDelay / 1000) end end)

Players.PlayerAdded:Connect(function(plr) plr.CharacterAdded:Connect(function() task.wait(1); if States.esp and plr.Character then
    local hl = Instance.new("Highlight"); hl.Name = "NESP"; hl.FillColor = Color3.fromRGB(255,50,50); hl.FillTransparency = 0.5; hl.OutlineColor = Color3.new(1,1,1); hl.Parent = plr.Character
    local head = plr.Character:FindFirstChild("Head"); if head then local bb = Instance.new("BillboardGui"); bb.Name = "NESPTag"; bb.Adornee = head; bb.Size = UDim2.new(0,200,0,40); bb.StudsOffset = Vector3.new(0,2.5,0); bb.AlwaysOnTop = true; bb.Parent = head
    local nt = Instance.new("TextLabel", bb); nt.BackgroundTransparency = 1; nt.Size = UDim2.new(1,0,0.5,0); nt.Font = Enum.Font.GothamBold; nt.Text = plr.DisplayName; nt.TextColor3 = Color3.new(1,1,1); nt.TextStrokeTransparency = 0; nt.TextSize = 14
    local dt = Instance.new("TextLabel", bb); dt.Name = "Dist"; dt.BackgroundTransparency = 1; dt.Position = UDim2.new(0,0,0.5,0); dt.Size = UDim2.new(1,0,0.5,0); dt.Font = Enum.Font.Gotham; dt.Text = "0m"; dt.TextColor3 = Color3.fromRGB(200,200,200); dt.TextSize = 12
end end end) end)

LocalPlayer.CharacterAdded:Connect(function(ch) task.wait(1)
    if States.noFallDmg then local h = ch:WaitForChild("Humanoid", 5); if h then h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false); h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end end
end)

-- ‚ēź‚ēź‚ēź DRAGGING ‚ēź‚ēź‚ēź
local dragging, dragInput, dragStart, startPos
topBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = i.Position; startPos = mainFrame.Position; i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then dragging = false end end) end end)
topBar.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then dragInput = i end end)
UserInputService.InputChanged:Connect(function(i) if i == dragInput and dragging then local d = i.Position - dragStart; TweenService:Create(mainFrame, TweenInfo.new(0.06), {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)}):Play() end end)

-- ‚ēź‚ēź‚ēź TOGGLE BUTTON ‚ēź‚ēź‚ēź
local togBtn = Instance.new("TextButton", screenGui)
togBtn.BackgroundColor3 = Color3.fromRGB(40,100,210); togBtn.BorderSizePixel = 0
togBtn.Size = UDim2.new(0,48,0,48); togBtn.Position = UDim2.new(0,10,0.5,-24)
togBtn.Font = Enum.Font.GothamBold; togBtn.Text = "ūüĆÄ"; togBtn.TextSize = 22
togBtn.TextColor3 = Color3.new(1,1,1); togBtn.ZIndex = 20; togBtn.AutoButtonColor = false
Instance.new("UICorner", togBtn).CornerRadius = UDim.new(1, 0)
local tgS = Instance.new("UIStroke", togBtn); tgS.Color = Color3.fromRGB(110,180,255); tgS.Thickness = 2

local isOpen = true
local function toggleGUI()
    isOpen = not isOpen
    if isOpen then mainFrame.Visible = true; mainScale.Scale = 0.85
        TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play()
        TweenService:Create(togBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(40,100,210), Rotation = 0}):Play()
    else TweenService:Create(mainScale, tweenFast, {Scale = 0.85}):Play()
        TweenService:Create(togBtn, tweenFast, {BackgroundColor3 = Color3.fromRGB(220,60,60), Rotation = 180}):Play()
        task.delay(0.25, function() if not isOpen then mainFrame.Visible = false end end) end
end

togBtn.MouseButton1Click:Connect(toggleGUI)
togBtn.MouseEnter:Connect(function() TweenService:Create(togBtn, tweenFast, {Size = UDim2.new(0,54,0,54), Position = UDim2.new(0,7,0.5,-27)}):Play() end)
togBtn.MouseLeave:Connect(function() TweenService:Create(togBtn, tweenFast, {Size = UDim2.new(0,48,0,48), Position = UDim2.new(0,10,0.5,-24)}):Play() end)

closeBtn.MouseButton1Click:Connect(function() musicSound:Stop(); TweenService:Create(mainScale, tweenFast, {Scale = 0}):Play(); task.delay(0.3, function() screenGui:Destroy() end) end)
closeBtn.MouseEnter:Connect(function() TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
closeBtn.MouseLeave:Connect(function() TweenService:Create(closeBtn, tweenFast, {BackgroundTransparency = 0.8}):Play() end)

local isMin = false; local savedSz
minBtn.MouseButton1Click:Connect(function() isMin = not isMin
    if isMin then savedSz = mainFrame.Size; TweenService:Create(mainFrame, tweenSmooth, {Size = UDim2.new(0,620,0,42)}):Play(); minBtn.Text = "‚Ė°"
    else TweenService:Create(mainFrame, tweenBounce, {Size = savedSz or UDim2.new(0,620,0,420)}):Play(); minBtn.Text = "‚ĒÄ" end end)
minBtn.MouseEnter:Connect(function() TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.15}):Play() end)
minBtn.MouseLeave:Connect(function() TweenService:Create(minBtn, tweenFast, {BackgroundTransparency = 0.8}):Play() end)

UserInputService.InputBegan:Connect(function(i, gpe) if gpe then return end
    if i.KeyCode == Enum.KeyCode.RightShift then toggleGUI() end
    if i.KeyCode == Enum.KeyCode.M then -- M key to toggle music
        if musicPlaying then musicSound:Pause(); musicPlaying = false; playPauseBtn.Text = "‚Ė∂"; nowPlayingLbl.Text = "Paused"
        else musicSound:Resume(); musicPlaying = true; playPauseBtn.Text = "‚Źł"; nowPlayingLbl.Text = "Playing" end
    end
end)

-- ‚ēź‚ēź‚ēź ENTRANCE ‚ēź‚ēź‚ēź
mainScale.Scale = 0; mainFrame.Visible = true
task.delay(0.15, function() TweenService:Create(mainScale, tweenBounce, {Scale = 1}):Play() end)
task.delay(1, function() notify("ūüĆÄ Nonsense Hub", "Loaded! ūüéĶ Music playing ‚ÄĘ RightShift toggle ‚ÄĘ M = music", 5) end)

-- Cleanup music on destroy
screenGui.Destroying:Connect(function()
    pcall(function() musicSound:Stop(); musicSound:Destroy() end)
end)

print("ūüĆÄ Nonsense Hub v2.0 ‚õįÔłŹūüéĶ - Loaded!")
print("   ‚úÖ Tabs visible | ‚úÖ Wallpaper bright | ‚úÖ Music auto-playing")
print("   ūüéĶ M key = toggle music | RightShift = toggle GUI")
print("   ūüēäÔłŹ Load FlyGuiV3 from Main tab ‚Üí press E")

return screenGui
