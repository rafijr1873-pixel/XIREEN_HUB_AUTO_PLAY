-- ═══════════════════════════════════════
-- Notification System
-- ═══════════════════════════════════════
local notifY = 0

local function notify(title, text, duration)
    duration = duration or 3
    local n = Instance.new("Frame", screenGui)
    n.BackgroundColor3 = Color3.fromRGB(12, 22, 42)
    n.BorderSizePixel = 0
    n.Size = UDim2.new(0, 250, 0, 58)
    n.Position = UDim2.new(1, 10, 1, -68 - notifY)
    n.ZIndex = 50
    n.ClipsDescendants = true
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 10)
    local ns = Instance.new("UIStroke", n)
    ns.Color = Color3.fromRGB(80, 150, 255)
    ns.Thickness = 1; ns.Transparency = 0.45

    -- Mini wallpaper in notification
    local nWP = Instance.new("ImageLabel", n)
    nWP.BackgroundTransparency = 1
    nWP.Size = UDim2.new(1, 0, 1, 0)
    nWP.Image = WALLPAPER_ID
    nWP.ImageTransparency = 0.92
    nWP.ScaleType = Enum.ScaleType.Crop
    nWP.ZIndex = 50
    Instance.new("UICorner", nWP).CornerRadius = UDim.new(0, 10)

    local nAcc = Instance.new("Frame", n)
    nAcc.BackgroundColor3 = Color3.fromRGB(80, 160, 255)
    nAcc.BorderSizePixel = 0
    nAcc.Size = UDim2.new(0, 3, 1, 0)
    nAcc.ZIndex = 51

    local nT = Instance.new("TextLabel", n)
    nT.BackgroundTransparency = 1
    nT.Position = UDim2.new(0, 12, 0, 5)
    nT.Size = UDim2.new(1, -16, 0, 16)
    nT.Font = Enum.Font.GothamBold
    nT.Text = title
    nT.TextColor3 = Color3.fromRGB(110, 180, 255)
    nT.TextSize = 12
    nT.TextXAlignment = Enum.TextXAlignment.Left
    nT.ZIndex = 51

    local nD = Instance.new("TextLabel", n)
    nD.BackgroundTransparency = 1
    nD.Position = UDim2.new(0, 12, 0, 22)
    nD.Size = UDim2.new(1, -16, 0, 30)
    nD.Font = Enum.Font.Gotham
    nD.Text = text
    nD.TextColor3 = Color3.fromRGB(180, 200, 230)
    nD.TextSize = 11
    nD.TextXAlignment = Enum.TextXAlignment.Left
    nD.TextWrapped = true
    nD.ZIndex = 51

    local yOff = notifY
    notifY += 64
    TweenService:Create(n, tweenSmooth, {Position = UDim2.new(1, -260, 1, -68 - yOff)}):Play()

    task.delay(duration, function()
        TweenService:Create(n, tweenSmooth, {Position = UDim2.new(1, 10, 1, -68 - yOff)}):Play()
        task.delay(0.5, function() n:Destroy(); notifY = math.max(0, notifY - 64) end)
    end)
end

-- ═══════════════════════════════════════
-- UI Builders
-- ═══════════════════════════════════════
local function createPage(name)
    local page = Instance.new("ScrollingFrame", contentArea)
    page.Name = "Page_" .. name
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.Position = UDim2.new(0, 0, 0, 40)
    page.Size = UDim2.new(1, 0, 1, -40)
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Color3.fromRGB(80, 160, 255)
    page.ScrollBarImageTransparency = 0.3
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false; page.ZIndex = 3

    Instance.new("UIListLayout", page).Padding = UDim.new(0, 5)
    page:FindFirstChildOfClass("UIListLayout").SortOrder = Enum.SortOrder.LayoutOrder

    local pd = Instance.new("UIPadding", page)
    pd.PaddingTop = UDim.new(0, 4); pd.PaddingBottom = UDim.new(0, 8)
    pd.PaddingLeft = UDim.new(0, 10); pd.PaddingRight = UDim.new(0, 12)
    return page
end

local function createSection(parent, text, order)
    local lbl = Instance.new("TextLabel", parent)
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Font = Enum.Font.GothamBold
    lbl.Text = "  " .. text
    lbl.TextColor3 = Color3.fromRGB(100, 180, 255)
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.LayoutOrder = order; lbl.ZIndex = 4

    local sep = Instance.new("Frame", parent)
    sep.BackgroundColor3 = Color3.fromRGB(40, 65, 100)
    sep.BorderSizePixel = 0
    sep.Size = UDim2.new(1, 0, 0, 1)
    sep.LayoutOrder = order + 1; sep.ZIndex = 4
end

local function createToggle(parent, text, default, callback, order)
    local toggled = default or false
    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = Color3.fromRGB(18, 30, 55)
    btn.BackgroundTransparency = 0.15
    btn.BorderSizePixel = 0
    btn.Size = UDim2.new(1, 0, 0, 34)
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.LayoutOrder = order; btn.ZIndex = 4
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(40, 65, 100)
    stroke.Thickness = 1; stroke.Transparency = 0.35

    local lbl = Instance.new("TextLabel", btn)
    lbl.BackgroundTransparency = 1
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.Size = UDim2.new(0.65, 0, 1, 0)
    lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(190, 210, 235)
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 5

    local ind = Instance.new("Frame", btn)
    ind.BackgroundColor3 = toggled and Color3.fromRGB(50, 180, 120) or Color3.fromRGB(40, 55, 85)
    ind.BorderSizePixel = 0
    ind.Size = UDim2.new(0, 34, 0, 17)
    ind.Position = UDim2.new(1, -46, 0.5, -8)
    ind.ZIndex = 5
    Instance.new("UICorner", ind).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", ind)
    circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    circle.BorderSizePixel = 0
    circle.Size = UDim2.new(0, 13, 0, 13)
    circle.Position = toggled and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
    circle.ZIndex = 6
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local function refresh()
        if toggled then
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(50, 180, 120)}):Play()
            TweenService:Create(circle, tweenFast, {Position = UDim2.new(1, -15, 0.5, -6)}):Play()
            TweenService:Create(stroke, tweenFast, {Color = Color3.fromRGB(50, 180, 120), Transparency = 0.25}):Play()
        else
            TweenService:Create(ind, tweenFast, {BackgroundColor3 = Color3.fromRGB(40, 55, 85)}):Play()
            TweenService:Create(circle, tweenFast, {Position = UDim2.new(0, 2, 0.5, -6)}):Play()
            TweenService:Create(stroke, tweenFast, {Color = Color3.fromRGB(40, 65, 100), Transparency = 0.35}):Play()
        end
    end

    btn.MouseButton1Click:Connect(function()
        toggled = not toggled; refresh(); callback(toggled)
    end)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(25, 42, 72)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, tweenFast, {BackgroundColor3 = Color3.fromRGB(18, 30, 55)}):Play()
    end)

    if toggled then refresh(); callback(true) end
    return btn
end

local function createSlider(parent, text, min, max, default, callback, order)
    local value = default or min
    local container = Instance.new("Frame", parent)
    container.BackgroundColor3 = Color3.fromRGB(18, 30, 55)
    container.BackgroundTransparency = 0.15
    container.BorderSizePixel = 0
    container.Size = UDim2.new(1, 0, 0, 50)
    container.LayoutOrder = order; container.ZIndex = 4
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", container).Color = Color3.fromRGB(40, 65, 100)

    local lbl = Instance.new("TextLabel", container)
    lbl.BackgroundTransparency = 1
    lbl.Position = UDim2.new(0, 12, 0, 2)
    lbl.Size = UDim2.new(0.55, 0, 0, 20)
    lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(190, 210, 235)
    lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 5

    local valLbl = Instance.new("TextLabel", container)
    valLbl.BackgroundTransparency = 1
    valLbl.Position = UDim2.new(0.6, 0, 0, 2)
    valLbl.Size = UDim2.new(0.35, 0, 0, 20)
    valLbl.Font = Enum.Font.GothamBold
    valLbl.Text = tostring(value)
    valLbl.TextColor3 = Color3.fromRGB(100, 180, 255)
    valLbl.TextSize = 12; valLbl.TextXAlignment = Enum.TextXAlignment.Right; valLbl.ZIndex = 5

    local bg = Instance.new("Frame", container)
    bg.BackgroundColor3 = Color3.fromRGB(12, 20, 38)
    bg.BorderSizePixel = 0
    bg.Position = UDim2.new(0, 12, 0, 28)
    bg.Size = UDim2.new(1, -24, 0, 6)
    bg.ZIndex = 5
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", bg)
    fill.BackgroundColor3 = Color3.fromRGB(70, 150, 255)
    fill.BorderSizePixel = 0
    fill.Size = UDim2.new((value - min)/(max - min), 0, 1, 0)
    fill.ZIndex = 6
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    Instance.new("UIGradient", fill).Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 130, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(120, 210, 255))
    })

    local knob = Instance.new("Frame", bg)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new((value - min)/(max - min), -7, 0.5, -7)
    knob.ZIndex = 7
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local isDragging = false
    local function update(pos)
        local rel = math.clamp((pos.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max - min) * rel)
        valLbl.Text = tostring(value)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -7, 0.5, -7)
        callback(value)
    end

    bg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            isDragging = true; update(i.Position)
        end
    end)
    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDragging = true end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if isDragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDragging = false end
    end)
    return container
end

local function createButton(parent, text, callback, order)
    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = Color3.fromRGB(45, 90, 200)
    btn.BackgroundTransparency = 0.2
    btn.BorderSizePixel = 0
    btn.Size = UDim2.new(1, 0, 0, 32)
    btn.Font = Enum.Font.GothamMedium
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(220, 235, 255)
    btn.TextSize = 12
    btn.AutoButtonColor = false
    btn.LayoutOrder = order; btn.ZIndex = 4
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(callback)
    btn.MouseEnter:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.02}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, tweenFast, {BackgroundTransparency = 0.2}):Play() end)
    return btn
end

local function createLabel(parent, text, order)
    local lbl = Instance.new("TextLabel", parent)
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 0, 18)
    lbl.Font = Enum.Font.Gotham
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(130, 160, 200)
    lbl.TextSize = 11; lbl.TextWrapped = true
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.LayoutOrder = order; lbl.ZIndex = 4
    return lbl
end

-- ═══════════════════════════════════════
-- TAB SYSTEM
-- ═══════════════════════════════════════
local tabNames = {"🏠 Main", "⚔️ Combat", "👁️ Visuals", "🌍 Teleport", "🎮 Player", "🔧 Misc", "⚙️ Settings"}
local tabBtns = {}
local pages = {}

for i, name in ipairs(tabNames) do
    local tab = Instance.new("TextButton", sidebar)
    tab.Name = "Tab_" .. i
    tab.BackgroundColor3 = (i == 1) and Color3.fromRGB(50, 110, 230) or Color3.fromRGB(20, 32, 55)
    tab.BackgroundTransparency = (i == 1) and 0.12 or 0.35
    tab.BorderSizePixel = 0
    tab.Size = UDim2.new(1, 0, 0, 30)
    tab.Font = (i == 1) and Enum.Font.GothamSemibold or Enum.Font.Gotham
    tab.Text = name
    tab.TextColor3 = (i == 1) and Color3.fromRGB(225, 240, 255) or Color3.fromRGB(120, 140, 175)
    tab.TextSize = 11; tab.AutoButtonColor = false
    tab.LayoutOrder = i; tab.ZIndex = 6
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 7)
    tabBtns[i] = tab
end

for i, name in ipairs(tabNames) do
    pages[i] = createPage(name)
    if i == 1 then pages[i].Visible = true end
end

