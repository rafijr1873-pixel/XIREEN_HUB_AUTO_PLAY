local ROW_H  = 46
local KEY_W  = 50
local LBL_W  = 72
local START_Y = 4

local function highlightKey(keyTxt, on)
    local btn = keyButtons[keyTxt]
    if btn then
        local col = on and Color3.fromRGB(0, 200, 120) or Color3.fromRGB(48, 48, 48)
        TweenService:Create(btn, TweenInfo.new(0.06), {BackgroundColor3 = col}):Play()
    end
end

local function pressKey(keyTxt)
    highlightKey(keyTxt, true)

    local kc = keyToKeyCode[keyTxt]
    if kc then
        pcall(function()
            VirtualInputManager:SendKeyEvent(true,  kc, false, game)
            task.wait(0.08)
            VirtualInputManager:SendKeyEvent(false, kc, false, game)
        end)
    end

    task.delay(0.15, function()
        highlightKey(keyTxt, false)
    end)
end

