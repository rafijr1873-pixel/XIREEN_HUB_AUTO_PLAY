-- ========================================
-- MIDI BINARY PARSER
-- ========================================

local MidiParser = {}

-- Baca bytes dari string binary
local function readBytes(data, pos, count)
    local bytes = {}
    for i = 0, count - 1 do
        bytes[i + 1] = string.byte(data, pos + i)
    end
    return bytes, pos + count
end

-- Baca integer dari bytes (Big Endian)
local function readInt(data, pos, bytes)
    local value = 0
    for i = 0, bytes - 1 do
        value = value * 256 + string.byte(data, pos + i)
    end
    return value, pos + bytes
end

-- Baca Variable Length Quantity (VLQ) - format MIDI
local function readVLQ(data, pos)
    local value = 0
    local byte
    repeat
        byte = string.byte(data, pos)
        if byte == nil then break end
        value = (value * 128) + (byte % 128)
        pos = pos + 1
    until byte < 128
    return value, pos
end

-- Parse file .mid binary
function MidiParser.parse(data)
    local events = {}
    local pos = 1
    local dataLen = #data

    -- Cek header MThd
    local header = data:sub(1, 4)
    if header ~= "MThd" then
        return nil, "Bukan file MIDI valid! Header: " .. tostring(header)
    end
    pos = 5

    -- Baca header length (harus 6)
    local headerLen, newPos = readInt(data, pos, 4)
    pos = newPos

    -- Baca format MIDI (0, 1, atau 2)
    local format, p2 = readInt(data, pos, 2)
    pos = p2

    -- Baca jumlah track
    local numTracks, p3 = readInt(data, pos, 2)
    pos = p3

    -- Baca timing (ticks per beat)
    local ticksPerBeat, p4 = readInt(data, pos, 2)
    pos = p4

    if ticksPerBeat == 0 then ticksPerBeat = 480 end

    local tempo = 500000 -- default 120 BPM (microseconds per beat)
    local allEvents = {}

    -- Parse setiap track
    for trackNum = 1, numTracks do
        if pos > dataLen then break end

        -- Cek header MTrk
        local trackHeader = data:sub(pos, pos + 3)
        if trackHeader ~= "MTrk" then
            pos = pos + 1
            repeat
                pos = pos + 1
                if pos + 3 > dataLen then break end
            until data:sub(pos, pos + 3) == "MTrk"
            if pos + 3 > dataLen then break end
        end
        pos = pos + 4

        -- Baca panjang track
        local trackLen, p5 = readInt(data, pos, 4)
        pos = p5
        local trackEnd = pos + trackLen

        local absoluteTick = 0
        local runningStatus = 0

        -- Parse events dalam track
        while pos < trackEnd do
            if pos > dataLen then break end

            -- Baca delta time
            local deltaTime, newP
            local success, err = pcall(function()
                deltaTime, newP = readVLQ(data, pos)
            end)
            if not success or newP == nil then break end
            pos = newP
            absoluteTick = absoluteTick + deltaTime

            if pos > dataLen then break end

            -- Baca event type
            local eventByte = string.byte(data, pos)
            if eventByte == nil then break end

            -- Running status
            if eventByte >= 128 then
                runningStatus = eventByte
                pos = pos + 1
            end

            local status = runningStatus
            local eventType = math.floor(status / 16)
            local channel = status % 16

            if pos > dataLen then break end

            -- Meta Event
            if status == 0xFF then
                local metaType = string.byte(data, pos)
                pos = pos + 1
                if pos > dataLen then break end

                local metaLen, mp = readVLQ(data, pos)
                pos = mp

                -- Tempo change
                if metaType == 0x51 and metaLen == 3 then
                    local t1 = string.byte(data, pos) or 0
                    local t2 = string.byte(data, pos + 1) or 0
                    local t3 = string.byte(data, pos + 2) or 0
                    tempo = t1 * 65536 + t2 * 256 + t3
                    table.insert(allEvents, {
                        tick = absoluteTick,
                        type = "tempo",
                        tempo = tempo,
                        track = trackNum
                    })
                end

                pos = pos + metaLen

            -- SysEx Event
            elseif status == 0xF0 or status == 0xF7 then
                local sysLen, sp = readVLQ(data, pos)
                pos = sp + sysLen

            -- Channel Events
            elseif eventType == 9 then -- Note On
                local note = string.byte(data, pos) or 0
                local velocity = string.byte(data, pos + 1) or 0
                pos = pos + 2

                table.insert(allEvents, {
                    tick = absoluteTick,
                    type = velocity > 0 and "noteOn" or "noteOff",
                    note = note,
                    velocity = velocity,
                    channel = channel,
                    track = trackNum
                })

            elseif eventType == 8 then -- Note Off
                local note = string.byte(data, pos) or 0
                local velocity = string.byte(data, pos + 1) or 0
                pos = pos + 2

                table.insert(allEvents, {
                    tick = absoluteTick,
                    type = "noteOff",
                    note = note,
                    velocity = velocity,
                    channel = channel,
                    track = trackNum
                })

            elseif eventType == 10 then -- Aftertouch
                pos = pos + 2
            elseif eventType == 11 then -- Control Change
                pos = pos + 2
            elseif eventType == 12 then -- Program Change
                pos = pos + 1
            elseif eventType == 13 then -- Channel Pressure
                pos = pos + 1
            elseif eventType == 14 then -- Pitch Bend
                pos = pos + 2
            else
                pos = pos + 1
            end
        end

        pos = trackEnd
    end

    -- Sort semua events berdasarkan tick
    table.sort(allEvents, function(a, b)
        if a.tick == b.tick then
            -- noteOff sebelum noteOn di tick yang sama
            if a.type == "noteOff" and b.type ~= "noteOff" then return true end
            if b.type == "noteOff" and a.type ~= "noteOff" then return false end
        end
        return a.tick < b.tick
    end)

    -- Konversi tick ke waktu detik
    local currentTempo = 500000
    local currentTick = 0
    local currentTime = 0
    local tempoChanges = {}

    -- Kumpulkan tempo changes
    for _, evt in ipairs(allEvents) do
        if evt.type == "tempo" then
            table.insert(tempoChanges, evt)
        end
    end

    -- Konversi tick ke seconds untuk setiap event
    local tempoIdx = 1
    local lastTempoTick = 0
    local lastTempoTime = 0
    local lastTempoValue = 500000

    for _, evt in ipairs(allEvents) do
        -- Update tempo jika ada perubahan
        while tempoIdx <= #tempoChanges and tempoChanges[tempoIdx].tick <= evt.tick do
            local tc = tempoChanges[tempoIdx]
            lastTempoTime = lastTempoTime + (tc.tick - lastTempoTick) * lastTempoValue / (ticksPerBeat * 1000000)
            lastTempoTick = tc.tick
            lastTempoValue = tc.tempo
            tempoIdx = tempoIdx + 1
        end

        local timeSeconds = lastTempoTime + (evt.tick - lastTempoTick) * lastTempoValue / (ticksPerBeat * 1000000)
        evt.timeSeconds = timeSeconds

        if evt.type == "noteOn" then
            table.insert(events, {
                time = timeSeconds,
                note = evt.note,
                velocity = evt.velocity,
                channel = evt.channel,
                track = evt.track
            })
        end
    end

    -- Sort final events
    table.sort(events, function(a, b) return a.time < b.time end)

    return events, nil, {
        format = format,
        numTracks = numTracks,
        ticksPerBeat = ticksPerBeat,
        totalNotes = #events
    }
end

