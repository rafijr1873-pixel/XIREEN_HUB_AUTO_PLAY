-- ═══════════════════════════════
-- MIDI PARSER
-- ═══════════════════════════════

local function parseMIDI(raw)
    if not raw or #raw < 14 then
        return nil, "File terlalu kecil"
    end

    local pos = 1
    local len = #raw

    local function readByte()
        if pos > len then error("EOF") end
        local b = string.byte(raw, pos)
        pos = pos + 1
        return b
    end

    local function readInt(bytes)
        local v = 0
        for _ = 1, bytes do
            v = v * 256 + readByte()
        end
        return v
    end

    local function readStr(bytes)
        if pos + bytes - 1 > len then error("EOF") end
        local s = raw:sub(pos, pos + bytes - 1)
        pos = pos + bytes
        return s
    end

    local function readVLQ()
        local v = 0
        local count = 0
        repeat
            local b = readByte()
            v = v * 128 + (b % 128)
            count = count + 1
            if count > 4 then error("VLQ too long") end
        until b < 128
        return v
    end

    -- Cek header
    local header = readStr(4)
    if header ~= "MThd" then
        return nil, "Bukan file MIDI! Header: " .. tostring(header)
    end

    local headerLen = readInt(4)
    readInt(2) -- format
    local numTracks = readInt(2)
    local ppq = readInt(2)

    if headerLen > 6 then pos = pos + (headerLen - 6) end
    if ppq >= 32768 then return nil, "Format SMPTE tidak didukung" end

    local allNotes = {}
    local tempoMap = {}

    -- Parse setiap track
    for _ = 1, numTracks do
        if pos + 8 > len then break end

        local ok, err = pcall(function()
            local trackHeader = readStr(4)
            if trackHeader ~= "MTrk" then
                error("Track header salah: " .. tostring(trackHeader))
            end

            local trackLen = readInt(4)
            local trackEnd = pos + trackLen
            local absoluteTick = 0
            local runningStatus = 0

            while pos < trackEnd and pos <= len do
                local delta = readVLQ()
                absoluteTick = absoluteTick + delta

                if pos > len then break end

                local byte1 = string.byte(raw, pos)
                if not byte1 then break end

                local statusByte
                if byte1 >= 128 then
                    statusByte = readByte()
                    if statusByte < 0xF0 then
                        runningStatus = statusByte
                    end
                else
                    statusByte = runningStatus
                    if statusByte == 0 then break end
                end

                local msgType = math.floor(statusByte / 16)
                local channel = statusByte % 16

                if statusByte == 0xFF then
                    -- Meta event
                    local metaType = readByte()
                    local metaLen = readVLQ()
                    if metaType == 0x51 and metaLen >= 3 then
                        local us = readByte() * 65536 + readByte() * 256 + readByte()
                        table.insert(tempoMap, {tick = absoluteTick, tempo = us})
                        if metaLen > 3 then pos = pos + (metaLen - 3) end
                    else
                        pos = pos + metaLen
                    end
                elseif statusByte == 0xF0 or statusByte == 0xF7 then
                    -- SysEx
                    pos = pos + readVLQ()
                elseif msgType == 9 then
                    -- Note On
                    local note = readByte()
                    local velocity = readByte()
                    if velocity > 0 then
                        table.insert(allNotes, {
                            tick = absoluteTick,
                            note = note,
                            velocity = velocity,
                            channel = channel
                        })
                    end
                elseif msgType == 8 then
                    readByte(); readByte() -- Note Off
                elseif msgType == 10 or msgType == 11 or msgType == 14 then
                    readByte(); readByte()
                elseif msgType == 12 or msgType == 13 then
                    readByte()
                else
                    pos = trackEnd
                end
            end

            pos = trackEnd
        end)

        if not ok then
            warn("Track parse error:", err)
            -- Coba skip ke track berikutnya
            break
        end
    end

    if #allNotes == 0 then
        return nil, "Tidak ada note ditemukan di file MIDI ini"
    end

    -- Sort by tick
    table.sort(allNotes, function(a, b) return a.tick < b.tick end)
    table.sort(tempoMap, function(a, b) return a.tick < b.tick end)

    -- Default tempo jika tidak ada
    if #tempoMap == 0 or tempoMap[1].tick ~= 0 then
        table.insert(tempoMap, 1, {tick = 0, tempo = 500000})
    end

    -- Build tempo timeline
    local tempoTimeline = {}
    local cumTime = 0
    local prevTick = 0
    local prevTempo = 500000

    for _, tc in ipairs(tempoMap) do
        cumTime = cumTime + (tc.tick - prevTick) * prevTempo / ppq / 1000000
        table.insert(tempoTimeline, {
            tick = tc.tick,
            timeSeconds = cumTime,
            tempo = tc.tempo
        })
        prevTick = tc.tick
        prevTempo = tc.tempo
    end

    -- Fungsi konversi tick ke detik
    local function tickToSeconds(tick)
        local t = 0
        local p = 0
        local m = 500000
        for _, entry in ipairs(tempoTimeline) do
            if entry.tick > tick then break end
            t = entry.timeSeconds
            p = entry.tick
            m = entry.tempo
        end
        return t + (tick - p) * m / ppq / 1000000
    end

    -- Deteksi channel terbaik (bukan drum/channel 9)
    local channelCount = {}
    for _, n in ipairs(allNotes) do
        channelCount[n.channel] = (channelCount[n.channel] or 0) + 1
    end

    local bestChannel = nil
    local bestCount = 0
    for ch, cnt in pairs(channelCount) do
        if ch ~= 9 and cnt > bestCount then
            bestChannel = ch
            bestCount = cnt
        end
    end

    -- Kalau semua drum, pakai channel 9
    if not bestChannel then
        bestChannel = 9
    end

    -- Build sequence
    local sequence = {}
    local groupByTick = {}
    local tickList = {}

    for _, n in ipairs(allNotes) do
        if n.channel == bestChannel or (bestChannel == 9 and n.channel == 9) then
            local note = n.note
            local key = NoteMap[note]

            -- Transpose kalau keluar range
            if not key then
                local shifted = note
                while shifted > 113 do shifted = shifted - 12 end
                while shifted < 36 do shifted = shifted + 12 end
                key = NoteMap[shifted]
            end

            if key then
                if not groupByTick[n.tick] then
                    groupByTick[n.tick] = {}
                    table.insert(tickList, n.tick)
                end
                -- Cegah duplikat
                local dup = false
                for _, k in ipairs(groupByTick[n.tick]) do
                    if k == key then dup = true; break end
                end
                if not dup then
                    table.insert(groupByTick[n.tick], key)
                end
            end
        end
    end

    table.sort(tickList)

    for _, tick in ipairs(tickList) do
        table.insert(sequence, {
            time = tickToSeconds(tick),
            keys = groupByTick[tick]
        })
    end

    if #sequence == 0 then
        return nil, "Tidak ada note yang bisa dimapping ke guitar keys"
    end

    local duration = sequence[#sequence].time
    local bpm = math.floor(60000000 / (tempoMap[1].tempo or 500000) + 0.5)
    local noteCount = #sequence

    return {
        sequence = sequence,
        duration = duration,
        bpm = bpm,
        noteCount = noteCount
    }
end

