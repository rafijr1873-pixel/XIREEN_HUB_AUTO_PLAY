-- ═══ MIDI PARSER (sama persis dari Auto Drum) ═══
local M={}
function M.parse(r)
    if not r or #r<14 then return nil,"File terlalu kecil"end
    local p,l=1,#r
    local function rb()if p>l then error("EOF")end;local b=string.byte(r,p);p=p+1;return b end
    local function rn(n)local v=0;for _=1,n do v=v*256+rb()end;return v end
    local function rs(n)if p+n-1>l then error("EOF")end;local s=r:sub(p,p+n-1);p=p+n;return s end
    local function rv()
        local v,c=0,0
        repeat
            local b=rb();v=v*128+(b%128);c=c+1
            if c>4 then error("VLQ overflow")end
        until b<128
        return v
    end
    local h=rs(4)
    if h~="MThd" then return nil,"Bukan file MIDI (header: "..tostring(h)..")"end
    local hl=rn(4);rn(2)
    local nT=rn(2)
    local dv=rn(2)
    if hl>6 then p=p+(hl-6)end
    if dv>=32768 then return nil,"Format SMPTE tidak didukung"end
    local ppq=dv
    local ns,ts={},{}
    for t=1,nT do
        if p+8>l then break end
        local th=rs(4)
        if th~="MTrk" then return nil,"Track header salah"end
        local tl=rn(4)
        local te=p+tl
        local at,rn2=0,0
        while p<te and p<=l do
            local d=rv();at=at+d
            if p>l then break end
            local pk=string.byte(r,p)
            if not pk then break end
            local st
            if pk>=128 then
                st=rb()
                if st<0xF0 then rn2=st end
            else
                st=rn2
                if st==0 then rb();break end
            end
            local hi=math.floor(st/16)
            if hi==9 then
                local n2,v2=rb(),rb()
                if v2>0 and #ns<50000 then
                    ns[#ns+1]={at,n2,v2,st%16}
                end
            elseif hi==8 or hi==10 or hi==11 or hi==14 then rb();rb()
            elseif hi==12 or hi==13 then rb()
            elseif st==0xFF then
                local mt=rb();local ml=rv()
                if mt==0x51 and ml>=3 then
                    local us=0
                    for _=1,3 do us=us*256+rb()end
                    ts[#ts+1]={at,us}
                    if ml>3 then p=p+(ml-3)end
                else p=p+ml end
            elseif st==0xF0 or st==0xF7 then p=p+rv()
            else p=te end
        end
        p=te
    end
    if #ns==0 then return nil,"Tidak ada note ditemukan"end
    table.sort(ns,function(a,b)return a[1]<b[1]end)
    table.sort(ts,function(a,b)return a[1]<b[1]end)
    return ns,ts,ppq
end

function M.build(ns,ts,ppq)
    -- Deteksi channel guitar (bukan drum/channel 9)
    local chanCount={}
    for _,n in ipairs(ns)do
        local ch=n[4]
        chanCount[ch]=(chanCount[ch]or 0)+1
    end

    -- Cari channel dengan note terbanyak (bukan channel 9/drum)
    local bestCh,bestCount=nil,0
    for ch,cnt in pairs(chanCount)do
        if ch~=9 and cnt>bestCount then
            bestCh=ch;bestCount=cnt
        end
    end

    -- Kalau semua channel 9 (drum midi), pakai semua
    local useDrum=false
    if not bestCh then
        bestCh=9;useDrum=true
    end

    -- Build note events dengan guitar mapping
    local dn={}
    for _,n in ipairs(ns)do
        local ch=n[4]
        -- Ambil semua channel non-drum, atau kalau terpaksa pakai drum
        if (not useDrum and ch~=9) or (useDrum and ch==9) then
            local note=n[2]
            local k=GM[note]
            -- Transpose kalau keluar range
            if not k then
                local shifted=note
                while shifted>113 do shifted=shifted-12 end
                while shifted<36  do shifted=shifted+12 end
                k=GM[shifted]
            end
            if k then
                dn[#dn+1]={t=n[1],k=k,note=note}
            end
        end
    end

    if #dn==0 then return nil,0,0,0 end

    -- Build tempo map
    if #ts==0 or ts[1][1]~=0 then
        table.insert(ts,1,{0,500000})
    end
    local tl={}
    local cs,pt,pm=0,0,500000
    for _,tc in ipairs(ts)do
        cs=cs+(tc[1]-pt)*pm/ppq/1e6
        tl[#tl+1]={t=tc[1],s=cs,m=tc[2]}
        pt=tc[1];pm=tc[2]
    end

    local function t2s(tk)
        local s,p2,m2=0,0,500000
        for _,t in ipairs(tl)do
            if t.t>tk then break end
            s=t.s;p2=t.t;m2=t.m
        end
        return s+(tk-p2)*m2/ppq/1e6
    end

    -- Group notes di tick yang sama (chord)
    local gr,tks={},{}
    for _,d in ipairs(dn)do
        local t=d.t
        if not gr[t]then gr[t]={};tks[#tks+1]=t end
        -- Cegah duplikat key di chord yang sama
        local dup=false
        for _,k in ipairs(gr[t])do if k==d.k then dup=true end end
        if not dup then gr[t][#gr[t]+1]=d.k end
    end
    table.sort(tks)

    local sq={}
    for _,t in ipairs(tks)do
        sq[#sq+1]={time=t2s(t),keys=gr[t]}
    end

    local dur=sq[#sq] and sq[#sq].time or 0
    local bpm=math.floor(60e6/(ts[1][2]or 5e5)+.5)
    return sq,dur,bpm,#dn
end

-- ═══ FETCH ═══
local function fetch(u)
    local b
    pcall(function()
        if syn and syn.request then
            b=syn.request({Url=u,Method="GET"}).Body
        elseif http_request then
            b=http_request({Url=u,Method="GET"}).Body
        elseif request then
            b=request({Url=u,Method="GET"}).Body
        elseif httpget then
            b=httpget(u)
        else
            b=game:HttpGet(u)
        end
    end)
    return b
end

local function loadMd(u,cb)
    if not u then return nil,"No URL"end
    cb("Mengunduh file .mid...")
    local r=fetch(u)
    if not r then return nil,"Gagal download. Cek URL!"end
    cb("Parsing binary MIDI...")
    local ns,ts,ppq=M.parse(r)
    if not ns then return nil,ts end
    cb("Building sequence...")
    local sq,dur,bpm,cnt=M.build(ns,ts,ppq)
    if not sq then return nil,"Build gagal, tidak ada note guitar"end
    return{sq=sq,dur=dur,bpm=bpm,cnt=cnt}
end

