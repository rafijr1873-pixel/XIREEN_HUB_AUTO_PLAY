playStopBtn.MouseButton1Click:Connect(function()
    if isPlaying then
        stopPlay()
    else
        if midiData then
            startPlay()
        else
            statusLabel.Text = "⚠ Load lagu dulu!"
            statusLabel.TextColor3 = COL.orange
            switchTab(1)
        end
    end
end)

MinBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
end)

ClsBtn.MouseButton1Click:Connect(function()
    stopPlay()
    task.wait(0.1)
    ScreenGui:Destroy()
    _G._AG = nil
end)

ToggleBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

-- P = toggle play/stop
UserInputService.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.KeyCode == Enum.KeyCode.P then
        if isPlaying then
            stopPlay()
        else
            if midiData then startPlay() end
        end
    end
end)

