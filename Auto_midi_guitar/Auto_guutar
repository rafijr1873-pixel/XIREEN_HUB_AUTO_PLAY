                    statusLabel.TextColor3 = COL.gray
                end
                playStopBtn.Text = "▶ PLAY"
                playStopBtn.BackgroundColor3 = COL.green
                statStatus.Text = "📍 Status: ⏹ Stopped"
                toggleIcon.Text = "🎸"
            end

            if midiData then
                npName.Text = currentSong
                npArtist.Text = isPlaying and "▶ Playing..." or "⏹ Ready"
                npBpm.Text = midiData.bpm .. " BPM · " .. midiData.noteCount .. " notes"
            end

            statHits.Text = "🎵 Hits: " .. totalHits
            statLoops.Text = "🔄 Loops: " .. loopCount
            statTime.Text = "⏱ Time: " .. midiTime
        end)
        task.wait(0.2)
    end
end)

