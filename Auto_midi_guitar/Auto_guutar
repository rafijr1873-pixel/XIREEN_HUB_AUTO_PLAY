local function loadSong(url, name, songIdx)
    statusLabel.Text = "⏳ Loading: " .. (name or "...")
    statusLabel.TextColor3 = COL.orange

    -- Stop dulu
    stopPlay()
    task.wait(0.1)

    task.spawn(function()
        statusLabel.Text = "📥 Downloading..."
        local raw = fetchFile(url)

        if not raw then
            statusLabel.Text = "❌ Gagal download! Cek URL"
            statusLabel.TextColor3 = COL.red
            return
        end

        statusLabel.Text = "🔍 Parsing MIDI..."
        statusLabel.TextColor3 = COL.yellow

        local data, err = parseMIDI(raw)

        if not data then
            statusLabel.Text = "❌ " .. tostring(err)
            statusLabel.TextColor3 = COL.red
            return
        end

        midiData = data
        currentSong = name or "Custom"
        currentSongIndex = songIdx
        totalHits = 0
        loopCount = 0

        statusLabel.Text = string.format("✅ %s · %d notes · %d BPM",
            currentSong, data.noteCount, data.bpm)
        statusLabel.TextColor3 = COL.green

        -- Highlight row yang dipilih
        for i, row in ipairs(songRowRefs) do
            if row and row.Parent then
                row.BackgroundColor3 = i == songIdx and Color3.fromRGB(50, 35, 75) or COL.card
            end
        end

        task.wait(0.3)
        startPlay()

        -- Notif
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "🎸 " .. currentSong,
                Text = data.noteCount .. " notes · " .. data.bpm .. " BPM",
                Duration = 3
            })
        end)
    end)
end

