local function midiLp()
    if not mObj or #mObj.sq==0 then
        secN="NO MIDI";task.wait(1);return
    end
    secN="♫ "..cSong
    local sq=mObj.sq
    local totalTime=mObj.dur/sM
    local st=tick()

    for i=1,#sq do
        if not ok()then mPr=0;return end
        -- Timing presisi
        local tg=st+sq[i].time/sM
        local now=tick()
        if tg>now+0.002 then
            task.wait(tg-now)
        end
        if not ok()then mPr=0;return end

        -- Press semua key di chord ini
        local keys=sq[i].keys
        if #keys==1 then
            -- Single note
            pr(keys[1])
        else
            -- Chord: press bersamaan (strumming)
            for _,k in ipairs(keys)do
                task.spawn(function() pr(k) end)
            end
            task.wait(0.05)
        end

        mPr=i/#sq
        mTm=fmt(tick()-st).."/"..fmt(totalTime)
    end

    lps=lps+1
    mPr=1

    -- Auto next
    if aNxt and ok()then
        secN="⏭ Next..."
        task.wait(0.8)
        if ok()then
            -- Cari lagu berikutnya
            local nextIdx=nil
            if aSg then
                nextIdx=(aSg%#PS)+1
            else
                nextIdx=1
            end
            if shuf then
                nextIdx=RNG:NextInteger(1,#PS)
            end
            _G._AG=false
            task.wait(0.15)
            aSg=nextIdx
            doLoad(PS[nextIdx].u,PS[nextIdx].n)
        end
    else
        secN="↻ Done"
        task.wait(0.5)
    end
end

-- ═══ PLAY / STOP ═══
local playThread=nil

local function go()
    if _G._AG then return end
    _G._AG=true
    tH=0;lps=0;mPr=0;secN="STARTING"
    playThread=task.spawn(function()
        while _G._AG do
            pcall(midiLp)
        end
    end)
end

local function stp()
    _G._AG=false
    secN="IDLE"
    mPr=0
    if playThread then
        pcall(function() task.cancel(playThread) end)
        playThread=nil
    end
    -- Release semua key
    pcall(function()
        for _,v in pairs(K)do
            VIM:SendKeyEvent(false,v,false,game)
        end
    end)
end

