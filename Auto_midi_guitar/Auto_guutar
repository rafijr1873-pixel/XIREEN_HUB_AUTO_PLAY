        "Row 5 (CTRL)  : Note 88-100 → E6 s/d E7",
        "Row 6 (z-m)   : Note 101-113 → F7 s/d F8",
    }
    for i,txt in ipairs(mInfoTxt)do
        ln(nInfo,UDim2.new(1,-8,0,8),UDim2.new(0,4,0,3+i*9),txt,C.t3,6)
    end

    -- ══════════════════════════════════
    -- TAB 4: SETTINGS
    -- ══════════════════════════════════
    local t4f=tFs[4]

    local function mkTg(ord,lbl,init,fn)
        local f=Instance.new("Frame",t4f)
        f.Size=UDim2.new(1,-4,0,26);f.BackgroundColor3=C.card
        f.BorderSizePixel=0;f.LayoutOrder=ord;cr(f,4)
        ln(f,UDim2.new(.6,0,1,0),UDim2.new(0,8,0,0),lbl,C.t1,8,Enum.Font.GothamBold).TextYAlignment=Enum.TextYAlignment.Center
        local bg2=Instance.new("Frame",f)
        bg2.Size=UDim2.new(0,32,0,16);bg2.Position=UDim2.new(1,-40,0,5)
        bg2.BackgroundColor3=init and C.grn or C.tog;bg2.BorderSizePixel=0;cr(bg2,3)
        local kb2=Instance.new("Frame",bg2)
        kb2.Size=UDim2.new(0,12,0,12)
        kb2.Position=init and UDim2.new(0,18,0,2) or UDim2.new(0,2,0,2)
        kb2.BackgroundColor3=C.w;kb2.BorderSizePixel=0;cr(kb2,3)
        local bn=Instance.new("TextButton",bg2)
        bn.Size=UDim2.new(1,0,1,0);bn.BackgroundTransparency=1;bn.Text=""
        local on=init
        bn.MouseButton1Click:Connect(function()
            on=not on
            bg2.BackgroundColor3=on and C.grn or C.tog
            TS:Create(kb2,TweenInfo.new(.1),{Position=on and UDim2.new(0,18,0,2)or UDim2.new(0,2,0,2)}):Play()
            if fn then fn(on) end
        end)
    end

    mkTg(0,"⏭️ Auto-Next",aNxt,function(v)aNxt=v end)
    mkTg(1,"🔀 Shuffle",shuf,function(v)shuf=v end)

    -- Speed
    local sf2=Instance.new("Frame",t4f)
    sf2.Size=UDim2.new(1,-4,0,26);sf2.BackgroundColor3=C.card
    sf2.BorderSizePixel=0;sf2.LayoutOrder=2;cr(sf2,4)
    ln(sf2,UDim2.new(.4,0,1,0),UDim2.new(0,8,0,0),"🎚️ Play Speed",C.t1,8,Enum.Font.GothamBold).TextYAlignment=Enum.TextYAlignment.Center
    local sDn=bt(sf2,UDim2.new(0,20,0,16),UDim2.new(1,-72,0,5),C.bg,"◀",C.t2,9)
    local sDp=ln(sf2,UDim2.new(0,28,0,16),UDim2.new(1,-50,0,5),"1.0x",C.t1,8,Enum.Font.GothamBold)
    sDp.TextXAlignment=Enum.TextXAlignment.Center;sDp.TextYAlignment=Enum.TextYAlignment.Center
    local sUp=bt(sf2,UDim2.new(0,20,0,16),UDim2.new(1,-22,0,5),C.bg,"▶",C.t2,9)
    sDn.MouseButton1Click:Connect(function()sI=math.max(1,sI-1);sM=SP[sI];sDp.Text=sM.."x";spdB.Text=sM.."x ▸"end)
    sUp.MouseButton1Click:Connect(function()sI=math.min(#SP,sI+1);sM=SP[sI];sDp.Text=sM.."x";spdB.Text=sM.."x ▸"end)

    -- Transpose
    local tpF=Instance.new("Frame",t4f)
    tpF.Size=UDim2.new(1,-4,0,26);tpF.BackgroundColor3=C.card
    tpF.BorderSizePixel=0;tpF.LayoutOrder=3;cr(tpF,4)
    ln(tpF,UDim2.new(.4,0,1,0),UDim2.new(0,8,0,0),"🎵 Transpose",C.t1,8,Enum.Font.GothamBold).TextYAlignment=Enum.TextYAlignment.Center
    local transpose=0
    local tpDn=bt(tpF,UDim2.new(0,20,0,16),UDim2.new(1,-72,0,5),C.bg,"◀",C.t2,9)
    local tpDp=ln(tpF,UDim2.new(0,28,0,16),UDim2.new(1,-50,0,5),"0",C.t1,8,Enum.Font.GothamBold)
    tpDp.TextXAlignment=Enum.TextXAlignment.Center;tpDp.TextYAlignment=Enum.TextYAlignment.Center
    local tpUp=bt(tpF,UDim2.new(0,20,0,16),UDim2.new(1,-22,0,5),C.bg,"▶",C.t2,9)
    tpDn.MouseButton1Click:Connect(function()transpose=math.max(-12,transpose-1);tpDp.Text=tostring(transpose)end)
    tpUp.MouseButton1Click:Connect(function()transpose=math.min(12,transpose+1);tpDp.Text=tostring(transpose)end)

    -- ══════════════════════════════════
    -- TAB 5: INFO
    -- ══════════════════════════════════
    local t5f=tFs[5]
    local infoTxt={
        "🎸 Auto Guitar [Reworked] v1.0",
        "made by me n team · "..#PS.." songs",
        "",
        "Features:",
        "• "..#PS.." MIDI songs auto-play",
        "• Baca file .mid binary langsung",
        "• Mapping 78 keys guitar (6 row)",
        "• Custom MIDI URL loader",
        "• Speed 0.5x — 2.0x",
        "• Transpose ±12 semitone",
        "• Auto-Next & Shuffle",
        "• Progress bar + live stats",
        "• 5 artist filter tabs",
        "",
        "Cara Pakai:",
        "1. Join Virtual Band",
        "2. Execute script ini",
        "3. Tab Songs → pilih lagu → ▶",
        "4. Atau paste custom .mid URL",
        "5. Enjoy auto-guitar! 🎸",
        "",
        "Custom MIDI:",
        "Upload .mid ke GitHub → Raw URL",
        "Paste di kolom Custom MIDI",
        "",
        "Key Layout:",
        "6 row × 13 key = 78 posisi",
        "MIDI note 36-113 (C2-F8)",
        "Auto-transpose jika keluar range",
        "",
        "made by me n team ❤️",
    }
    for i,tx in ipairs(infoTxt)do
        local f=Instance.new("Frame",t5f)
        f.Size=UDim2.new(1,-4,0,tx==""and 4 or 11)
        f.BackgroundTransparency=1;f.LayoutOrder=i
        if tx~="" then
            local bold=tx:find("🎸")or tx:find("made by")or(tx:find(":")and #tx<25)
            ln(f,UDim2.new(1,0,1,0),UDim2.new(),tx,bold and C.t1 or C.t3,bold and 8 or 7,
               bold and Enum.Font.GothamBold or Enum.Font.Gotham)
        end
    end

    -- ══════════════════════════════════
    -- REFRESH LOOP
    -- ══════════════════════════════════
    local function ref()
        pcall(function()
            if _G._AG then
                togB.Text="⏹ Stop";togB.BackgroundColor3=C.red
                sDot.BackgroundColor3=C.grn
            else
                togB.Text="▶ Play";togB.BackgroundColor3=C.grn
                sDot.BackgroundColor3=C.tog
            end

            spdB.Text=sM.."x ▸"

            local bs=mObj and tostring(mObj.bpm) or "--"
            npBpm.Text=bs.." BPM"

            if cSong~="" then
                npN.Text=cSong;npA.Text=bs.." BPM"
            elseif _G._AG then
                npN.Text="Playing...";npA.Text="Guitar"
            else
                npN.Text="Not Playing";npA.Text="Select a song"
            end

            local pc=math.clamp(mPr,0,1)
            pFl.Size=UDim2.new(pc,0,1,0)
            pFl.BackgroundColor3=pc>=1 and C.grn or C.gtr

            pTm.Text=mObj and (mTm.." · "..math.floor(pc*100).."%") or "∞"

            sH.Text=tostring(tH)
            sN.Text=tostring(nps())
            sL.Text=tostring(lps)
            sSc.Text=secN

            if mObj and not mLd then
                mLb.Text="✅ "..mObj.cnt.."n · "..mObj.bpm.."BPM"
                mLb.TextColor3=C.grn
            elseif not mLd then
                mLb.Text="No MIDI loaded"
                mLb.TextColor3=C.t3
            end
        end)
    end

    task.spawn(function()
        while gui and gui.Parent do
            pcall(ref);task.wait(.25)
        end
    end)

    -- ══════════════════════════════════
    -- DOLOAD FUNCTION
    -- ══════════════════════════════════
    doLoad=function(u,nm)
        if mLd then return end
        mLd=true
        local wasPlaying=_G._AG
        if wasPlaying then stp();task.wait(.15)end

        ldB.Text="⏳"
        mLb.Text="⏳ Loading...";mLb.TextColor3=C.acc

        -- Highlight lagu yang dipilih
        for i,q in ipairs(qBs)do
            for _,c in ipairs(q.row:GetChildren())do
                if c:IsA("UIStroke")then c:Destroy()end
            end
        end
        if aSg then
            local s=Instance.new("UIStroke",qBs[aSg].row)
            s.Color=C.gtr;s.Thickness=1.5
        end

        task.spawn(function()
            local d,e=loadMd(u,function(m)
                mLb.Text="⏳ "..m;mLb.TextColor3=C.acc
            end)
            mLd=false;ldB.Text="📥 Load"

            if d then
                -- Apply transpose ke mapping
                if transpose~=0 then
                    local newGM={}
                    for note,key in pairs(GM)do
                        newGM[note+transpose]=key
                    end
                    -- Rebuild sequence dengan transpose
                    local ns2,ts2,ppq2=M.parse(fetch(u))
                    if ns2 then
                        -- Shift semua note
                        for _,n in ipairs(ns2)do
                            n[2]=n[2]+transpose
                        end
                        local sq2,dur2,bpm2,cnt2=M.build(ns2,ts2,ppq2)
                        if sq2 then d={sq=sq2,dur=dur2,bpm=bpm2,cnt=cnt2}end
                    end
                end

                mObj=d;cSong=nm or "Custom"
                tH=0;lps=0;mPr=0;secN="LOADED"

                ref()
                task.wait(.2)
                if not _G._AG then
                    go()
                    ref()
                end

                -- Notifikasi
                pcall(function()
                    game:GetService("StarterGui"):SetCore("SendNotification",{
                        Title="🎸 "..cSong,
                        Text=d.cnt.." notes · "..d.bpm.." BPM",
                        Duration=3
                    })
                end)
            else
                mLb.Text="❌ "..tostring(e):sub(1,22)
                mLb.TextColor3=C.red
                warn("[AutoGuitar] Load error:",e)
            end
        end)
    end

    -- ══════════════════════════════════
    -- CONNECTIONS
    -- ══════════════════════════════════
    togB.MouseButton1Click:Connect(function()
        if _G._AG then stp() else
            if mObj then go() end
        end
        ref()
    end)

    spdB.MouseButton1Click:Connect(function()
        sI=sI%#SP+1;sM=SP[sI]
        sDp.Text=sM.."x";spdB.Text=sM.."x ▸"
    end)

    ldB.MouseButton1Click:Connect(function()
        local u=uBox.Text:match("^%s*(.-)%s*$")
        if u and u~="" then
            aSg=nil
            doLoad(u,u:match("([^/]+)%.mid") or "Custom")
        else
            mLb.Text="⚠ Paste URL .mid dulu!";mLb.TextColor3=C.acc
        end
    end)

    -- Confirm close
    clB.MouseButton1Click:Connect(function()
        local ov=Instance.new("Frame",gui)
        ov.Size=UDim2.new(1,0,1,0);ov.BackgroundColor3=Color3.new(0,0,0)
        ov.BackgroundTransparency=.5;ov.BorderSizePixel=0;ov.ZIndex=50

        local bx=Instance.new("Frame",ov)
        bx.Size=UDim2.new(0,200,0,90);bx.Position=UDim2.new(.5,-100,.5,-45)
        bx.BackgroundColor3=C.bg;bx.BorderSizePixel=0;bx.ZIndex=51;cr(bx,4)
        Instance.new("UIStroke",bx).Color=C.div

        local tl=ln(bx,UDim2.new(1,0,0,14),UDim2.new(0,0,0,8),"⚠️ Close Auto Guitar?",C.t1,10,Enum.Font.GothamBold)
        tl.TextXAlignment=Enum.TextXAlignment.Center;tl.ZIndex=52

        local yB=bt(bx,UDim2.new(0,70,0,24),UDim2.new(0,15,0,52),C.red,"Yes, close",C.w,8);yB.ZIndex=52
        local nB=bt(bx,UDim2.new(0,70,0,24),UDim2.new(0,115,0,52),C.card,"Cancel",C.t1,8);nB.ZIndex=52
        Instance.new("UIStroke",nB).Color=C.div

        yB.MouseButton1Click:Connect(function()
            ov:Destroy();stp();task.wait(.1)
            gui:Destroy()
            if kC then kC:Disconnect()end
            _G._AG=nil
        end)
        nB.MouseButton1Click:Connect(function()ov:Destroy()end)
    end)

    mnB.MouseButton1Click:Connect(function()mf.Visible=false;mini.Visible=true end)
    mini.MouseButton1Click:Connect(function()mf.Visible=true;mini.Visible=false end)

    -- Keyboard shortcut P = toggle
    kC=UIS.InputBegan:Connect(function(i,g)
        if g then return end
        if i.KeyCode==Enum.KeyCode.P then
            if _G._AG then stp() else if mObj then go() end end
        end
    end)

    -- Startup
    aFl("All");ref()

    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification",{
            Title="🎸 Auto Guitar [Reworked]",
            Text="v1.0 · "..#PS.." songs · Siap!",
            Duration=3
        })
    end)

    print("🎸 Auto Guitar [Reworked] v1.0")
    print("  "..#PS.." songs · Guitar MIDI Player")
    print("  P = Play/Stop")
end

