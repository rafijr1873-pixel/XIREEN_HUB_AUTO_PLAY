-- ========================================
-- SPEED SLIDER LOGIC
-- ========================================

local draggingSpeed = false

local function updateSpeed(ratio)
    ratio = math.clamp(ratio, 0, 1)
    -- Range: 0.25x (kiri) sampai 3x (kanan)
    playSpeed = 0.25 + ratio * 2.75
    spdFill.Size = UDim2.new(ratio, 0, 1, 0)
    spdHandle.Position = UDim2.new(ratio, 0, 0.5, 0)
    spdLbl.Text = string.format("⚡ Speed: %.2fx", playSpeed)
end

updateSpeed(0.33) -- Default 1x

spdTrack.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        draggingSpeed = true
        local abs = spdTrack.AbsolutePosition
        local sz  = spdTrack.AbsoluteSize
        local ratio = (inp.Position.X - abs.X) / sz.X
        updateSpeed(ratio)
    end
end)

UserInputService.InputChanged:Connect(function(inp)
    if draggingSpeed then
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            local abs = spdTrack.AbsolutePosition
            local sz  = spdTrack.AbsoluteSize
            local ratio = (inp.Position.X - abs.X) / sz.X
            updateSpeed(ratio)
        end
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        draggingSpeed = false
    end
end)

-- ========================================
-- MIDI LOAD & PLAY FUNCTIONS
-- ========================================

local function setStatus(txt, col)
    statusLbl.Text = "⏺ " .. txt
    statusLbl.TextColor3 = col or Color3.fromRGB(150, 255, 150)
end

local function stopPlay()
    isPlaying = false
    isPaused = false
    if playCoroutine then
        task.cancel(playCoroutine)
        playCoroutine = nil
    end
    progressFill.Size = UDim2.new(0, 0, 1, 0)
    pauseBtn.Text = "⏸ PAUSE"
    pauseBtn.BackgroundColor3 = Color3.fromRGB(200, 140, 0)
end

local function loadMidi()
    local url = urlBox.Text:match("^%s*(.-)%s*$")

    if url == "" then
        setStatus("Masukkan URL terlebih dahulu!", Color3.fromRGB(255,100,100))
        return
    end

    -- Konversi github.com/blob/ -> raw.githubusercontent.com
    url = url:gsub("https://github%.com/([^/]+)/([^/]+)/blob/(.+)",
                   "https://raw.githubusercontent.com/%1/%2/%3")

    setStatus("Mengunduh file .mid ...", Color3.fromRGB(255, 200, 0))
    infoLbl.Text = "📥 Sedang mengunduh..."
    infoLbl.TextColor3 = Color3.fromRGB(255, 200, 0)

    task.spawn(function()
        local ok, result = pcall(function()
            return HttpService:GetAsync(url, true)
        end)

        if not ok then
            setStatus("Gagal download! Cek URL / HttpService", Color3.fromRGB(255,80,80))
            infoLbl.Text = "❌ Error: " .. tostring(result):sub(1, 60)
            infoLbl.TextColor3 = Color3.fromRGB(255, 80, 80)
            warn("[MidiGUI] HTTP Error:", result)
            return
        end

        -- Parse MIDI binary
        setStatus("Parsing file .mid ...", Color3.fromRGB(255, 200, 0))
        local events, err, info = MidiParser.parse(result)

        if err then
            setStatus("Parse gagal: " .. err, Color3.fromRGB(255,80,80))
            infoLbl.Text = "❌ " .. err
            infoLbl.TextColor3 = Color3.fromRGB(255, 80, 80)
            warn("[MidiGUI] Parse error:", err)
            return
        end

        midiEvents = events
        loadedInfo = info or {}
        stopPlay()

        local dur = 0
        if #midiEvents > 0 then
            dur = midiEvents[#midiEvents].time
        end

        setStatus(string.format("✅ Loaded! %d notes | %.1f detik", #midiEvents, dur),
                  Color3.fromRGB(100, 255, 150))
        infoLbl.Text = string.format("✅ Format MIDI %d | %d Track | %d Notes | %.1fs",
            loadedInfo.format or 0,
            loadedInfo.numTracks or 0,
            #midiEvents, dur)
        infoLbl.TextColor3 = Color3.fromRGB(100, 255, 150)
    end)
end

local function playMidi()
    if #midiEvents == 0 then
        setStatus("Load file .mid dulu!", Color3.fromRGB(255, 150, 0))
        return
    end
    if isPlaying then return end

    isPlaying = true
    isPaused = false
    setStatus("▶ Sedang main...", Color3.fromRGB(50, 255, 150))

    local totalNotes = #midiEvents
    local totalTime = midiEvents[totalNotes] and midiEvents[totalNotes].time or 1

    playCoroutine = task.spawn(function()
        local startTick = tick()
        local eventIndex = 1
        local pauseOffset = 0
        local pauseStart = 0

        while eventIndex <= totalNotes and isPlaying do
            if isPaused then
                if pauseStart == 0 then
                    pauseStart = tick()
                end
                task.wait(0.05)
                continue
            else
                if pauseStart > 0 then
                    pauseOffset = pauseOffset + (tick() - pauseStart)
                    pauseStart = 0
                end
            end

            local evt = midiEvents[eventIndex]
            local targetTime = evt.time / playSpeed
            local elapsed = tick() - startTick - pauseOffset

            local waitTime = targetTime - elapsed
            if waitTime > 0 then
                task.wait(waitTime)
            end

            if not isPlaying then break end
            if isPaused then continue end

            -- Cari key untuk note ini
            local key = noteToKey[evt.note]

            -- Transpose jika note di luar range
            if not key then
                -- Coba oktaf di atas/bawah
                local shifted = evt.note
                while shifted > 113 do shifted = shifted - 12 end
                while shifted < 36  do shifted = shifted + 12 end
                key = noteToKey[shifted]
            end

            if key and evt.velocity > 0 then
                pressKey(key)
            end

            -- Update progress bar
            local progress = math.min(evt.time / totalTime, 1)
            progressFill.Size = UDim2.new(progress, 0, 1, 0)

            -- Update status setiap 10 notes
            if eventIndex % 10 == 0 then
                setStatus(string.format("▶ %d/%d notes | %.1fs", eventIndex, totalNotes, evt.time),
                          Color3.fromRGB(50, 255, 150))
            end

            eventIndex = eventIndex + 1
        end

        -- Selesai
        if isPlaying then
            isPlaying = false
            setStatus("✅ Selesai!", Color3.fromRGB(100, 255, 100))
            progressFill.Size = UDim2.new(1, 0, 1, 0)
            task.wait(1)
            progressFill.Size = UDim2.new(0, 0, 1, 0)
        end
    end)
end

