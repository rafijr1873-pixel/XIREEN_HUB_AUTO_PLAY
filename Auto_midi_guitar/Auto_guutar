local function pressKey(keyCode)
    pcall(function()
        VIM:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.05)
        VIM:SendKeyEvent(false, keyCode, false, game)
    end)
    totalHits = totalHits + 1
end

-- ═══════════════════════════════
-- PLAY LOOP
-- ═══════════════════════════════

local function formatTime(s)
    s = math.max(0, math.floor(s))
    return string.format("%d:%02d", math.floor(s/60), s%60)
end

local function stopPlay()
    isPlaying = false
    if playThread then
        pcall(function() task.cancel(playThread) end)
        playThread = nil
    end
    midiProgress = 0
end

local function startPlay()
    if isPlaying then return end
    if not midiData then return end

    isPlaying = true
    totalHits = 0

    playThread = task.spawn(function()
        repeat
            local seq = midiData.sequence
            local totalTime = midiData.duration / playSpeed
            local startTime = tick()

            for i = 1, #seq do
                if not isPlaying then
                    midiProgress = 0
                    return
                end

                local event = seq[i]
                local targetTime = startTime + (event.time / playSpeed)
                local now = tick()

                if targetTime > now + 0.001 then
                    task.wait(targetTime - now)
                end

                if not isPlaying then
                    midiProgress = 0
                    return
                end

                -- Press keys
                for _, key in ipairs(event.keys) do
                    task.spawn(function()
                        pressKey(key)
                    end)
                end

                midiProgress = i / #seq
                midiTime = formatTime(tick() - startTime) .. "/" .. formatTime(totalTime)
            end

            loopCount = loopCount + 1
            midiProgress = 1

            if not autoNext then
                task.wait(0.5)
            else
                -- Auto next song
                task.wait(0.5)
                if currentSongIndex then
                    local nextIdx
                    if shuffleMode then
                        nextIdx = math.random(1, #Songs)
                    else
                        nextIdx = (currentSongIndex % #Songs) + 1
                    end
                    currentSongIndex = nextIdx
                    -- Will be handled by GUI
                end
            end

        until not isPlaying or not autoNext

        isPlaying = false
        midiProgress = 0
    end)
end

