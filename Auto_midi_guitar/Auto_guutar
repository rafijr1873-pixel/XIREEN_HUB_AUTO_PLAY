-- TOGGLE GUI ANIMATION
-- ========================================

local function toggleGui()
    if isAnimating then return end
    isAnimating = true
    guiVisible = not guiVisible

    local totalH = midiPanelVisible and 650 or 415
    local targetPos = guiVisible
        and UDim2.new(0, 0, 1, -totalH)
        or  UDim2.new(0, 0, 1, 5)

    local tween = TweenService:Create(
        MainFrame,
        TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Position = targetPos}
    )
    tween:Play()
    tween.Completed:Connect(function() isAnimating = false end)

    TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
        BackgroundColor3 = guiVisible
            and Color3.fromRGB(0, 100, 200)
            or  Color3.fromRGB(30, 30, 30)
    }):Play()
end

ToggleBtn.MouseButton1Click:Connect(toggleGui)

