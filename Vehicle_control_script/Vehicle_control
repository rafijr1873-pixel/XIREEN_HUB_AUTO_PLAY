    local function onVehicleEnter(vehicle)
        currentVehicle = vehicle
        ToggleBtn.Visible = true
        
        -- Apply speed settings
        if autoTurbo3 then
            setVehicleSpeed(vehicle, TURBO3_SPEED)
        elseif autoMaxSpeed then
            setVehicleSpeed(vehicle, MAX_SPEED)
        end
        
        showNotif("🚗 Kendaraan Terdeteksi! Ketuk 🚗", Color3.fromRGB(120, 0, 255))
        
        -- Animate toggle button
        TweenService:Create(ToggleBtn, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
            Size = UDim2.new(0, 60, 0, 60)
        }):Play()
    end
    
    local function onVehicleLeave()
        currentVehicle = nil
        ToggleBtn.Visible = false
        
        if isMenuVisible then
            isMenuVisible = false
            TweenService:Create(MenuFrame, TweenInfo.new(0.3), {
                Position = UDim2.new(-0.5, 0, 0.5, -275)
            }):Play()
            task.delay(0.3, function()
                MenuFrame.Visible = false
            end)
        end
        
        showNotif("🚶 Keluar dari Kendaraan", Color3.fromRGB(150, 150, 200))
    end
    
    -- ========================================
    -- SPEED DISPLAY UPDATE
    -- ========================================
    
    RunService.Heartbeat:Connect(function()
        local vehicle = getVehicle()
        
        if vehicle ~= currentVehicle then
            if vehicle then
                onVehicleEnter(vehicle)
            else
                onVehicleLeave()
            end
        end
        
        -- Update speed display
        if vehicle then
            local primaryPart = vehicle.PrimaryPart or vehicle:FindFirstChild("VehicleSeat")
            if primaryPart and primaryPart:IsA("BasePart") then
                local speed = math.floor(primaryPart.Velocity.Magnitude * 3.6)
                currentSpeed = speed
                SpeedValue.Text = speed .. " km/h"
                
                -- Color based on speed
                if speed > 200 then
                    SpeedValue.TextColor3 = Color3.fromRGB(255, 50, 50)
                    StatusDot.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                elseif speed > 100 then
                    SpeedValue.TextColor3 = Color3.fromRGB(255, 150, 0)
                    StatusDot.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
                else
                    SpeedValue.TextColor3 = Color3.fromRGB(0, 255, 100)
                    StatusDot.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                end
            end
            
            -- Apply auto speed settings
            if autoTurbo3 then
                setVehicleSpeed(vehicle, TURBO3_SPEED)
            elseif autoMaxSpeed then
                setVehicleSpeed(vehicle, MAX_SPEED)
            end
        else
            SpeedValue.Text = "0 km/h"
            StatusDot.BackgroundColor3 = Color3.fromRGB(100, 100, 150)
        end
        
        -- God Mode Regeneration
        if godMode then
            local char = Player.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health < humanoid.MaxHealth then
                    humanoid.Health = humanoid.MaxHealth
                end
            end
        end
    end)
    
