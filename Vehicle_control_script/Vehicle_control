    local function getVehicle()
        local char = Player.Character
        if not char then return nil end
        
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid and humanoid.SeatPart then
            return humanoid.SeatPart.Parent
        end
        return nil
    end
    
    local function setVehicleSpeed(vehicle, speed)
        if not vehicle then return end
        
        for _, part in pairs(vehicle:GetDescendants()) do
            if part:IsA("VehicleSeat") then
                part.MaxSpeed = speed
                break
            end
        end
    end
    
    local function applyTorque(vehicle, torqueValue)
        if not vehicle then return end
        
        for _, part in pairs(vehicle:GetDescendants()) do
            if part:IsA("VehicleSeat") then
                part.Throttle = torqueValue
                break
            end
        end
    end
    
    local function toggleFeature(toggle, dot, state, onColor)
        if state then
            TweenService:Create(toggle, TweenInfo.new(0.3), {
                BackgroundColor3 = onColor
            }):Play()
            TweenService:Create(dot, TweenInfo.new(0.3), {
                Position = UDim2.new(1, -22, 0.5, -9)
            }):Play()
        else
            TweenService:Create(toggle, TweenInfo.new(0.3), {
                BackgroundColor3 = Color3.fromRGB(50, 50, 80)
            }):Play()
            TweenService:Create(dot, TweenInfo.new(0.3), {
                Position = UDim2.new(0, 3, 0.5, -9)
            }):Play()
        end
    end
    
